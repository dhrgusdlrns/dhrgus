#. REC: INFO:NAM1
msgctxt "00258E"
msgid "Goddamnit!"
msgstr ""

#. List: 2
#. EDID: [0108BD33]
#. REC: INFO:NAM1
msgctxt "0025A0"
msgid "[Forest]"
msgstr ""

#. List: 2
#. EDID: [0108BD34]
#. REC: INFO:NAM1
msgctxt "0025A1"
msgid "[Volcanic]"
msgstr ""

#. List: 2
#. EDID: [0108BD2F]
#. REC: INFO:NAM1
msgctxt "0025A2"
msgid "[Desert] "
msgstr ""

#. List: 2
#. EDID: [0108FD68]
#. REC: INFO:NAM1
msgctxt "0025CA"
msgid "I'd like to know more about your job."
msgstr ""

#. List: 2
#. EDID: [01092C6B]
#. REC: INFO:NAM1
msgctxt "002628"
msgid "Sorry, but I'm not running a charity here. Come back when you have the credits."
msgstr ""

#. List: 2
#. EDID: [01092C6A]
#. REC: INFO:NAM1
msgctxt "002629"
msgid "Come back when you've got the credits, and we'll take care of it then."
msgstr ""

#. List: 2
#. EDID: [01092C69]
#. REC: INFO:NAM1
msgctxt "00262A"
msgid "First things first. When you can pay, we'll do the work. "
msgstr ""

#. List: 2
#. EDID: [01092C68]
#. REC: INFO:NAM1
msgctxt "00262B"
msgid "Don't you worry, we'll get your ship back in tip-top condition."
msgstr ""

#. List: 2
#. EDID: [01092C67]
#. REC: INFO:NAM1
msgctxt "00262C"
msgid "Seen some action, have you? We'll take care of it."
msgstr ""

#. List: 2
#. EDID: [01092C66]
#. REC: INFO:NAM1
msgctxt "00262D"
msgid "We'll get you fixed up in no time."
msgstr ""

#. List: 2
#. EDID: [01092C64]
#. REC: INFO:NAM1
msgctxt "00262E"
msgid "What do you mean? Your ship's in great condition."
msgstr ""

#. List: 2
#. EDID: [01092C63]
#. REC: INFO:NAM1
msgctxt "00262F"
msgid "You really don't know much about ships, do you? There's nothing wrong with yours."
msgstr ""

#. List: 2
#. EDID: [01092C62]
#. REC: INFO:NAM1
msgctxt "002630"
msgid "Well, I don't know what you're seeing, but your ship looks just fine to me."
msgstr ""

#. List: 2
#. EDID: [01092C60]
#. REC: INFO:NAM1
msgctxt "002631"
msgid "[<Global=ShipServicesRepairCost> Credits] My ship needs some repairs."
msgstr ""

#. List: 2
#. EDID: [01083CCA]
#. REC: INFO:NAM1
msgctxt "010588"
msgid "*Sigh*"
msgstr ""

#. List: 2
#. EDID: [01083D22]
#. REC: INFO:NAM1
msgctxt "01058A"
msgid "Oh cool we're fighting. Luckily my stuff is insured."
msgstr ""

#. List: 2
#. EDID: [01083D0E]
#. REC: INFO:NAM1
msgctxt "010590"
msgid "I'll let you borrow my stuff, with interest."
msgstr ""

#. List: 2
#. EDID: [01083E22]
#. REC: INFO:NAM1
msgctxt "010591"
msgid "I can't wait to suck this place dry of all its resources."
msgstr ""

#. List: 2
#. EDID: [01083E21]
#. REC: INFO:NAM1
msgctxt "010592"
msgid "Some will tell you places like this are beautiful. Thankfully, there's therapy for that."
msgstr ""

#. List: 2
#. EDID: [01083D6B]
#. REC: INFO:NAM1
msgctxt "010A41"
msgid "You're back. I guess I'll go put away your coffin."
msgstr ""

#. List: 2
#. EDID: [01083CA2]
#. REC: INFO:NAM1
msgctxt "010A42"
msgid "Oh good, more stuff to kill."
msgstr ""

#. List: 2
#. EDID: [01083C2D]
#. REC: INFO:NAM1
msgctxt "010A43"
msgid "Might be an ambush coming. Fun."
msgstr ""

#. List: 2
#. EDID: [01083D67]
#. REC: INFO:NAM1
msgctxt "010EE5"
msgid "Back again, huh. I'm sure somebody around here's happy about it."
msgstr ""

#. List: 2
#. EDID: [01083C17]
#. REC: INFO:NAM1
msgctxt "010EE7"
msgid "I can't...keep this...up..."
msgstr ""

#. List: 2
#. EDID: [01083C75]
#. REC: INFO:NAM1
msgctxt "010EE8"
msgid "Weapon's offline, Captain."
msgstr ""

#. List: 2
#. EDID: [01083C6D]
#. REC: INFO:NAM1
msgctxt "010EE9"
msgid "Dead ships make for plenty of treasure."
msgstr ""

#. List: 2
#. EDID: [01083D32]
#. REC: INFO:NAM1
msgctxt "010EEF"
msgid "Spells and incantations."
msgstr ""

#. List: 2
#. EDID: [01083E1B]
#. REC: INFO:NAM1
msgctxt "010EF0"
msgid "Scanners say there's no oxygen. I bet it was your fault. "
msgstr ""

#. List: 2
#. EDID: [010276D7]
#. REC: INFO:NAM1
msgctxt "011328"
msgid "Honestly, I'm surprised you're walking around like this."
msgstr ""

#. List: 2
#. EDID: [01083D7D]
#. REC: INFO:NAM1
msgctxt "01135C"
msgid "Let's hear it."
msgstr ""

#. List: 2
#. EDID: [01083CCB]
#. REC: INFO:NAM1
msgctxt "01135D"
msgid "Goddamnit."
msgstr ""

#. List: 2
#. EDID: [01083D7A]
#. REC: INFO:NAM1
msgctxt "0117D2"
msgid "I guess you want to talk."
msgstr ""

#. List: 2
#. EDID: [01083C2A]
#. REC: INFO:NAM1
msgctxt "0117D3"
msgid "Lost them. Not that I was looking that hard."
msgstr ""

#. List: 2
#. EDID: [01083D46]
#. REC: INFO:NAM1
msgctxt "0117D5"
msgid "Huh. Shield systems offline."
msgstr ""

#. List: 2
#. EDID: [01083D42]
#. REC: INFO:NAM1
msgctxt "0117D6"
msgid "Our shields are out. Damn."
msgstr ""

#. List: 2
#. EDID: [01083E18]
#. REC: INFO:NAM1
msgctxt "0117DB"
msgid "It'd be suicide to explore this area without our suits. So, helmets off or what?"
msgstr ""

#. List: 2
#. EDID: [01083E09]
#. REC: INFO:NAM1
msgctxt "0117DC"
msgid "It would've been glorious to be here in the final days. All the screaming and panic... music to my ears."
msgstr ""

#. List: 2
#. EDID: [01083DE2]
#. REC: INFO:NAM1
msgctxt "0117DD"
msgid "Akila does look like a good place to find corpses. They probably just leave them out with the rest of the trash."
msgstr ""

#. List: 2
#. EDID: [01083C76]
#. REC: INFO:NAM1
msgctxt "011CD6"
msgid "And now we've lost our weapon."
msgstr ""

#. List: 2
#. EDID: [01083D1B]
#. REC: INFO:NAM1
msgctxt "011CD7"
msgid "I need hazard pay for this."
msgstr ""

#. List: 2
#. EDID: [01083CBD]
#. REC: INFO:NAM1
msgctxt "011CD9"
msgid "There's something satisfying about putting together your own slum."
msgstr ""

#. List: 2
#. EDID: [01083CA3]
#. REC: INFO:NAM1
msgctxt "012168"
msgid "Lucky you, you get to go to hell."
msgstr ""

#. List: 2
#. EDID: [01083DD7]
#. REC: INFO:NAM1
msgctxt "012169"
msgid "Hmm...Nothing there."
msgstr ""

#. List: 2
#. EDID: [01083C88]
#. REC: INFO:NAM1
msgctxt "01216A"
msgid "Something's wrong with their weapon."
msgstr ""

#. List: 2
#. EDID: [01083E2B]
#. REC: INFO:NAM1
msgctxt "01216C"
msgid "Some say exploring is a rich, rewarding adventure. You should show them this place."
msgstr ""

#. List: 2
#. EDID: [01083CFB]
#. REC: INFO:NAM1
msgctxt "012628"
msgid "It's just us out here."
msgstr ""

#. List: 2
#. EDID: [01083DC9]
#. REC: INFO:NAM1
msgctxt "01262A"
msgid "I'm a fan of gravity personally. I like to keep people down."
msgstr ""

#. List: 2
#. EDID: [01083D30]
#. REC: INFO:NAM1
msgctxt "01262B"
msgid "You should do parties."
msgstr ""

#. List: 2
#. EDID: [01083E14]
#. REC: INFO:NAM1
msgctxt "01262C"
msgid "This planet has no oxygen. You should remove your spacesuit."
msgstr ""

#. List: 2
#. EDID: [01083CD7]
#. REC: INFO:NAM1
msgctxt "01262D"
msgid "I wonder if this ship has its own crew of thralls, like yours does."
msgstr ""

#. List: 2
#. EDID: [01083CD3]
#. REC: INFO:NAM1
msgctxt "01262E"
msgid "So is this gonna be our ship now?"
msgstr ""

#. List: 2
#. EDID: [01083DD6]
#. REC: INFO:NAM1
msgctxt "012AF9"
msgid "And they're gone."
msgstr ""

#. List: 2
#. EDID: [01083CA1]
#. REC: INFO:NAM1
msgctxt "012AFA"
msgid "In for a penny..."
msgstr ""

#. List: 2
#. EDID: [01083C87]
#. REC: INFO:NAM1
msgctxt "012AFB"
msgid "That weapon's decomposing now."
msgstr ""

#. List: 2
#. EDID: [01083E2A]
#. REC: INFO:NAM1
msgctxt "012AFE"
msgid "I bet there's an army of dead things here, just sitting underneath our feet."
msgstr ""

#. List: 2
#. EDID: [01083CC8]
#. REC: INFO:NAM1
msgctxt "012FB2"
msgid "Oh great..."
msgstr ""

#. List: 2
#. EDID: [01083CF7]
#. REC: INFO:NAM1
msgctxt "012FB3"
msgid "Oh neat we can blow stuff up again."
msgstr ""

#. List: 2
#. EDID: [01083C5E]
#. REC: INFO:NAM1
msgctxt "012FB9"
msgid "*Sigh* Fine, I'll live."
msgstr ""

#. List: 2
#. EDID: [01083E34]
#. REC: INFO:NAM1
msgctxt "012FBA"
msgid "Party time I guess."
msgstr ""

#. List: 2
#. EDID: [01083D6A]
#. REC: INFO:NAM1
msgctxt "0136BC"
msgid "You're back. Find any good mushrooms?"
msgstr ""

#. List: 2
#. EDID: [01083E4C]
#. REC: INFO:NAM1
msgctxt "0136BD"
msgid "They're all dead. Cool."
msgstr ""

#. List: 2
#. EDID: [01083C4F]
#. REC: INFO:NAM1
msgctxt "0136BE"
msgid "Do you feel like we're being watched?"
msgstr ""

#. List: 2
#. EDID: [01083D1C]
#. REC: INFO:NAM1
msgctxt "0136BF"
msgid "Would now be a bad time to take a sick day?"
msgstr ""

#. List: 2
#. EDID: [01083D5F]
#. REC: INFO:NAM1
msgctxt "0136C0"
msgid "Bad news, their weapon's back online."
msgstr ""

#. List: 2
#. EDID: [01083DD0]
#. REC: INFO:NAM1
msgctxt "0136C5"
msgid "If one of us starts bleeding, does the blood actually float? How does that work?"
msgstr ""

#. List: 2
#. EDID: [01083E1E]
#. REC: INFO:NAM1
msgctxt "0136C6"
msgid "All this life just makes me sad."
msgstr ""

#. List: 2
#. EDID: [01083DF0]
#. REC: INFO:NAM1
msgctxt "0136C7"
msgid "Imagine living here and not immediately blowing your brains out."
msgstr ""

#. List: 2
#. EDID: [01083D63]
#. REC: INFO:NAM1
msgctxt "013B49"
msgid "Their weapon's repaired. Hooray for them."
msgstr ""

#. List: 2
#. EDID: [01083CBE]
#. REC: INFO:NAM1
msgctxt "013B4C"
msgid "This outpost is looking like a real dump. I'm proud."
msgstr ""

#. List: 2
#. EDID: [01083D11]
#. REC: INFO:NAM1
msgctxt "013B4D"
msgid "Uh huh."
msgstr ""

#. List: 2
#. EDID: [01083E58]
#. REC: INFO:NAM1
msgctxt "013FE0"
msgid "If you end up in hell, don't wait up."
msgstr ""

#. List: 2
#. EDID: [01083DC1]
#. REC: INFO:NAM1
msgctxt "013FE1"
msgid "Ergh!"
msgstr ""

#. List: 2
#. EDID: [01083D27]
#. REC: INFO:NAM1
msgctxt "014485"
msgid "Fire in the hole."
msgstr ""

#. List: 2
#. EDID: [01083C74]
#. REC: INFO:NAM1
msgctxt "014486"
msgid "In case you didn't notice, our weapons are cooked."
msgstr ""

#. List: 2
#. EDID: [01083D5C]
#. REC: INFO:NAM1
msgctxt "014487"
msgid "They're aiming their weapon at us. Maybe we should move."
msgstr ""

#. List: 2
#. EDID: [01083C68]
#. REC: INFO:NAM1
msgctxt "014913"
msgid "That was fun."
msgstr ""

#. List: 2
#. EDID: [01083DF2]
#. REC: INFO:NAM1
msgctxt "014915"
msgid "I'd say most people don't care about Cydonia enough to visit. Not you though."
msgstr ""

#. List: 2
#. EDID: [01083D7B]
#. REC: INFO:NAM1
msgctxt "014DBF"
msgid "Huh? Sorry, I was emptying my brain."
msgstr ""

#. List: 2
#. EDID: [01083DC7]
#. REC: INFO:NAM1
msgctxt "014DC0"
msgid "That hurt!"
msgstr ""

#. List: 2
#. EDID: [01083D44]
#. REC: INFO:NAM1
msgctxt "014DC1"
msgid "Our shields are disabled. Not that it matters. Everyone dies."
msgstr ""

#. List: 2
#. EDID: [01083E02]
#. REC: INFO:NAM1
msgctxt "014DC2"
msgid "The parks and bars here are great for people watching. I like to sit and stare at people being miserable."
msgstr ""

#. List: 2
#. EDID: [01083C78]
#. REC: INFO:NAM1
msgctxt "015278"
msgid "Weapons aren't responding."
msgstr ""

#. List: 2
#. EDID: [01083D62]
#. REC: INFO:NAM1
msgctxt "015279"
msgid "Damn, their weapon's fixed."
msgstr ""

#. List: 2
#. EDID: [01083DD2]
#. REC: INFO:NAM1
msgctxt "01527B"
msgid "I'm floating. You're floating. Cool."
msgstr ""

#. List: 2
#. EDID: [01083E2C]
#. REC: INFO:NAM1
msgctxt "01527C"
msgid "We should take a few dirt samples home. Sell them online."
msgstr ""

#. List: 2
#. EDID: [01083E0D]
#. REC: INFO:NAM1
msgctxt "01527D"
msgid "I've seen pictures of Old Earth. This is better."
msgstr ""

#. List: 2
#. EDID: [01083D0C]
#. REC: INFO:NAM1
msgctxt "01527E"
msgid "Got any dead stuff?"
msgstr ""

#. List: 2
#. EDID: [01083CD4]
#. REC: INFO:NAM1
msgctxt "01527F"
msgid "Wonder how much this ship will fetch on the market."
msgstr ""

#. List: 2
#. EDID: [010276CC]
#. REC: INFO:NAM1
msgctxt "0156E1"
msgid "Suit yourself."
msgstr ""

#. List: 2
#. EDID: [010276DB]
#. REC: INFO:NAM1
msgctxt "0156E2"
msgid "There's nothing wrong with you. You appear in perfect health."
msgstr ""

#. List: 2
#. EDID: [01083DC6]
#. REC: INFO:NAM1
msgctxt "015710"
msgid "Hey!"
msgstr ""

#. List: 2
#. EDID: [01083D1F]
#. REC: INFO:NAM1
msgctxt "015711"
msgid "Yep. This is where we open fire."
msgstr ""

#. List: 2
#. EDID: [01083D5D]
#. REC: INFO:NAM1
msgctxt "015712"
msgid "They fixed their weapon. That was quick."
msgstr ""

#. List: 2
#. EDID: [01083DF9]
#. REC: INFO:NAM1
msgctxt "015714"
msgid "Aurora's a pretty big chem in the cult scene. Pretty damn big."
msgstr ""

#. List: 2
#. EDID: [01083E2F]
#. REC: INFO:NAM1
msgctxt "015B8A"
msgid "This would be a good place to set up a wizard tower."
msgstr ""

#. List: 2
#. EDID: [010388DB]
#. REC: INFO:NAM1
msgctxt "015C22"
msgid "Those pirates better show up soon. Our time is valuable."
msgstr ""

#. List: 2
#. EDID: [010276E2]
#. REC: INFO:NAM1
msgctxt "015FF5"
msgid "Eh. You could probably tough this out if you wanted."
msgstr ""

#. List: 2
#. EDID: [010276EF]
#. REC: INFO:NAM1
msgctxt "015FF6"
msgid "I'm afraid you'll need to cover your own medical expenses today. Come back when you have the credits."
msgstr ""

#. List: 2
#. EDID: [01083CFC]
#. REC: INFO:NAM1
msgctxt "01601D"
msgid "Lost 'em."
msgstr ""

#. List: 2
#. EDID: [01083CB8]
#. REC: INFO:NAM1
msgctxt "01601E"
msgid "You're done."
msgstr ""

#. List: 2
#. EDID: [01083C8B]
#. REC: INFO:NAM1
msgctxt "01601F"
msgid "Their weapon's probably broken?"
msgstr ""

#. List: 2
#. EDID: [01083DFE]
#. REC: INFO:NAM1
msgctxt "016022"
msgid "I wonder what the rent on the Lodge is. I bet it costs more than a spaceship."
msgstr ""

#. List: 2
#. EDID: [01083CD1]
#. REC: INFO:NAM1
msgctxt "016023"
msgid "Let's hope they got some good cargo to loot."
msgstr ""

#. List: 2
#. EDID: [01083D69]
#. REC: INFO:NAM1
msgctxt "0164B5"
msgid "Oh. Hey."
msgstr ""

#. List: 2
#. EDID: [01083D45]
#. REC: INFO:NAM1
msgctxt "0164B6"
msgid "Shields are down."
msgstr ""

#. List: 2
#. EDID: [01083DEF]
#. REC: INFO:NAM1
msgctxt "0164BB"
msgid "I bet people here love that their taxes help fund New Atlantis."
msgstr ""

#. List: 2
#. EDID: [01083C51]
#. REC: INFO:NAM1
msgctxt "016967"
msgid "Trust me, there's something out there."
msgstr ""

#. List: 2
#. EDID: [01083CB9]
#. REC: INFO:NAM1
msgctxt "016968"
msgid "End of the line!"
msgstr ""

#. List: 2
#. EDID: [01083C77]
#. REC: INFO:NAM1
msgctxt "016969"
msgid "Well, weapon's gone."
msgstr ""

#. List: 2
#. EDID: [01083CCF]
#. REC: INFO:NAM1
msgctxt "01696D"
msgid "I like ship invasions. It's like shopping, but everything's free."
msgstr ""

#. List: 2
#. EDID: [010276E8]
#. REC: INFO:NAM1
msgctxt "016DBD"
msgid "Of course. Here's what I have."
msgstr ""

#. List: 2
#. EDID: [01083D05]
#. REC: INFO:NAM1
msgctxt "016DFD"
msgid "Here it comes."
msgstr ""

#. List: 2
#. EDID: [01083DBE]
#. REC: INFO:NAM1
msgctxt "016DFE"
msgid "Urgh!"
msgstr ""

#. List: 2
#. EDID: [010276F9]
#. REC: INFO:NAM1
msgctxt "017257"
msgid "Let me look you over..."
msgstr ""

#. List: 2
#. EDID: [010276D9]
#. REC: INFO:NAM1
msgctxt "0176EB"
msgid "You're lucky I know what I'm doing. Because you're a real mess."
msgstr ""

#. List: 2
#. EDID: [01083E57]
#. REC: INFO:NAM1
msgctxt "01771A"
msgid "I hope these corpses have loot."
msgstr ""

#. List: 2
#. EDID: [010276E7]
#. REC: INFO:NAM1
msgctxt "017B98"
msgid "I'm sure I have something I can spare."
msgstr ""

#. List: 2
#. EDID: [01083DF1]
#. REC: INFO:NAM1
msgctxt "017BC8"
msgid "I heard the miners here have devil eyes, which makes me jealous. But then I remembered mining sucks."
msgstr ""

#. List: 2
#. EDID: [01083E3D]
#. REC: INFO:NAM1
msgctxt "01804F"
msgid "Nice."
msgstr ""

#. List: 2
#. EDID: [01083CDE]
#. REC: INFO:NAM1
msgctxt "018050"
msgid "Environmental hazards. Yay."
msgstr ""

#. List: 2
#. EDID: [01083E32]
#. REC: INFO:NAM1
msgctxt "018051"
msgid "This place reminds me of a mushroom that lived in space. Just fed on dead humans. I like to imagine this place once had humans."
msgstr ""

#. List: 2
#. EDID: [01083E0F]
#. REC: INFO:NAM1
msgctxt "018052"
msgid "I bet some cool fungi survived this."
msgstr ""

#. List: 2
#. EDID: [01083D75]
#. REC: INFO:NAM1
msgctxt "0184DB"
msgid "If I don't get my cat nap the claws come out."
msgstr ""

#. List: 2
#. EDID: [01083DCC]
#. REC: INFO:NAM1
msgctxt "0184E1"
msgid "I'd love to float right into a spike."
msgstr ""

#. List: 2
#. EDID: [01083DF6]
#. REC: INFO:NAM1
msgctxt "0184E2"
msgid "Neon is a colorless, odorless gas. It's scientifically soulless. Makes you think."
msgstr ""

#. List: 2
#. EDID: [01083CD9]
#. REC: INFO:NAM1
msgctxt "0184E3"
msgid "Ignore the beeping noises. It's fine."
msgstr ""

#. List: 2
#. EDID: SE_FAB10SharedInfo01_GoodbyeDUPLICATE000
#. REC: INFO:NAM1
msgctxt "018581"
msgid "Sorry about that, this group certainly is making me earn my paycheck. Clear skies."
msgstr ""

#. List: 2
#. EDID: SE_FAB10SharedInfo01_GoodbyeDUPLICATE000
#. REC: INFO:NAM1
msgctxt "018582"
msgid "You heard the captain. Everyone return to their seats and prepare for our next jump. Mics off?"
msgstr ""

#. List: 2
#. EDID: [01083DE6]
#. REC: INFO:NAM1
msgctxt "018994"
msgid "I hope you like mud on your boots."
msgstr ""

#. List: 2
#. EDID: [01083D7C]
#. REC: INFO:NAM1
msgctxt "018E7D"
msgid "Is it me or is life not worth living anymore."
msgstr ""

#. List: 2
#. EDID: [01083D76]
#. REC: INFO:NAM1
msgctxt "018E7E"
msgid "I need a nap."
msgstr ""

#. List: 2
#. EDID: [01083DFC]
#. REC: INFO:NAM1
msgctxt "018E84"
msgid "Neon has to many gangs, not enough goths."
msgstr ""

#. List: 2
#. EDID: [01083DF3]
#. REC: INFO:NAM1
msgctxt "01933A"
msgid "I thought about interviewing at Ryujin once. But corporations are faceless. I want to see the customer's eyes when I deny them a loan."
msgstr ""

#. List: 2
#. EDID: [01083C9D]
#. REC: INFO:NAM1
msgctxt "019774"
msgid "Do we have to do this now?"
msgstr ""

#. List: 2
#. EDID: [01083DEB]
#. REC: INFO:NAM1
msgctxt "019775"
msgid "I wonder if I can take life insurance policies on the miners."
msgstr ""

#. List: 2
#. EDID: [01083D1A]
#. REC: INFO:NAM1
msgctxt "019C2C"
msgid "I hope these ships have tons of loot."
msgstr ""

#. List: 2
#. EDID: [01083CDA]
#. REC: INFO:NAM1
msgctxt "019C31"
msgid "I love hazards. Walking in to them is always a good time."
msgstr ""

#. List: 2
#. EDID: [01083E15]
#. REC: INFO:NAM1
msgctxt "019C32"
msgid "No need for suits here, Captain. I just wear mine because it's fashionable."
msgstr ""

#. List: 2
#. EDID: [01083E10]
#. REC: INFO:NAM1
msgctxt "019C33"
msgid "I'm disappointed capitalism hasn't found a way to monetize this planet."
msgstr ""

#. List: 2
#. EDID: [01083DF7]
#. REC: INFO:NAM1
msgctxt "019C34"
msgid "I wonder if they ever thought of shipping aurora to a planet that doesn't suck."
msgstr ""

#. List: 2
#. EDID: [01083DE3]
#. REC: INFO:NAM1
msgctxt "019C35"
msgid "Heard there's a lot of bank robberies here. Seems kind of backwards. Banks are supposed to rob you, not the other way around."
msgstr ""

#. List: 2
#. EDID: [01083BEA]
#. REC: INFO:NAM1
msgctxt "01A517"
msgid "I found them!"
msgstr ""

#. List: 2
#. EDID: [01083E19]
#. REC: INFO:NAM1
msgctxt "01A518"
msgid "Scanners say you can't breathe here without a suit. But you won't know until you try it."
msgstr ""

#. List: 2
#. EDID: [010276FB]
#. REC: INFO:NAM1
msgctxt "01A986"
msgid "Alright. Let's examine you..."
msgstr ""

#. List: 2
#. EDID: [01083CC4]
#. REC: INFO:NAM1
msgctxt "01AE6F"
msgid "I appreciate your commitment to being a slumlord."
msgstr ""

#. List: 2
#. EDID: [01083E3C]
#. REC: INFO:NAM1
msgctxt "01AE70"
msgid "Let me know how that works out for you."
msgstr ""

#. List: 2
#. EDID: [01083CDD]
#. REC: INFO:NAM1
msgctxt "01AE71"
msgid "Every time that watch beeps I get excited. Maybe we'll both die in a horrific accident. Fingers crossed."
msgstr ""

#. List: 2
#. EDID: [01083E31]
#. REC: INFO:NAM1
msgctxt "01AE72"
msgid "Finally. A place with no children."
msgstr ""

#. List: 2
#. EDID: [01083E0E]
#. REC: INFO:NAM1
msgctxt "01AE73"
msgid "Seeing the Earth in this state gives me hope for New Atlantis."
msgstr ""

#. List: 2
#. EDID: [01083D34]
#. REC: INFO:NAM1
msgctxt "01AE74"
msgid "You want to teach me how to do that?"
msgstr ""

#. List: 2
#. EDID: [01083DDA]
#. REC: INFO:NAM1
msgctxt "01B321"
msgid "I hope it was a ghost."
msgstr ""

#. List: 2
#. EDID: [01083D28]
#. REC: INFO:NAM1
msgctxt "01B322"
msgid "Blowin' em up."
msgstr ""

#. List: 2
#. EDID: [01083E3A]
#. REC: INFO:NAM1
msgctxt "01B325"
msgid "Hope that's medical grade."
msgstr ""

#. List: 2
#. EDID: [01083DE8]
#. REC: INFO:NAM1
msgctxt "01B326"
msgid "Oh cool, there's a bar by the spaceport."
msgstr ""

#. List: 2
#. EDID: [01083D6C]
#. REC: INFO:NAM1
msgctxt "01B774"
msgid "One day you won't come back alive, and everyone's gonna be all sad and stuff. It'll be great."
msgstr ""

#. List: 2
#. EDID: [01083CAF]
#. REC: INFO:NAM1
msgctxt "01B775"
msgid "You're so dead."
msgstr ""

#. List: 2
#. EDID: [01083CF3]
#. REC: INFO:NAM1
msgctxt "01B776"
msgid "Weapon's fixed, I think."
msgstr ""

#. List: 2
#. EDID: [01083D1E]
#. REC: INFO:NAM1
msgctxt "01B777"
msgid "Let's blow 'em up and take the bodies home."
msgstr ""

#. List: 2
#. EDID: [01083D0B]
#. REC: INFO:NAM1
msgctxt "01B77A"
msgid "Sure, I can take some things."
msgstr ""

#. List: 2
#. EDID: [01083E08]
#. REC: INFO:NAM1
msgctxt "01B77B"
msgid "Earth. It's a necromancer's dream."
msgstr ""

#. List: 2
#. EDID: [01083DEE]
#. REC: INFO:NAM1
msgctxt "01B77C"
msgid "There's a community center here with some real preachy types. They say the sermons are free but they cost your sanity."
msgstr ""

#. List: 2
#. EDID: [01083D9D]
#. REC: INFO:NAM1
msgctxt "01BC1A"
msgid "Don't worry, I'm not dead. I just feel that way."
msgstr ""

#. List: 2
#. EDID: [01083E39]
#. REC: INFO:NAM1
msgctxt "01BC1B"
msgid "If that kills you I call dibs on your corpse."
msgstr ""

#. List: 2
#. EDID: [01083E1F]
#. REC: INFO:NAM1
msgctxt "01BC1C"
msgid "Lot of picaresque views here. Shame if someone put a factory right in the middle of it. "
msgstr ""

#. List: 2
#. EDID: [01083C80]
#. REC: INFO:NAM1
msgctxt "01BC1D"
msgid "I'll be sure to let this betrayal fester."
msgstr ""

#. List: 2
#. EDID: [01083D6F]
#. REC: INFO:NAM1
msgctxt "01C0E2"
msgid "The sooner you leave, the sooner we can all start half-assing it."
msgstr ""

#. List: 2
#. EDID: [01083D20]
#. REC: INFO:NAM1
msgctxt "01C0E3"
msgid "Oh cool. More fighting."
msgstr ""

#. List: 2
#. EDID: [01083D10]
#. REC: INFO:NAM1
msgctxt "01C0E8"
msgid "Yeah, sure."
msgstr ""

#. List: 2
#. EDID: [01083D0A]
#. REC: INFO:NAM1
msgctxt "01C0E9"
msgid "Got any fungi?"
msgstr ""

#. List: 2
#. EDID: [010276ED]
#. REC: INFO:NAM1
msgctxt "01C505"
msgid "I won't lie. You're gonna feel this. But try your best to sit still..."
msgstr ""

#. List: 2
#. EDID: [01083C7B]
#. REC: INFO:NAM1
msgctxt "01C539"
msgid "Weapon's busted. I'll go get my wrench."
msgstr ""

#. List: 2
#. EDID: [01083E4F]
#. REC: INFO:NAM1
msgctxt "01CA1F"
msgid "They're dead. Good for them."
msgstr ""

#. List: 2
#. EDID: [01083CFF]
#. REC: INFO:NAM1
msgctxt "01CA20"
msgid "Must've been my imagination. It does that."
msgstr ""

#. List: 2
#. EDID: [010276E9]
#. REC: INFO:NAM1
msgctxt "01CE3A"
msgid "I trust you'll put this to good use."
msgstr ""

#. List: 2
#. EDID: [01083D71]
#. REC: INFO:NAM1
msgctxt "01CE6D"
msgid "Oh you're back. Everyone here's been talking about you behind it. Not me though. I don't care."
msgstr ""

#. List: 2
#. EDID: [01083D74]
#. REC: INFO:NAM1
msgctxt "01CE6E"
msgid "Bore me. I dare you."
msgstr ""

#. List: 2
#. EDID: [01083D25]
#. REC: INFO:NAM1
msgctxt "01CE6F"
msgid "Grenade."
msgstr ""

#. List: 2
#. EDID: [010388DC]
#. REC: INFO:NAM1
msgctxt "01CEFE"
msgid "If I don't see a pirate in the next hour, I'm shooting one of the help."
msgstr ""

#. List: 2
#. EDID: [01083CF0]
#. REC: INFO:NAM1
msgctxt "01D2CC"
msgid "Nice, you repaired the weapon."
msgstr ""

#. List: 2
#. EDID: [01083CE2]
#. REC: INFO:NAM1
msgctxt "01D2CD"
msgid "Death marches on. So should we."
msgstr ""

#. List: 2
#. EDID: [01083C82]
#. REC: INFO:NAM1
msgctxt "01D2CE"
msgid "Uh huh. I'm sure you have your reasons."
msgstr ""

#. List: 2
#. EDID: [010276DC]
#. REC: INFO:NAM1
msgctxt "01D79F"
msgid "I see nothing here that needs healing. Nothing physical anyway."
msgstr ""

#. List: 2
#. EDID: [01083D70]
#. REC: INFO:NAM1
msgctxt "01D7CF"
msgid "Yeah, I'm bored."
msgstr ""

#. List: 2
#. EDID: [01083C19]
#. REC: INFO:NAM1
msgctxt "01D7D0"
msgid "I-I need...help..."
msgstr ""

#. List: 2
#. EDID: [01083DBB]
#. REC: INFO:NAM1
msgctxt "01D7D1"
msgid "Ugh!"
msgstr ""

#. List: 2
#. EDID: [01083CF5]
#. REC: INFO:NAM1
msgctxt "01D7D2"
msgid "Weapon's online, back to shooting stuff."
msgstr ""

#. List: 2
#. EDID: [01083CDF]
#. REC: INFO:NAM1
msgctxt "01D7D6"
msgid "If your watch starts beeping like that it's usually a good sign to keep going."
msgstr ""

#. List: 2
#. EDID: [01083CDB]
#. REC: INFO:NAM1
msgctxt "01D7D7"
msgid "The warnings are just suggestions, really."
msgstr ""

#. List: 2
#. EDID: [01083D0D]
#. REC: INFO:NAM1
msgctxt "01D7D8"
msgid "I've got a dead spider in my bag if you want it."
msgstr ""

#. List: 2
#. EDID: [01083CCC]
#. REC: INFO:NAM1
msgctxt "01DC47"
msgid "Guess we're doing this."
msgstr ""

#. List: 2
#. EDID: [01083D01]
#. REC: INFO:NAM1
msgctxt "01DC48"
msgid "Oh boy."
msgstr ""

#. List: 2
#. EDID: [01083C71]
#. REC: INFO:NAM1
msgctxt "01DC49"
msgid "Time for dessert."
msgstr ""

#. List: 2
#. EDID: [01083C7E]
#. REC: INFO:NAM1
msgctxt "01DC4B"
msgid "Guess it was something I said."
msgstr ""

#. List: 2
#. EDID: [01083E35]
#. REC: INFO:NAM1
msgctxt "01DC4C"
msgid "You need to introduce me to your dealer."
msgstr ""

#. List: 2
#. EDID: [01083D43]
#. REC: INFO:NAM1
msgctxt "01E0F9"
msgid "The shields need more power. You should probably get on that."
msgstr ""

#. List: 2
#. EDID: [01083DD1]
#. REC: INFO:NAM1
msgctxt "01E0FD"
msgid "*Sigh* Here we go..."
msgstr ""

#. List: 2
#. EDID: [01083E37]
#. REC: INFO:NAM1
msgctxt "01E0FE"
msgid "Chems are just magic potions with different packaging."
msgstr ""

#. List: 2
#. EDID: [01083E26]
#. REC: INFO:NAM1
msgctxt "01E0FF"
msgid "I hope you don't assign me to work on this rock. It's too... pretty."
msgstr ""

#. List: 2
#. EDID: [01083DE7]
#. REC: INFO:NAM1
msgctxt "01E100"
msgid "This place looks dirty."
msgstr ""

#. List: 2
#. EDID: [01083CE1]
#. REC: INFO:NAM1
msgctxt "01E101"
msgid "This place isn't safe. We should build a home here."
msgstr ""

#. List: 2
#. EDID: [01083CDC]
#. REC: INFO:NAM1
msgctxt "01E102"
msgid "Your watch sure likes to make noise."
msgstr ""

#. List: 2
#. EDID: [01083D68]
#. REC: INFO:NAM1
msgctxt "01E58C"
msgid "I think for my next job, I'll be something low key, like a waitress, or a cannibal."
msgstr ""

#. List: 2
#. EDID: [01083DC4]
#. REC: INFO:NAM1
msgctxt "01E58D"
msgid "Unh!"
msgstr ""

#. List: 2
#. EDID: [01083D23]
#. REC: INFO:NAM1
msgctxt "01E58E"
msgid " Let's hope everyone on their side dies."
msgstr ""

#. List: 2
#. EDID: [01083D49]
#. REC: INFO:NAM1
msgctxt "01E58F"
msgid "Shields are overrated anyway."
msgstr ""

#. List: 2
#. EDID: [01083E20]
#. REC: INFO:NAM1
msgctxt "01E594"
msgid "I hope we find sentient life here. I'd love to introduce them to the concept of credit cards."
msgstr ""

#. List: 2
#. EDID: [01083C9B]
#. REC: INFO:NAM1
msgctxt "01EA47"
msgid "Ready, fight."
msgstr ""

#. List: 2
#. EDID: [01083DFB]
#. REC: INFO:NAM1
msgctxt "01EA49"
msgid "Does Neon have schools? Or did they find a way to eradicate children?"
msgstr ""

#. List: 2
#. EDID: [01083CB7]
#. REC: INFO:NAM1
msgctxt "01EEC7"
msgid "Try me."
msgstr ""

#. List: 2
#. EDID: [01083C79]
#. REC: INFO:NAM1
msgctxt "01EEC8"
msgid "Weapons need repairs."
msgstr ""

#. List: 2
#. EDID: [01083E00]
#. REC: INFO:NAM1
msgctxt "01EECD"
msgid "I used to know soemone who worked at MAST. Talked in their sleep. So I don't trust their agents to keep secrets."
msgstr ""

#. List: 2
#. EDID: [01083C52]
#. REC: INFO:NAM1
msgctxt "01F3C2"
msgid "I don't think we're the only ones here."
msgstr ""

#. List: 2
#. EDID: [01083DCB]
#. REC: INFO:NAM1
msgctxt "01F3C3"
msgid "Hey, beats walking."
msgstr ""

#. List: 2
#. EDID: [010276D1]
#. REC: INFO:NAM1
msgctxt "01F780"
msgid "There, good as new. More or less."
msgstr ""

#. List: 2
#. EDID: [01083C9A]
#. REC: INFO:NAM1
msgctxt "01F7BF"
msgid "Here they come."
msgstr ""

#. List: 2
#. EDID: [01083E51]
#. REC: INFO:NAM1
msgctxt "01F7C0"
msgid "They're dead. Guess this place is now haunted."
msgstr ""

#. List: 2
#. EDID: [01083DFA]
#. REC: INFO:NAM1
msgctxt "01F7C1"
msgid "You can smell vice in the air.  No, wait, that's just garbage."
msgstr ""

#. List: 2
#. EDID: [01083C2B]
#. REC: INFO:NAM1
msgctxt "01FCD3"
msgid "I feel like they're still close by."
msgstr ""

#. List: 2
#. EDID: [01083CB0]
#. REC: INFO:NAM1
msgctxt "01FCD4"
msgid "Time's up."
msgstr ""

#. List: 2
#. EDID: [01083C73]
#. REC: INFO:NAM1
msgctxt "01FCD5"
msgid "Might wanna check our weapons."
msgstr ""

#. List: 2
#. EDID: [010276DD]
#. REC: INFO:NAM1
msgctxt "020128"
msgid "You seem in perfect health to me. But a little rest and relaxation might help if you are feeling off."
msgstr ""

#. List: 2
#. EDID: [01083DD8]
#. REC: INFO:NAM1
msgctxt "02016F"
msgid "I must be imagining things. Good."
msgstr ""

#. List: 2
#. EDID: [01083DBF]
#. REC: INFO:NAM1
msgctxt "020170"
msgid "Oof!"
msgstr ""

#. List: 2
#. EDID: [010276FA]
#. REC: INFO:NAM1
msgctxt "0205E4"
msgid "Let's take a look..."
msgstr ""

#. List: 2
#. EDID: [01083C4E]
#. REC: INFO:NAM1
msgctxt "020A63"
msgid "I think I hear something."
msgstr ""

#. List: 2
#. EDID: [01083D02]
#. REC: INFO:NAM1
msgctxt "020A64"
msgid "Incoming."
msgstr ""

#. List: 2
#. EDID: [01083DC2]
#. REC: INFO:NAM1
msgctxt "020A65"
msgid "Damn!"
msgstr ""

#. List: 2
#. EDID: [01083D29]
#. REC: INFO:NAM1
msgctxt "020A66"
msgid "Time to make a mess."
msgstr ""

#. List: 2
#. EDID: [01083E1C]
#. REC: INFO:NAM1
msgctxt "020A6B"
msgid "You put a couple of slate-casters on a planet like this, all the oxygen gets sucked out in minutes. I'm guessing that's what happened here."
msgstr ""

#. List: 2
#. EDID: [01083E0B]
#. REC: INFO:NAM1
msgctxt "020A6C"
msgid "Earth, huh. I thought there'd be more stuff going on here."
msgstr ""

#. List: 2
#. EDID: [010276F1]
#. REC: INFO:NAM1
msgctxt "020EEF"
msgid "I'm sorry, you don't have enough credits. You'll need to come back when you can afford to pay. "
msgstr ""

#. List: 2
#. EDID: [01083E53]
#. REC: INFO:NAM1
msgctxt "020F2E"
msgid "That was kind of fun."
msgstr ""

#. List: 2
#. EDID: [01083D26]
#. REC: INFO:NAM1
msgctxt "020F2F"
msgid "Here it comes."
msgstr ""

#. List: 2
#. EDID: [01083DFF]
#. REC: INFO:NAM1
msgctxt "020F33"
msgid "God I wish there were merpeople here. If you're gonna call it New \"Atlantis,\"  give me some merpeople."
msgstr ""

#. List: 2
#. EDID: [01083C5F]
#. REC: INFO:NAM1
msgctxt "0213A7"
msgid "Unhhh... I feel dizzy."
msgstr ""

#. List: 2
#. EDID: [01083C81]
#. REC: INFO:NAM1
msgctxt "0213A8"
msgid "I suppose I'll let someone else step on you for once."
msgstr ""

#. List: 2
#. EDID: [01083BC8]
#. REC: INFO:NAM1
msgctxt "02188D"
msgid "I think they gave up."
msgstr ""

#. List: 2
#. EDID: [01083CF1]
#. REC: INFO:NAM1
msgctxt "02188E"
msgid "Oh cool, weapon's back online."
msgstr ""

#. List: 2
#. EDID: [01083D2E]
#. REC: INFO:NAM1
msgctxt "021892"
msgid "Nice. Maybe for your next trick you can conjure me a beer."
msgstr ""

#. List: 2
#. EDID: [01083DE1]
#. REC: INFO:NAM1
msgctxt "021893"
msgid "I've heard there's a book store here. I wonder if I can pick up some alchemy recipes."
msgstr ""

#. List: 2
#. EDID: [01083CD2]
#. REC: INFO:NAM1
msgctxt "021894"
msgid "Maybe we'll find something useful here, like dead people."
msgstr ""

#. List: 2
#. EDID: [01083C15]
#. REC: INFO:NAM1
msgctxt "021D38"
msgid "Delete... my... browser history..."
msgstr ""

#. List: 2
#. EDID: [01083C9E]
#. REC: INFO:NAM1
msgctxt "0221E7"
msgid "More corpses for the coffers."
msgstr ""

#. List: 2
#. EDID: [01083BE8]
#. REC: INFO:NAM1
msgctxt "0221E8"
msgid "Spotted them!"
msgstr ""

#. List: 2
#. EDID: [01083E27]
#. REC: INFO:NAM1
msgctxt "0221F2"
msgid "Discovering places like this always brings a frown to my face."
msgstr ""

#. List: 2
#. EDID: [01083D14]
#. REC: INFO:NAM1
msgctxt "0221F3"
msgid "Fair enough."
msgstr ""

#. List: 2
#. EDID: [01083D31]
#. REC: INFO:NAM1
msgctxt "0221F4"
msgid "Nice magic. Ever thought of starting your own cult?"
msgstr ""

#. List: 2
#. EDID: [01083DD9]
#. REC: INFO:NAM1
msgctxt "02268E"
msgid "Nothing to worry about."
msgstr ""

#. List: 2
#. EDID: [01083CF6]
#. REC: INFO:NAM1
msgctxt "02268F"
msgid "Weapons are back."
msgstr ""

#. List: 2
#. EDID: [01083D2F]
#. REC: INFO:NAM1
msgctxt "022695"
msgid "That's way more useful then going to college."
msgstr ""

#. List: 2
#. EDID: [01083DE0]
#. REC: INFO:NAM1
msgctxt "022696"
msgid "Did they make this town so grown men can play cowboy?"
msgstr ""

#. List: 2
#. EDID: [01083BE7]
#. REC: INFO:NAM1
msgctxt "022B04"
msgid "Over here!"
msgstr ""

#. List: 2
#. EDID: [01083E50]
#. REC: INFO:NAM1
msgctxt "022B05"
msgid "I don't see anyone else coming."
msgstr ""

#. List: 2
#. EDID: [01083CF9]
#. REC: INFO:NAM1
msgctxt "022B06"
msgid "Weapons are a go."
msgstr ""

#. List: 2
#. EDID: [01083C6A]
#. REC: INFO:NAM1
msgctxt "022B07"
msgid "I think I deserve a raise for that."
msgstr ""

#. List: 2
#. EDID: [01083D15]
#. REC: INFO:NAM1
msgctxt "022B09"
msgid "Fine."
msgstr ""

#. List: 2
#. EDID: [01083C7A]
#. REC: INFO:NAM1
msgctxt "022FFA"
msgid "Yeah, there goes our weapons."
msgstr ""

#. List: 2
#. EDID: [01083E01]
#. REC: INFO:NAM1
msgctxt "022FFB"
msgid "We should stop by GalBank, in case you need to put more money into my account."
msgstr ""

#. List: 2
#. EDID: [01083E3B]
#. REC: INFO:NAM1
msgctxt "022FFC"
msgid "You look uncomfortable."
msgstr ""

#. List: 2
#. EDID: [01083CE0]
#. REC: INFO:NAM1
msgctxt "022FFD"
msgid "A hazard warning like that is always a good sign. It means fun times are coming."
msgstr ""

#. List: 2
#. EDID: [01083E4E]
#. REC: INFO:NAM1
msgctxt "023453"
msgid "If you pick up any corpses from these wrecks, put them on my dissecting table. "
msgstr ""

#. List: 2
#. EDID: [01083BC5]
#. REC: INFO:NAM1
msgctxt "023454"
msgid "I'm not sensing anything."
msgstr ""

#. List: 2
#. EDID: [01083CC3]
#. REC: INFO:NAM1
msgctxt "023457"
msgid "Your outpost workbenches should be CredStik operated. You'll want to charge people to use them."
msgstr ""

#. List: 2
#. EDID: [01083C61]
#. REC: INFO:NAM1
msgctxt "023458"
msgid "Ugh... my back feels like a pretzel."
msgstr ""

#. List: 2
#. EDID: [01083D2B]
#. REC: INFO:NAM1
msgctxt "023459"
msgid "So magic is real, huh. Fun."
msgstr ""

#. List: 2
#. EDID: [01083DED]
#. REC: INFO:NAM1
msgctxt "02345A"
msgid "I heard there's a crater here that looks like a smiley face. Personally I like a good grimace."
msgstr ""

#. List: 2
#. EDID: [01083CD5]
#. REC: INFO:NAM1
msgctxt "02345B"
msgid "I wonder if they know their ship smells like this."
msgstr ""

#. List: 2
#. EDID: [01083D61]
#. REC: INFO:NAM1
msgctxt "023947"
msgid "Ugh, someone gave their weapon a potion or something."
msgstr ""

#. List: 2
#. EDID: [01083D12]
#. REC: INFO:NAM1
msgctxt "023948"
msgid "All right. Let's trade."
msgstr ""

#. List: 2
#. EDID: [01083C6E]
#. REC: INFO:NAM1
msgctxt "023D9D"
msgid "Ship seems to be in okay shape."
msgstr ""

#. List: 2
#. EDID: [01083D4B]
#. REC: INFO:NAM1
msgctxt "023D9E"
msgid "Shields are cooked."
msgstr ""

#. List: 2
#. EDID: [01083D48]
#. REC: INFO:NAM1
msgctxt "023D9F"
msgid "Shields are out. Good times."
msgstr ""

#. List: 2
#. EDID: [01083DF8]
#. REC: INFO:NAM1
msgctxt "023DA3"
msgid "I got robbed in Neon once. It's an essential part of the experience."
msgstr ""

#. List: 2
#. EDID: [01083DC5]
#. REC: INFO:NAM1
msgctxt "024246"
msgid "I'm hit!"
msgstr ""

#. List: 2
#. EDID: [01083CB4]
#. REC: INFO:NAM1
msgctxt "024247"
msgid "It's your lucky day. You get to die."
msgstr ""

#. List: 2
#. EDID: [01083D0F]
#. REC: INFO:NAM1
msgctxt "02424B"
msgid "There's still some room in my pack, if you can pay the storage fees."
msgstr ""

#. List: 2
#. EDID: [01083DBD]
#. REC: INFO:NAM1
msgctxt "0246BF"
msgid "Agh!"
msgstr ""

#. List: 2
#. EDID: [01083C6C]
#. REC: INFO:NAM1
msgctxt "0246C0"
msgid "I think I see a dead body floating. Cool."
msgstr ""

#. List: 2
#. EDID: [01083DF4]
#. REC: INFO:NAM1
msgctxt "0246C1"
msgid "Everything in Neon is artificial. The lights, the music, the people. It's for the best."
msgstr ""

#. List: 2
#. EDID: [010388D8]
#. REC: INFO:NAM1
msgctxt "02474F"
msgid "That tour guide better come back and explain himself."
msgstr ""

#. List: 2
#. EDID: [010276CD]
#. REC: INFO:NAM1
msgctxt "024AEF"
msgid "As you wish."
msgstr ""

#. List: 2
#. EDID: [01083C18]
#. REC: INFO:NAM1
msgctxt "024B15"
msgid "That's... gonna leave a mark..."
msgstr ""

#. List: 2
#. EDID: [01083CB1]
#. REC: INFO:NAM1
msgctxt "024B16"
msgid "You've done it now."
msgstr ""

#. List: 2
#. EDID: [01083E13]
#. REC: INFO:NAM1
msgctxt "024B18"
msgid "You don't need a spacesuit here. It's fine."
msgstr ""

#. List: 2
#. EDID: [01083D9C]
#. REC: INFO:NAM1
msgctxt "024FCC"
msgid "If I could be anything, I'd be a black hole. No light could escape me, it'd be great."
msgstr ""

#. List: 2
#. EDID: [01083C9C]
#. REC: INFO:NAM1
msgctxt "024FCD"
msgid "Oh boy."
msgstr ""

#. List: 2
#. EDID: [01083B6C]
#. REC: INFO:NAM1
msgctxt "024FCE"
msgid "I'm dying... Cool."
msgstr ""

#. List: 2
#. EDID: [01083CB6]
#. REC: INFO:NAM1
msgctxt "024FCF"
msgid "Last chance."
msgstr ""

#. List: 2
#. EDID: [01083C8C]
#. REC: INFO:NAM1
msgctxt "024FD0"
msgid "They're having some kind of weapon trouble."
msgstr ""

#. List: 2
#. EDID: [01083E30]
#. REC: INFO:NAM1
msgctxt "024FD1"
msgid "Nice scenery at least. No people to screw it up."
msgstr ""

#. List: 2
#. EDID: [01083E16]
#. REC: INFO:NAM1
msgctxt "024FD2"
msgid "You don't need that spacesuits. What's the worst that can happen?"
msgstr ""

#. List: 2
#. EDID: [01083E0A]
#. REC: INFO:NAM1
msgctxt "024FD3"
msgid "Earth. This is where people come from. Gross."
msgstr ""

#. List: 2
#. EDID: [01083DEC]
#. REC: INFO:NAM1
msgctxt "02545E"
msgid "I heard they settled here because one of the craters looked like a face. Not the stupidest reason to start a city, but pretty damn close."
msgstr ""

#. List: 2
#. EDID: [01083D6D]
#. REC: INFO:NAM1
msgctxt "0258CB"
msgid "I've been doing a lot of work lately. Resting my eyes, sitting down, that sort of thing."
msgstr ""

#. List: 2
#. EDID: [01083E4D]
#. REC: INFO:NAM1
msgctxt "0258CE"
msgid "We should dissect any corpses you pick up. "
msgstr ""

#. List: 2
#. EDID: [01083CFD]
#. REC: INFO:NAM1
msgctxt "0258CF"
msgid "I don't see anyone."
msgstr ""

#. List: 2
#. EDID: [01083DBC]
#. REC: INFO:NAM1
msgctxt "0258D0"
msgid "Got me!"
msgstr ""

#. List: 2
#. EDID: [01083D1D]
#. REC: INFO:NAM1
msgctxt "0258D1"
msgid "Oh fun, another fight."
msgstr ""

#. List: 2
#. EDID: [01083D60]
#. REC: INFO:NAM1
msgctxt "0258D2"
msgid "Oh great, their weapon's firing again."
msgstr ""

#. List: 2
#. EDID: [01083E1A]
#. REC: INFO:NAM1
msgctxt "0258D3"
msgid "Nothing standing in the way of death here. What a paradise."
msgstr ""

#. List: 2
#. EDID: [01083E03]
#. REC: INFO:NAM1
msgctxt "0258D4"
msgid "I'm glad I was born here. I feel like you can't be truly evil unless you grew up in a corporate environment."
msgstr ""

#. List: 2
#. EDID: [01083BC7]
#. REC: INFO:NAM1
msgctxt "025D79"
msgid "Hopefully they don't come back."
msgstr ""

#. List: 2
#. EDID: [01083C16]
#. REC: INFO:NAM1
msgctxt "025D7B"
msgid "I can't...feel...my brain..."
msgstr ""

#. List: 2
#. EDID: [01083DCE]
#. REC: INFO:NAM1
msgctxt "025D7E"
msgid "I can't wait for my bones to atrophy into twigs."
msgstr ""

#. List: 2
#. EDID: [010276F6]
#. REC: INFO:NAM1
msgctxt "0261F4"
msgid "Let's get you patched up."
msgstr ""

#. List: 2
#. EDID: [01083C5D]
#. REC: INFO:NAM1
msgctxt "02621D"
msgid "Yeah, I guess I'll live a little longer."
msgstr ""

#. List: 2
#. EDID: [01083E0C]
#. REC: INFO:NAM1
msgctxt "02621E"
msgid "I was hoping there'd be more skeletons."
msgstr ""

#. List: 2
#. EDID: [010276D3]
#. REC: INFO:NAM1
msgctxt "0266A2"
msgid "Ship shape and ready for action."
msgstr ""

#. List: 2
#. EDID: [01083D03]
#. REC: INFO:NAM1
msgctxt "0266B8"
msgid "Just our luck."
msgstr ""

#. List: 2
#. EDID: [01083C60]
#. REC: INFO:NAM1
msgctxt "0266BD"
msgid "Agh. Medpacks always give me a headache. But thanks."
msgstr ""

#. List: 2
#. EDID: [01083E24]
#. REC: INFO:NAM1
msgctxt "0266BE"
msgid "Scanner says there's signs of life on this planet. Huzzah."
msgstr ""

#. List: 2
#. EDID: [010276D8]
#. REC: INFO:NAM1
msgctxt "026B36"
msgid "Yeah, that's... we should fix all that."
msgstr ""

#. List: 2
#. EDID: [01083DCF]
#. REC: INFO:NAM1
msgctxt "026B6F"
msgid "I'm just gonna drift for a while."
msgstr ""

#. List: 2
#. EDID: [01083E29]
#. REC: INFO:NAM1
msgctxt "026B70"
msgid "This place is dead silent... music to my ears."
msgstr ""

#. List: 2
#. EDID: [01083E06]
#. REC: INFO:NAM1
msgctxt "026B71"
msgid "The real estate here is named after Greek gods. No Hades though. The people here don't have taste."
msgstr ""

#. List: 2
#. EDID: [01083D04]
#. REC: INFO:NAM1
msgctxt "026FED"
msgid "This is gonna hurt."
msgstr ""

#. List: 2
#. EDID: [01083C70]
#. REC: INFO:NAM1
msgctxt "026FEE"
msgid "The salvaging is the best part."
msgstr ""

#. List: 2
#. EDID: [01083D47]
#. REC: INFO:NAM1
msgctxt "026FEF"
msgid "I forgot to tell you, but our shields are down."
msgstr ""

#. List: 2
#. EDID: [01083D5E]
#. REC: INFO:NAM1
msgctxt "026FF0"
msgid "I hate to tell you, but their weapon's back online."
msgstr ""

#. List: 2
#. EDID: [01083D16]
#. REC: INFO:NAM1
msgctxt "026FF3"
msgid "Go ahead."
msgstr ""

#. List: 2
#. EDID: [01083E05]
#. REC: INFO:NAM1
msgctxt "026FF4"
msgid "Ever been to the Dawn's Roost? The meat there's as fake as the people."
msgstr ""

#. List: 2
#. EDID: [01083DE9]
#. REC: INFO:NAM1
msgctxt "026FF5"
msgid "Wow, so this is where they invented boredom."
msgstr ""

#. List: 2
#. EDID: [010276F0]
#. REC: INFO:NAM1
msgctxt "027465"
msgid "I'm not running a charity I'm afraid. Come back when you have the credits."
msgstr ""

#. List: 2
#. EDID: [01083C2C]
#. REC: INFO:NAM1
msgctxt "027491"
msgid "Come out, come out, wherever you are..."
msgstr ""

#. List: 2
#. EDID: [01083D4A]
#. REC: INFO:NAM1
msgctxt "027492"
msgid "Oh will you look at that. No shields."
msgstr ""

#. List: 2
#. EDID: [01083D21]
#. REC: INFO:NAM1
msgctxt "027493"
msgid "Buckling my safety belt..."
msgstr ""

#. List: 2
#. EDID: [01083C9F]
#. REC: INFO:NAM1
msgctxt "0278E9"
msgid "Ooh, new things to kill."
msgstr ""

#. List: 2
#. EDID: [01083D64]
#. REC: INFO:NAM1
msgctxt "0278EB"
msgid "Well, their weapon's fixed. That's not good."
msgstr ""

#. List: 2
#. EDID: [01083CC2]
#. REC: INFO:NAM1
msgctxt "0278EF"
msgid "You should build a module with no doors or windows and add an intercom to an answering machine."
msgstr ""

#. List: 2
#. EDID: [01083CBC]
#. REC: INFO:NAM1
msgctxt "0278F0"
msgid "Is that for your dungeon?"
msgstr ""

#. List: 2
#. EDID: [01083E38]
#. REC: INFO:NAM1
msgctxt "0278F1"
msgid "I hope that comes with some cool side effects."
msgstr ""

#. List: 2
#. EDID: [01083E2E]
#. REC: INFO:NAM1
msgctxt "0278F2"
msgid "Imagine coming to a place like this on purpose."
msgstr ""

#. List: 2
#. EDID: [01083E23]
#. REC: INFO:NAM1
msgctxt "0278F3"
msgid "Don't know if this planet is hospitable to outsiders. Not everyone likes it when you place an oil derrick or two in their backyard."
msgstr ""

#. List: 2
#. EDID: [01083DE4]
#. REC: INFO:NAM1
msgctxt "0278F4"
msgid "We could stop by Laredo Firearms. Now that I'm a member of your crew I need to learn how to kill people."
msgstr ""

#. List: 2
#. EDID: [010276EC]
#. REC: INFO:NAM1
msgctxt "027D64"
msgid "I've seen worse. Not very often though. Hold onto something..."
msgstr ""

#. List: 2
#. EDID: [010276EB]
#. REC: INFO:NAM1
msgctxt "027D65"
msgid "Okay. This might hurt a little."
msgstr ""

#. List: 2
#. EDID: [01083CF2]
#. REC: INFO:NAM1
msgctxt "027D86"
msgid "Weapon repairs are done."
msgstr ""

#. List: 2
#. EDID: [01083D08]
#. REC: INFO:NAM1
msgctxt "027D88"
msgid "Yeah. Sure. Take it all."
msgstr ""

#. List: 2
#. EDID: [01083DEA]
#. REC: INFO:NAM1
msgctxt "027D89"
msgid "Mars sure is bland."
msgstr ""

#. List: 2
#. EDID: [01083E56]
#. REC: INFO:NAM1
msgctxt "02822D"
msgid "Let's find out how much money they were carrying."
msgstr ""

#. List: 2
#. EDID: [01083DC3]
#. REC: INFO:NAM1
msgctxt "02822E"
msgid "Ack!"
msgstr ""

#. List: 2
#. EDID: [01083CC0]
#. REC: INFO:NAM1
msgctxt "028230"
msgid "Another module for the outpost. Yay."
msgstr ""

#. List: 2
#. EDID: [01083E36]
#. REC: INFO:NAM1
msgctxt "028231"
msgid "I know a fungus that can do the same thing."
msgstr ""

#. List: 2
#. EDID: [01083CCE]
#. REC: INFO:NAM1
msgctxt "028232"
msgid "Su casa mi casa."
msgstr ""

#. List: 2
#. EDID: [01083CF4]
#. REC: INFO:NAM1
msgctxt "0286A2"
msgid "Weapon's fixed. Time for some pew-pew."
msgstr ""

#. List: 2
#. EDID: [01083E04]
#. REC: INFO:NAM1
msgctxt "0286A8"
msgid "The sun here never stops glaring. It's creepy."
msgstr ""

#. List: 2
#. EDID: [010276D2]
#. REC: INFO:NAM1
msgctxt "028FE2"
msgid "Might be a little scar tissue, but that just adds character."
msgstr ""

#. List: 2
#. EDID: [010276CB]
#. REC: INFO:NAM1
msgctxt "028FE3"
msgid "Alright."
msgstr ""

#. List: 2
#. EDID: [01083BE9]
#. REC: INFO:NAM1
msgctxt "02900A"
msgid "I see 'em!"
msgstr ""

#. List: 2
#. EDID: [010276E0]
#. REC: INFO:NAM1
msgctxt "02945E"
msgid "Not so bad, really."
msgstr ""

#. List: 2
#. EDID: [01083CFE]
#. REC: INFO:NAM1
msgctxt "029486"
msgid "Huh, lost 'em."
msgstr ""

#. List: 2
#. EDID: [01083BC6]
#. REC: INFO:NAM1
msgctxt "029943"
msgid "Well, they were probably poor anyway."
msgstr ""

#. List: 2
#. EDID: [01083DC0]
#. REC: INFO:NAM1
msgctxt "029944"
msgid "Nargh!"
msgstr ""

#. List: 2
#. EDID: [01083C29]
#. REC: INFO:NAM1
msgctxt "029DD4"
msgid "Huh. Where'd they go?"
msgstr ""

#. List: 2
#. EDID: [01083C8E]
#. REC: INFO:NAM1
msgctxt "029DD6"
msgid "Their weapon's been hit. I guess we did that?"
msgstr ""

#. List: 2
#. EDID: [01083CBF]
#. REC: INFO:NAM1
msgctxt "029DDA"
msgid "This outpost is really starting to feel like hell. Maybe I'm dead and nobody told me."
msgstr ""

#. List: 2
#. EDID: [01083CD0]
#. REC: INFO:NAM1
msgctxt "029DDB"
msgid "We're like nosy neighbors."
msgstr ""

#. List: 2
#. EDID: [01083C8A]
#. REC: INFO:NAM1
msgctxt "02A274"
msgid "You got their weapons Captain. I think. I mean, what do I know."
msgstr ""

#. List: 2
#. EDID: [01083E11]
#. REC: INFO:NAM1
msgctxt "02A275"
msgid "Earth. I've got an earache that's more interesting than this place."
msgstr ""

#. List: 2
#. EDID: [01083CC9]
#. REC: INFO:NAM1
msgctxt "02A714"
msgid "Not them again."
msgstr ""

#. List: 2
#. EDID: [01083C6F]
#. REC: INFO:NAM1
msgctxt "02A715"
msgid "They thought they could take you. Cute."
msgstr ""

#. List: 2
#. EDID: [01083CBB]
#. REC: INFO:NAM1
msgctxt "02A717"
msgid "I hope that's gonna house some kind of torture device."
msgstr ""

#. List: 2
#. EDID: [01083D33]
#. REC: INFO:NAM1
msgctxt "02A718"
msgid "Why can't I do that?"
msgstr ""

#. List: 2
#. EDID: [01083D2D]
#. REC: INFO:NAM1
msgctxt "02A719"
msgid "That's cool."
msgstr ""

#. List: 2
#. EDID: [01083E2D]
#. REC: INFO:NAM1
msgctxt "02A71A"
msgid "We might be the first explorers to set foot on this place. Most people know better."
msgstr ""

#. List: 2
#. EDID: [01083DF5]
#. REC: INFO:NAM1
msgctxt "02A71B"
msgid "They say Aurora is made from fish. Beats licking toads."
msgstr ""

#. List: 2
#. EDID: [01083D6E]
#. REC: INFO:NAM1
msgctxt "02ABC3"
msgid "Are you gonna be hanging out here more? Hope you aren't one of those micro-managing types. Or managing types. Both are bad. "
msgstr ""

#. List: 2
#. EDID: [01083C7C]
#. REC: INFO:NAM1
msgctxt "02ABC5"
msgid "Weapons are broken."
msgstr ""

#. List: 2
#. EDID: [01083C50]
#. REC: INFO:NAM1
msgctxt "02B090"
msgid "I think we're being followed."
msgstr ""

#. List: 2
#. EDID: [01083C69]
#. REC: INFO:NAM1
msgctxt "02B091"
msgid "Nothing left but the autopsies."
msgstr ""

#. List: 2
#. EDID: [01083C7F]
#. REC: INFO:NAM1
msgctxt "02B095"
msgid "Later."
msgstr ""

#. List: 2
#. EDID: [010276F4]
#. REC: INFO:NAM1
msgctxt "02B9D4"
msgid "Straightforward zipper job really."
msgstr ""

#. List: 2
#. EDID: [01083BC4]
#. REC: INFO:NAM1
msgctxt "02B9E6"
msgid "Oh good, they're gone."
msgstr ""

#. List: 2
#. EDID: [01083CC1]
#. REC: INFO:NAM1
msgctxt "02B9E8"
msgid "You're a real carpenter, aren't you. Hope there's good money in it."
msgstr ""

#. List: 2
#. EDID: [01083D2C]
#. REC: INFO:NAM1
msgctxt "02B9E9"
msgid "Neat trick."
msgstr ""

#. List: 2
#. EDID: [01083CB5]
#. REC: INFO:NAM1
msgctxt "02BDFE"
msgid "I'm going to dissect you!"
msgstr ""

#. List: 2
#. EDID: [01083C8D]
#. REC: INFO:NAM1
msgctxt "02BDFF"
msgid "Is their weapon damaged or something?"
msgstr ""

#. List: 2
#. EDID: [01083CB2]
#. REC: INFO:NAM1
msgctxt "02C287"
msgid "Come here, corpsie."
msgstr ""

#. List: 2
#. EDID: [01083C6B]
#. REC: INFO:NAM1
msgctxt "02C288"
msgid "I hope they got the extended warranty."
msgstr ""

#. List: 2
#. EDID: [01083C8F]
#. REC: INFO:NAM1
msgctxt "02C289"
msgid "Their weapon's offline."
msgstr ""

#. List: 2
#. EDID: [01083C89]
#. REC: INFO:NAM1
msgctxt "02C28A"
msgid "Their weapons look pretty broken. Good."
msgstr ""

#. List: 2
#. EDID: [01083DCD]
#. REC: INFO:NAM1
msgctxt "02C28C"
msgid "I guess we don't need feet."
msgstr ""

#. List: 2
#. EDID: [01083D07]
#. REC: INFO:NAM1
msgctxt "02C28D"
msgid "I should charge you to go through my stuff."
msgstr ""

#. List: 2
#. EDID: [010276E1]
#. REC: INFO:NAM1
msgctxt "02C6FD"
msgid "I've seen worse."
msgstr ""

#. List: 2
#. EDID: [01083D65]
#. REC: INFO:NAM1
msgctxt "02C723"
msgid "Their weapon's back online. That's handy for them."
msgstr ""

#. List: 2
#. EDID: [01083DFD]
#. REC: INFO:NAM1
msgctxt "02C724"
msgid "Here we are, home sweet home."
msgstr ""

#. List: 2
#. EDID: [01083DE5]
#. REC: INFO:NAM1
msgctxt "02C725"
msgid "There's a lot of farms outside the walls. We should introduce some invasive weeds."
msgstr ""

#. List: 2
#. EDID: [01083CD6]
#. REC: INFO:NAM1
msgctxt "02C726"
msgid "Lot of good hiding places here. You might want to start shooting indiscriminately."
msgstr ""

#. List: 2
#. EDID: [010276F5]
#. REC: INFO:NAM1
msgctxt "02CBD5"
msgid "Hmm. Nothing a little needle and thread can't fix."
msgstr ""

#. List: 2
#. EDID: [01083CF8]
#. REC: INFO:NAM1
msgctxt "02CBEE"
msgid "Weapons are operational."
msgstr ""

#. List: 2
#. EDID: [01083DCA]
#. REC: INFO:NAM1
msgctxt "02CBF1"
msgid "My head's starting to get dizzy. This is supposed to happen to other people, not me."
msgstr ""

#. List: 2
#. EDID: [01083E17]
#. REC: INFO:NAM1
msgctxt "02CBF2"
msgid "Our oxygen tanks are full. Shame."
msgstr ""

#. List: 2
#. EDID: [01083BE6]
#. REC: INFO:NAM1
msgctxt "02CEEE"
msgid "Got you!"
msgstr ""

#. List: 2
#. EDID: [01083CA0]
#. REC: INFO:NAM1
msgctxt "02CEEF"
msgid "Guess we're doing this."
msgstr ""

#. List: 2
#. EDID: [01083C86]
#. REC: INFO:NAM1
msgctxt "02CEF0"
msgid "I think their weapons are dead."
msgstr ""

#. List: 2
#. EDID: [01083E25]
#. REC: INFO:NAM1
msgctxt "02CEF2"
msgid "We should plant our flag here. We have to defend our copyright, or we lose it."
msgstr ""

#. List: 2
#. EDID: [01083DDF]
#. REC: INFO:NAM1
msgctxt "02CEF3"
msgid "Well this place is a dump."
msgstr ""
