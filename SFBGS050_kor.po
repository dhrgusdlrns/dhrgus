#. Speaker = Delta_04
#. SoundFileID = 0056C677
#. Notes = / to Player Default
#: 02019FA5/00006/SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose:02019FF0
msgctxt "00072E"
msgid "Are you hurt? Do you need help?"
msgstr "다쳤어? 도움이 필요해?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02019FE9
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
#. SoundFileID = 00A92303
#. Notes = Mad / to Player Default, Prompt: 이제 이 일 넘겨서 다행이야. 가자.
#: 02019FA6/00006/SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose:02019FE9
msgctxt "00072F"
msgid "Incorrect. Not, \"over this\"."
msgstr "부정확. \"이걸 넘기는\" 것이 아님."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02019FE0
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
#. SoundFileID = 00C157B3
#. Notes = / to Player Default
#: 02019FA7/00006/SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose:02019FE0
msgctxt "000730"
msgid "Glad you're over this, now let's get going."
msgstr "이제 이 일 넘겨서 다행이야. 가자."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02019FD8
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 007A7D3D
#. Notes = Refusing to believe it / to Player Default, Prompt: 그만해, 델타. 끝났어. 내가 이겼어.
#: 02019FA8/00006/SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose:02019FD8
msgctxt "000731"
msgid "Impossible."
msgstr "불가능."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02019FD1
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 003BA4CE
#. Notes = / to Player Default
#: 02019FA9/00006/SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose:02019FD1
msgctxt "000732"
msgid "Stop it, Delta. It's over, I beat you."
msgstr "그만해, 델타. 끝났어. 내가 이겼어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0201A018
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_06_PostCombat_DeltaLose
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
