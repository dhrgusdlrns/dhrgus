#. DialogCallType = PlayerDialogue
#. Speaker = SFTER_NPCDelta
#. SoundFileID = 00BD6F9A
#. Notes = A line that's played sometimes when Delta and the player land in Anchorpoint.
#: 0200FA17:02030F40
msgctxt "0011AE"
msgid "Logging areas of improvement for Maddie Wing's records..."
msgstr "매디 윙의 기록용 개선 영역 기록 중..."

