msgctxt "0017AF"
msgid "Lowering Gullible variable..."
msgstr "순진함 변수 낮추는 중..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203B69D
#. QuestName = SFTER_EC_Robot_Q03
#. SceneName = SFTER_EC_Robot_Q03_08_PostHomesteadDeath_PlayerKilling
