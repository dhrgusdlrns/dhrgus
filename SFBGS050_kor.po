#. SoundFileID = 00892B46
#. Notes = Terrans killed a lot of people here. / Serious, Face: Serious
#: 0203B48C/00000/SFTER_INC_DP01_Companion_CompleteScene:0203B4AF
msgctxt "0016BA"
msgid "Death is too good these Terrans."
msgstr "죽음도 이 테란들에겐 과분해."

#. List: 2
#. REC: INFO:NAM1
