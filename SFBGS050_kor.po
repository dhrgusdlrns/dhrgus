msgid "No comment."
msgstr "할 말 없음."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203D18C
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett02
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett02_01
#. DialogCallType = SceneDialogue
#. Speaker = Barrett
#. SoundFileID = 008A820B
#. Notes = Now this is funny / Amused / to Delta, Face: Amused
#: 0203D17F/00000/SFTER_CREW_EliteCrew_Delta_Convo_Barrett02_01:0203D18C
msgctxt "001874"
msgid "But you're not arguing that you did it because you were annoyed?"
msgstr "하지만 짜증이 나서 그랬다는 주장은 안 하는 거지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203D18B
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett02
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett02_01
