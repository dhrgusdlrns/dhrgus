#. Speaker = Delta_04
#. SoundFileID = 003D076B, 0037253E
#. Notes = Smug / to Player Default, Prompt: 난 계속할 수 있어.
#: 0202B99C/00000/SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose:0202B9B9
msgctxt "000EDC"
msgid "Conclusion: I would kill you."
msgstr "결론: 나는 당신을 죽일 것임."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202B9B9
