msgid "I get where you're coming from. Believe me."
msgstr "네 입장은 이해해. 정말이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC54
#. QuestName = SFTER_INC_Dialogue
#. SceneName = SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0022A997
#. Notes = Speech challenge win: Once the truth is out, this all gets easier. / Thinking, Face: Thinking
#: 0205DC4D/00000/SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene:0205DC54
