#. List: 0
#. EDID: SFTER_INC_APG_RefineryDesktop
#. REC: TMLM:BTXT
#. FormID: 0202C4C9
msgctxt "000F1E"
msgid "Class X: Assault Ship\nType: Terran Reclaimer\n\nRefinery status: Online\n-Distillation Unit A: <Token.Title=MessageA> <Token.Value=ValueA>\n-Distillation Unit B: <Token.Title=MessageB> <Token.Value=ValueB>\n"
