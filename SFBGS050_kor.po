#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202757E
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AnnaSantos
#. SoundFileID = 003C1F80, 00534713
#. Notes = NO FACE DATA NEEDED So much love here
#: 0202756D/00000/SFTER_EC_Robot01_AL_02:0202757E
