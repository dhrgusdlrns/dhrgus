#. DialogCallType = SceneDialogue
#. Speaker = companion
#. SoundFileID = 008044EC
#. Notes = Concerned, Face: Concerned
#: 0203B48A/00000/SFTER_INC_DP01_Companion_StartScene:0203B49D
msgctxt "00169F"
msgid "Damn, this place looks rough."
msgstr "젠장, 여긴 상태가 엉망이군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203B49C
#. QuestName = SFTER_INC_MIN_DropPodsGround01
