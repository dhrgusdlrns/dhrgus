#. SoundFileID = 00F1BC82
#. Notes = / to Player Default
#: 02016645/00007/SFTER_EC_Robot_Q03_07_PostHomesteadDeath:020166A4
msgctxt "000629"
msgid "What was the point of that?"
msgstr "대체 왜 그런 거야?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020166A1
#. QuestName = SFTER_EC_Robot_Q03
#. SceneName = SFTER_EC_Robot_Q03_05_Homesteaders_Death
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AnnaSantos
#. SoundFileID = 0096FE3C, 00840A81
#. Notes = Slightly eerie. Tempting a deer into a trap / to Player Default
#: 0201664E/00005/SFTER_EC_Robot_Q03_05_Homesteaders_Death:020166A1
msgctxt "00062B"
msgid "I'm so glad you asked!"
msgstr "물어봐 주셔서 정말 기쁘네요!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0201668D
#. QuestName = SFTER_EC_Robot_Q03
#. SceneName = SFTER_EC_Robot_Q03_09_ChallengeStated
