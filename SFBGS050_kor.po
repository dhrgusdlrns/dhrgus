#: 0205DC4D/00000/SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene:0205DC59
msgctxt "001F53"
msgid "But I already told you the truth."
msgstr "하지만 이미 진실을 말했잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC58
#. QuestName = SFTER_INC_Dialogue
#. SceneName = SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene
