#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AnnaSantos
#. SoundFileID = 004A03F0, 003623F3
#. Notes = NO FACE DATA NEEDED Kneeling down to look him in the eye, Attempt to reason
#: 02027571/00000/SFTER_EC_Robot01_AL_02:02027578
msgctxt "000AD3"
msgid "I think it's time we lower our standards and work with what we can get."
msgstr "이제 기준을 낮추고 구할 수 있는 걸로 작업해야 할 때인 것 같아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02027578
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AnnaSantos
#. SoundFileID = 004A03F0, 003623F3
#. Notes = NO FACE DATA NEEDED Kneeling down to look him in the eye, Attempt to reason
#: 02027571/00000/SFTER_EC_Robot01_AL_02:02027578
msgctxt "000AD5"
msgid "Frank. You are the smartest man I know. There is nothing I want more than your dream. Our dream."
msgstr "프랭크. 당신은 내가 아는 사람 중 가장 똑똑한 남자야. 난 당신의 꿈, 우리의 꿈보다 더 원하는 게 없어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02027577
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_FrankSantos
#. SoundFileID = 00624A1A
#. Notes = NO FACE DATA NEEDED Sitting down, anger has left them and been replaced with exhaustion
#: 02027572/00000/SFTER_EC_Robot01_AL_02:02027577
msgctxt "000AD6"
msgid "I just want it to be perfect. I want to create perfection."
msgstr "난 그저 완벽하길 바랄 뿐이야. 완벽 그 자체를 만들고 싶어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202757B
msgctxt "000AD7"
msgid "*Metal clattering*"
msgstr "*금속이 요란하게 부딪히는 소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02027579
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_FrankSantos
#. SoundFileID = 00CBA0F1
#. Notes = NO FACE DATA NEEDED Trying to find something to unleash their anger on
#: 02027574/00000/SFTER_EC_Robot01_AL_02:02027579
msgctxt "000AD8"
msgid "Dammit! *Metal clattering*"
msgstr "젠장! *금속이 요란하게 부딪히는 소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02027580
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_FrankSantos
#. SoundFileID = 00FF5284
#. Notes = NO FACE DATA NEEDED now is also upset at not being taken seriously
#: 02027575/00000/SFTER_EC_Robot01_AL_02:02027580
msgctxt "000AD9"
msgid "I don't know, all I know is that this is impossible!"
msgstr "몰라, 내가 아는 건 이건 불가능하다는 것뿐이야!"

