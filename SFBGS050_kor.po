msgid "You're too busy note-taking to lead."
msgstr "넌 필기하느라 바빠서 이끌 수 없잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EADE
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose
