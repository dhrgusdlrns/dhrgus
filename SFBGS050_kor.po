#: 0205DC4D/00000/SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene:0205DC58
msgctxt "001F54"
msgid "I'm already being honest here."
msgstr "난 지금도 솔직하게 말하고 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC56
#. QuestName = SFTER_INC_Dialogue
#. SceneName = SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
