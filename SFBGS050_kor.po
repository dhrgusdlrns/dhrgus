msgstr "거부."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AD16
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01
#. DialogCallType = SceneDialogue
#. Speaker = Barrett
#. SoundFileID = 007091E6
#. Notes = Yes this, and also it's fun to annoy Delta / Surprised / to Delta, Face: Surprised
#: 0203AD0B/00000/SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01:0203AD16
msgctxt "0014DD"
msgid "What? And miss out on talking to a modern marvel?"
msgstr "뭐? 현대의 경이와 대화할 기회를 놓치라고?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AD15
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01
#. DialogCallType = SceneDialogue
