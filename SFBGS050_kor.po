#. SoundFileID = 00EB6735
#. Notes = yelling in vain attempting to outrun a killer robot, before being shot
#: 0205DC3D/00000/SFTER_MQ01_0350_TerranExecutionScene:0205DC3F
msgctxt "001F5A"
msgid "Out of the way!"
msgstr "비켜!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC46
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0320_TerranHallScene
#. DialogCallType = SceneDialogue
#. Speaker = PassengerVoice
#. SoundFileID = 00C1950B
#. Notes = general death/anguish
#: 0205DC3E/00000/SFTER_MQ01_0320_TerranHallScene:0205DC46
msgctxt "001F5B"
msgid "Ugh..."
msgstr "으윽..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC45
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0320_TerranHallScene
#. DialogCallType = SceneDialogue
#. Speaker = PassengerVoice
#. SoundFileID = 009BE58E
#: 0205DC3E/00000/SFTER_MQ01_0320_TerranHallScene:0205DC45
msgctxt "001F5C"
msgid "No, make it stop..."
msgstr "안 돼, 멈춰 줘..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC44
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0320_TerranHallScene
#. DialogCallType = SceneDialogue
#. Speaker = PassengerVoice
#. SoundFileID = 00C58F0A
#: 0205DC3E/00000/SFTER_MQ01_0320_TerranHallScene:0205DC44
msgctxt "001F5D"
msgid "Move, move!"
msgstr "움직여, 움직여!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC43
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0320_TerranHallScene
#. DialogCallType = SceneDialogue
#. Speaker = PassengerVoice
#. SoundFileID = 0083CD75
#: 0205DC3E/00000/SFTER_MQ01_0320_TerranHallScene:0205DC43
msgctxt "001F5E"
msgid "Please, don't!"
msgstr "제발, 그러지 마!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC42
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0320_TerranHallScene
#. DialogCallType = SceneDialogue
#. Speaker = PassengerVoice
#. SoundFileID = 00E44F7D
#. Notes = generic, panicked screaming (attempting to outrun killer robots who are hunting down passengers in the area)
#: 0205DC3E/00000/SFTER_MQ01_0320_TerranHallScene:0205DC42
msgctxt "001F5F"
msgid "Aaah!"
msgstr "아아악!"

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB01
#. REC: INFO:NAM1
#. FormID: 0205DC23
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 008C5975, 0060A922, 00C6CCD7
#. Notes = Serious / to Player Default, Face: Serious, Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC23
msgctxt "001F7F"
msgid "Thank you for setting us straight."
msgstr "우리를 바로잡아 줘서 고마워."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB01
#. REC: INFO:NAM1
#. FormID: 0205DC23
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 008C5975, 0060A922, 00C6CCD7
#. Notes = Serious / to Player Default, Face: Serious, Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC23
msgctxt "001F80"
msgid "Once we've found somewhere to settle, we'll make sure others will have a safe space to go."
msgstr "정착할 곳을 찾고 나면, 다른 사람들도 갈 수 있는 안전한 공간을 마련할게."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB01
#. REC: INFO:NAM1
#. FormID: 0205DC23
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 008C5975, 0060A922, 00C6CCD7
#. Notes = Serious / to Player Default, Face: Serious, Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC23
msgctxt "001F81"
msgid "You're... you're right. Our situation won't allow for much, but we'll do what we can."
msgstr "네... 네 말이 맞아. 우리 처지상 많은 건 못 하겠지만, 할 수 있는 건 해 볼게."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB02
#. REC: INFO:NAM1
#. FormID: 0205DC22
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00242BA8, 00E95D4C, 009219CF
#. Notes = Serious / to Player Default, Face: Serious, Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC22
msgctxt "001F82"
msgid "Hopefully, we can help others as you helped us today."
msgstr "오늘 네가 우리를 도와준 것처럼, 우리도 다른 사람들을 도울 수 있으면 좋겠어."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB02
#. REC: INFO:NAM1
#. FormID: 0205DC22
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00242BA8, 00E95D4C, 009219CF
#. Notes = Serious / to Player Default, Face: Serious, Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC22
msgctxt "001F83"
msgid "It'll be our first priority once we can set up a small base of operations."
msgstr "작은 작전 거점이라도 세울 수 있게 되면 그걸 최우선으로 삼을게."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB02
#. REC: INFO:NAM1
#. FormID: 0205DC22
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00242BA8, 00E95D4C, 009219CF
#. Notes = Serious / to Player Default, Face: Serious, Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC22
msgctxt "001F84"
msgid "You're right. Our fight doesn't end here, it just changes direction."
msgstr "네 말이 맞아. 우리의 싸움은 여기서 끝나는 게 아니라 방향이 바뀌는 거야."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB03
#. REC: INFO:NAM1
#. FormID: 0205DC21
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 003B36C7, 00FF4557, 00435AC2
#. Notes = Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC21
msgctxt "001F85"
msgid "Thanks to you, we'll be able to provide that route for them."
msgstr "네 덕분에 우리가 그들에게 그런 길을 마련해 줄 수 있을 거야."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB03
#. REC: INFO:NAM1
#. FormID: 0205DC21
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 003B36C7, 00FF4557, 00435AC2
#. Notes = Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC21
msgctxt "001F86"
msgid "I know many who would leap at the opportunity to get out, if only they knew how."
msgstr "빠져나갈 방법만 알았다면 당장이라도 기회를 잡을 사람이 많다는 걸 알아."

#. List: 2
#. EDID: SFTER_INC_SCP_SoldierFinalResponseB03
#. REC: INFO:NAM1
#. FormID: 0205DC21
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 003B36C7, 00FF4557, 00435AC2
#. Notes = Confident / to Player Default, Face: Confident, Grateful / to Player Default, Face: Grateful
#: 0205DC0B/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC21
msgctxt "001F87"
msgid "As soon as we're able, it will be the least we can do."
msgstr "할 수 있게 되는 즉시, 그 정도는 우리가 해야 할 최소한의 일이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC3B
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00B2732E
#. Notes = Irritated / to Player Default, Face: Irritated
#: 0202C35E/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC3B
msgctxt "001F88"
msgid "What is it now?"
msgstr "이번엔 또 뭐야?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC3A
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00BACF13
#. Notes = Irritated / to Player Default, Face: Irritated
#: 0202C35E/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC3A
msgctxt "001F89"
msgid "You're still here?"
msgstr "아직도 여기 있어?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020517DE
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0068AD2E
#. Notes = Serious / to Player Default, Face: Serious
#: 020517CD/02200/SFTER_INC_SCP01_RudeIntroMainScene:020517DE
msgctxt "001F8A"
msgid "Yes, we're the enemy. We're Terrans. Now start talking before I put a bullet in your brain."
msgstr "그래, 우리가 적이다. 우리는 테란이야. 이제 말해. 안 그러면 네 머리에 총알을 박아 주지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020517DD
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00CA0D42
#. Notes = Serious / to Player Default, Face: Serious
#: 020517CD/02200/SFTER_INC_SCP01_RudeIntroMainScene:020517DD
msgctxt "001F8B"
msgid "We're Terrans, and I think we both know you better have a pretty good story, or you aren't walking away from here alive."
msgstr "우리는 테란이고, 너도 꽤 그럴듯한 이야기가 없으면 여기서 살아서 못 나간다는 걸 알겠지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020517DC
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 002448C8
#. Notes = Serious / to Player Default, Face: Serious
#: 020517CD/02200/SFTER_INC_SCP01_RudeIntroMainScene:020517DC
msgctxt "001F8C"
msgid "We're Terrans. And now that you know, you better start talking."
msgstr "우리는 테란이야. 이제 알았으니 말문을 여는 게 좋을 거다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1D
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 003982C1, 001CA502
#. Notes = Confident / to Player Default, Face: Confident
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1D
msgctxt "001F8D"
msgid "Thank you. I know you didn't have to deal with my attitude or try to convince us of the truth, but we appreciate it all the same."
msgstr "고마워. 내 태도를 받아 줄 필요도, 우리에게 진실을 납득시키려 애쓸 필요도 없었는데, 그래도 고맙게 생각해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1D
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 003982C1, 001CA502
#. Notes = Confident / to Player Default, Face: Confident
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1D
msgctxt "001F8E"
msgid "You're right. A small group like us with no ships or robots isn't worth the recovery effort when we turn up missing."
msgstr "네 말이 맞아. 함선도 로봇도 없는 우리 같은 소규모 집단은 실종돼도 회수 작전을 벌일 가치가 없겠지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1C
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0035F966, 00530CE3, 00CE972A
#. Notes = Confident / to Player Default, Face: Confident, Apologetic / to Player Default, Face: Apologetic, Grateful / to Player Default, Face: Grateful
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1C
msgctxt "001F8F"
msgid "You got through to me, and I'm in your debt."
msgstr "넌 내 마음을 움직였어. 신세를 졌군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1C
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0035F966, 00530CE3, 00CE972A
#. Notes = Confident / to Player Default, Face: Confident, Apologetic / to Player Default, Face: Apologetic, Grateful / to Player Default, Face: Grateful
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1C
msgctxt "001F90"
msgid "And hey, sorry about the attitude back there. I was just hoping to run you off rather than follow protocol, if you know what I mean."
msgstr "그리고 아까 태도가 나빴던 건 미안해. 무슨 말인지 알겠지만, 규약대로 하기보다는 그냥 널 쫓아내고 싶었을 뿐이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1C
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0035F966, 00530CE3, 00CE972A
#. Notes = Confident / to Player Default, Face: Confident, Apologetic / to Player Default, Face: Apologetic, Grateful / to Player Default, Face: Grateful
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1C
msgctxt "001F91"
msgid "It sure is the perfect opportunity. The Terrans will write us off as just another lost scouting party."
msgstr "정말 완벽한 기회야. 테란들은 우리를 그냥 또 하나의 실종 정찰대로 처리할 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1B
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00DC6D3E, 00178276, 00B240D3
#. Notes = Confident / to Player Default, Face: Confident, Apologetic / to Player Default, Face: Apologetic, Grateful / to Player Default, Face: Grateful
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1B
msgctxt "001F92"
msgid "We don't deserve this chance, but we'll make the most of it."
msgstr "우리는 이 기회를 받을 자격이 없지만, 최대한 잘 활용할게."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1B
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00DC6D3E, 00178276, 00B240D3
#. Notes = Confident / to Player Default, Face: Confident, Apologetic / to Player Default, Face: Apologetic, Grateful / to Player Default, Face: Grateful
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1B
msgctxt "001F93"
msgid "Look, I know I wasn't the easiest to deal with, so I appreciate you trying to get through to me. "
msgstr "봐, 내가 상대하기 쉬운 사람은 아니었다는 거 알아. 그래도 내게 닿으려고 애써 준 건 고맙게 생각해. "

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC1B
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_RudeIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00DC6D3E, 00178276, 00B240D3
#. Notes = Confident / to Player Default, Face: Confident, Apologetic / to Player Default, Face: Apologetic, Grateful / to Player Default, Face: Grateful
#: 0205DC0D/02200/SFTER_INC_SCP01_RudeIntroMainScene:0205DC1B
msgctxt "001F94"
msgid "You're right, and the timing is ideal since we're already out here. With any luck, we'll be labeled MIA and forgotten."
msgstr "네 말이 맞아. 이미 밖에 나와 있으니 타이밍도 딱 좋아. 운이 좋으면 MIA로 분류되고 잊히겠지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC52
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_Misc05Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 001DA23A
#. Notes = Speech challenge lose: You're the ones breaking the peace. It's so hypocritical. / Confident, Face: Confident
#: 0205DC48/02400/SFTER_INC_SCP01_SC_Misc05Scene:0205DC52
msgctxt "001F95"
msgid "You just need to look at the big picture. "
msgstr "넌 큰 그림을 봐야 해. "

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC51
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_Misc05Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00ED223C
#. Notes = Speech challenge win: You're the ones breaking the peace. It's so hypocritical. / Thinking, Face: Thinking
#: 0205DC48/02400/SFTER_INC_SCP01_SC_Misc05Scene:0205DC51
msgctxt "001F96"
msgid "I can see how this looks..."
msgstr "이게 어떻게 보일지는 알아..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC50
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_Misc05Scene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0018C7AB
#. Notes = / to ScoutLeader
#: 0205DC49/02400/SFTER_INC_SCP01_SC_Misc05Scene:0205DC50
msgctxt "001F97"
msgid "You're the ones breaking the peace. It's so hypocritical."
msgstr "평화를 깨는 건 너희야. 정말 위선적이군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC69
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 004E3BB2
#. Notes = Speech challenge lose: You know what you're doing is wrong. / Stern, Face: Stern
#: 0205DC4C/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC69
msgctxt "001F98"
msgid "The Settled Systems left us no choice."
msgstr "개척 성계가 우리에게 다른 선택지를 남기지 않았어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC68
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 008AB66F
#. Notes = Speech challenge lose: You know what you're doing is wrong. / Stern, Face: Stern
#: 0205DC4C/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC68
msgctxt "001F99"
msgid "We do what we must."
msgstr "우리는 해야 할 일을 할 뿐이다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC67
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 003AF344
#. Notes = Speech challenge lose: You know what you're doing is wrong. / Stern, Face: Stern
#: 0205DC4C/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC67
msgctxt "001F9A"
msgid "It's a means to an end."
msgstr "목적을 위한 수단일 뿐이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC65
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 000BD601
#. Notes = Speech challenge win: You know what you're doing is wrong. / Thinking, Face: Thinking
#: 0205DC4C/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC65
msgctxt "001F9B"
msgid " I do sometimes wonder..."
msgstr " 가끔은 나도 생각해..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC64
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00F3C086
#. Notes = Speech challenge win: You know what you're doing is wrong. / Thinking, Face: Thinking
#: 0205DC4C/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC64
msgctxt "001F9C"
msgid "It's not like I've never questioned anything."
msgstr "내가 한 번도 의문을 품지 않은 건 아니야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC63
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 005A3655
#. Notes = Speech challenge win: You know what you're doing is wrong. / Thinking, Face: Thinking
#: 0205DC4C/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC63
msgctxt "001F9D"
msgid "I have my doubts on occasion..."
msgstr "가끔은 의심이 들기도 해..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC77
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 003261C1
#. Notes = / to ScoutLeader
#: 0205DC4E/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC77
msgctxt "001F9E"
msgid "You know what you're doing is wrong, and yet, you do nothing to stop it."
msgstr "네가 하는 일이 잘못됐다는 걸 알면서도, 넌 그걸 막기 위해 아무것도 하지 않아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC76
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00C9AD7D
#. Notes = / to ScoutLeader
#: 0205DC4E/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC76
msgctxt "001F9F"
msgid "Don't act like you can't see how delusional your leaders are."
msgstr "네 지도자들이 얼마나 망상에 빠져 있는지 못 보는 척하지 마."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC75
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00B72332
#. Notes = / to ScoutLeader
#: 0205DC4E/02400/SFTER_INC_SCP01_SC_RepeatableManipulation01Scene:0205DC75
msgctxt "001FA0"
msgid "You know what you're doing is wrong."
msgstr "네가 하는 일이 잘못됐다는 걸 알고 있잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200FB19
#. QuestName = SFTER_CREW_EliteCrew_Delta
#. SceneName = CREW_EliteCrew_Delta_13_TopLevel_PersonalDetails_3
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 005733DF, 0075A681
#. Notes = Does Delta want to admit this? / to Player Default, Prompt: 스스로 정비할 수는 없었어?, Allowed by who? / to Player Default
#: 0200FAA1/00013/CREW_EliteCrew_Delta_13_TopLevel_PersonalDetails_3:0200FB19
msgctxt "001FA1"
msgid "Only human allowed to work on Delta Unit."
msgstr "델타 유닛 작업은 인간만 허용됨."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200FB19
#. QuestName = SFTER_CREW_EliteCrew_Delta
#. SceneName = CREW_EliteCrew_Delta_13_TopLevel_PersonalDetails_3
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 005733DF, 0075A681
#. Notes = Does Delta want to admit this? / to Player Default, Prompt: 스스로 정비할 수는 없었어?, Allowed by who? / to Player Default
#: 0200FAA1/00013/CREW_EliteCrew_Delta_13_TopLevel_PersonalDetails_3:0200FB19
msgctxt "001FA2"
msgid "Counterpoint: Dr. Bourreau best suited for task. Has understanding of intricacies of original construction and modifications made. Work is proficient and deft."
msgstr "반론: 부로 박사가 작업에 최적. 원래 구조와 적용된 개조의 복잡성 이해. 작업 능숙하고 정교함."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C52B
#. QuestName = SFTER_CREW_EliteCrew_Delta
#. SceneName = CREW_EliteCrew_Delta_15_TopLevel_Personal_1
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 000D7F0C, 00F0E83B
#. Notes = Autopilot / to Player Default, Reliving the glory days / to Player Default
#: 0202C51E/00015/CREW_EliteCrew_Delta_15_TopLevel_Personal_1:0202C52B
msgctxt "001FA3"
msgid "Prior to physical transfer, operated at maximum efficiency. Friction, overheating, and other restrictions classified as irrelevant."
msgstr "물리적 이전 전에는 최대 효율로 작동. 마찰, 과열 및 기타 제약은 무관한 것으로 분류."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E5
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00EC987B
#: 0206188B:020618E5
msgctxt "001FE7"
msgid "Do you need to take a break?"
msgstr "잠깐 쉬어야 해?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E4
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00CA6BC0
#: 0206188B:020618E4
msgctxt "001FE8"
msgid "I'm all ears."
msgstr "듣고 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E3
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 003A6574
#: 0206188B:020618E3
msgctxt "001FE9"
msgid "Take your time."
msgstr "천천히 해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618F3
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 0036FC14
#: 0206188C:020618F3
msgctxt "001FEA"
msgid "Anything you need?"
msgstr "필요한 것 있나?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618F2
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00B23240
#: 0206188C:020618F2
msgctxt "001FEB"
msgid "A pleasure."
msgstr "반갑군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618F1
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 0062B617
#: 0206188C:020618F1
msgctxt "001FEC"
msgid "Always on the move."
msgstr "늘 바쁘게 움직이는군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618F0
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00203899
#: 0206188C:020618F0
msgctxt "001FED"
msgid "Ryujin will remain available to help clean up the mess left behind by the Terrans."
msgstr "류진은 테란들이 남긴 혼란을 수습하는 데 계속 도움을 줄 겁니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618EF
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00372224
#: 0206188C:020618EF
msgctxt "001FEE"
msgid "If you come across any Terran threats, do let us know."
msgstr "테란 위협을 발견하면 알려 주십시오."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618CF
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00128E3D
#: 0206188A:020618CF
msgctxt "001FEF"
msgid "I look forward to our next encounter."
msgstr "다음 만남을 기대하겠습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618CE
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00352AE0
#: 0206188A:020618CE
msgctxt "001FF0"
msgid "I'll be here, as always."
msgstr "저는 늘 그렇듯 여기 있겠습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B6
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 0017EAED
#. Notes = Angry, Face: Angry
#: 02061888:020618B6
msgctxt "001FF1"
msgid "You lack business acumen."
msgstr "당신은 비즈니스 감각이 부족하군요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B5
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 002F953C
#. Notes = Angry, Face: Angry
#: 02061888:020618B5
msgctxt "001FF2"
msgid "Do not open a deal you cannot close."
msgstr "마무리할 수 없는 거래를 시작하지 마십시오."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B4
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00D41511
#. Notes = Angry, Face: Angry
#: 02061888:020618B4
msgctxt "001FF3"
msgid "Luck will not favor you long."
msgstr "행운이 오래 따르지는 않을 겁니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C3
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00A61564
#. Notes = InPain, Face: InPain
#: 02061887:020618C3
msgctxt "001FF4"
msgid "This was not in the contract..."
msgstr "이건 계약에 없던 일인데..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E9
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00660D49
#. Notes = InPain, Face: InPain
#: 02061889:020618E9
msgctxt "001FF5"
msgid "Desist now!"
msgstr "지금 중지하십시오!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E8
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 004AEC85
#. Notes = InPain, Face: InPain
#: 02061889:020618E8
msgctxt "001FF6"
msgid "You are simply adding to my hazard pay."
msgstr "제 위험 수당만 늘리고 있을 뿐입니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E7
#. QuestName = SFTER_MS02_Dialogue
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMKenjiKanazawa
#. SoundFileID = 00CF832E
#. Notes = InPain, Face: InPain
#: 02061889:020618E7
msgctxt "001FF7"
msgid "My insurance will cover that!"
msgstr "그건 제 보험이 처리할 겁니다!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D8
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL2
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 001799E9
#: 0206188F/00000/SFTER_MS02_Kenji_MQ02_TL2:020618D8
msgctxt "001FF8"
msgid "What can you tell me about Radha?"
msgstr "라다에 대해 무엇을 말해 줄 수 있지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A4
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL2
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00A522EA
#: 0206188D/00000/SFTER_MS02_Kenji_MQ02_TL2:020618A4
msgctxt "001FF9"
msgid "Those who do not keep the mistakes of our history in mind are bound to repeat them."
msgstr "역사의 실수를 마음에 새기지 않는 자들은 반드시 그것을 반복하게 됩니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AA
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL2
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 006DCD2C
#: 0206188E/00000/SFTER_MS02_Kenji_MQ02_TL2:020618AA
msgctxt "001FFA"
msgid "It has not been long, but I value her perspective. It is my mantra to learn what I can from those who have collected more experience."
msgstr "오래되지는 않았지만, 저는 그녀의 관점을 소중히 여깁니다. 더 많은 경험을 쌓은 사람들에게서 배울 수 있는 것은 배우는 것이 제 신조입니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B8
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL3
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 005D69C8
#: 02061890/00000/SFTER_MS02_Kenji_MQ02_TL3:020618B8
msgctxt "001FFB"
msgid "I am confident we can utilize his expertise to help decide our best courses of action."
msgstr "그의 전문 지식을 활용하면 우리가 최선의 행동 방침을 결정하는 데 도움이 될 것이라 확신합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618E0
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00283A9D
#: 02061897/00000/SFTER_MS02_Kenji_TL1:020618E0
msgctxt "001FFC"
msgid "From what I've gathered, you appear most capable. If you need anything, I hope you will not hesitate to bring it to my attention."
msgstr "제가 들은 바로는 당신은 매우 유능해 보입니다. 필요한 것이 있다면 주저하지 말고 제게 알려 주시길 바랍니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DF
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00B88549, 00C6D9B8
#: 02061897/00000/SFTER_MS02_Kenji_TL1:020618DF
msgctxt "001FFD"
msgid "If you come across anything worth noting out there, I hope you will not hesitate to involve me."
msgstr "밖에서 주목할 만한 것을 발견하면 주저하지 말고 저를 끌어들여 주시길 바랍니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DF
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00B88549, 00C6D9B8
#: 02061897/00000/SFTER_MS02_Kenji_TL1:020618DF
msgctxt "001FFE"
msgid "From what I hear across the Ryujin offices, you are a most capable operative."
msgstr "류진 사무실 곳곳에서 들은 바로는, 당신은 매우 유능한 요원이라고 하더군요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A7
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL1
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0027C9D9
#: 02061896/00000/SFTER_MS02_Kenji_MQ02_TL1:020618A7
msgctxt "001FFF"
msgid "What's VOID again?"
msgstr "VOID가 뭐였지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618CB
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00B86540
#: 02061898/00000/SFTER_MS02_Kenji_TL1:020618CB
msgctxt "002000"
msgid "And I assure you my intentions are pure. I wish only to fulfill Ryujin's stake in these operations and restore our good name."
msgstr "그리고 제 의도는 순수하다고 확언드립니다. 저는 그저 이 작전에서 류진의 지분을 이행하고 우리의 명예를 회복하고 싶을 뿐입니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D5
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 0062C840
#: 02061894/00000/SFTER_MS02_Kenji_MQ02_TL1:020618D5
msgctxt "002001"
msgid "I hope we can turn to you again in the future, if need be."
msgstr "필요하다면 앞으로도 다시 당신에게 의지할 수 있기를 바랍니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DB
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 001EEE9D
#: 02061893/00000/SFTER_MS02_Kenji_MQ02_TL1:020618DB
msgctxt "002002"
msgid "As before VOID continues to prepare for potential threats to the Settled Systems -- Terran or otherwise."
msgstr "이전과 마찬가지로 VOID는 테란이든 아니든 개척 성계에 대한 잠재적 위협에 대비하고 있습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B0
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL3
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00728134
#: 02061891/00000/SFTER_MS02_Kenji_MQ02_TL3:020618B0
msgctxt "002003"
msgid "He is a vital asset to the UC. I can see the value he brings to VOID."
msgstr "그는 UC에 중요한 자산입니다. 그가 VOID에 가져오는 가치를 알 수 있습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618BF
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL3
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 000856F2
#: 02061892/00000/SFTER_MS02_Kenji_MQ02_TL3:020618BF
msgctxt "002004"
msgid "What can you tell me about Tracy?"
msgstr "트레이시에 대해 무엇을 말해 줄 수 있지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AE
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00269492
#: 02061899/00000/SFTER_MS02_Kenji_TL1:020618AE
msgctxt "002005"
msgid "Greetings -- Kenji Kanazawa. I'll be taking over all VOID projects and duties left by my predecessor."
msgstr "안녕하십니까. 켄지 카나자와입니다. 제 전임자가 남긴 모든 VOID 프로젝트와 임무를 제가 맡게 되었습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C5
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL2
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 007D67FB
#: 0206189A/00000/SFTER_MS02_Kenji_TL2:020618C5
msgctxt "002006"
msgid "I look forward to fostering our working relationship going forward."
msgstr "앞으로 우리의 업무 관계를 발전시켜 나가길 기대합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D1
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_MQ02_TL1
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 00597AC4
#: 02061895/00000/SFTER_MS02_Kenji_MQ02_TL1:020618D1
msgctxt "002007"
msgid "As I am a more recent addition, I would think you might be better equipped to answer that question than I."
msgstr "저는 비교적 최근에 합류했으니, 그 질문에는 당신이 저보다 더 잘 답할 수 있을 것 같습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618BC
#. QuestName = SFTER_MS02_Dialogue
#. SceneName = SFTER_MS02_Kenji_TL2
#. DialogCallType = SceneDialogue
#. Speaker = KenjiKanazawa
#. SoundFileID = 007640D5
#: 0206189B/00000/SFTER_MS02_Kenji_TL2:020618BC
msgctxt "002008"
msgid "Ryujin does not place any blame on you, nor do I. On the contrary, I have nothing but respect for people that deliver results as consistently as you have."
msgstr "류진은 당신을 탓하지 않습니다. 저도 마찬가지입니다. 오히려 저는 당신처럼 꾸준히 성과를 내는 사람들을 존중할 뿐입니다."

#. List: 2
#. REC: INFO:NAM1
