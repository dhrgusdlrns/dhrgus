#. SoundFileID = 00B00507
#. Notes = Angry, Face: Angry
#: 0200D26B:0200D2A5
msgctxt "00017B"
msgid "Let's get it done!"
msgstr "끝내 버리자!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200E39B
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Detection
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00811CD6
#. Notes = Angry, Face: Angry
#: 0200D26B:0200E39B
msgctxt "00017C"
msgid "Open fire!"
msgstr "사격 개시!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200E39A
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Detection
