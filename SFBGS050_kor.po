#. EDID: SFBGS034_co_Outpost_Crafting_CrimsonFleet_WorkbenchChem
#. REC: COBJ:DESC
#. FormID: 0209D4A3
msgctxt "00260E"
msgid "Allows crafting of medicines and other pharmaceuticals."
msgstr "의약품과 기타 약품을 제작할 수 있습니다."

