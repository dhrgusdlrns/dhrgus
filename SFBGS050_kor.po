msgctxt "000248"
msgid "Thank you, Delta."
msgstr "고마워, 델타."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200FAD8
#. QuestName = SFTER_CREW_EliteCrew_Delta
#. SceneName = CREW_EliteCrew_Delta_06_System_GiveItem
