#: 020174AD/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:020174AE
msgctxt "0005FC"
msgid "Can I help you?"
msgstr "무슨 일이죠?"

#. List: 2
#. REC: INFO:NAM1
