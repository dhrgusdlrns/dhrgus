#: 0203ADF2/00000/SFTER_CREW_EliteCrew_Delta_Convo_Cora00_01COPY0000:0203AE02
msgctxt "001479"
msgid "Correct."
msgstr "맞습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AE07
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Cora01
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Cora00_01COPY0000
#. DialogCallType = SceneDialogue
