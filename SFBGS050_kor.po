#. DialogCallType = SceneDialogue
#. Speaker = companion
#. SoundFileID = 00E16DA7
#. Notes = Confident, Face: Confident
#: 0203B48A/00000/SFTER_INC_DP01_Companion_StartScene:0203B49C
