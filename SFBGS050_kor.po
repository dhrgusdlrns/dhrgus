#: 0203ADF3/00000/SFTER_CREW_EliteCrew_Delta_Convo_Cora00_01COPY0000:0203AE07
msgctxt "00147A"
msgid "You did that just now?"
msgstr "방금 그걸 한 거야?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AE0E
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Cora01
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Cora00_01COPY0000
