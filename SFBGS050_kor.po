#. SoundFileID = 00070960
#: 0206185D/00000/SFTER_MQ01_AudioLogs_Report03:020618BA
msgctxt "00201E"
msgid "*gunfire*"
msgstr "*총성*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618BD
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 0014C1F7
#: 02061866/00000/SFTER_MQ01_AudioLogs_Report03:020618BD
msgctxt "00201F"
msgid "Hold on, give me a minute first. I might be able to use the reserves to squeeze out a signal long enough for a quick message..."
msgstr "잠깐만, 먼저 1분만 줘. 예비 전력을 써서 짧은 메시지를 보낼 만큼 신호를 짜낼 수 있을지도 몰라..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A2
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 007383F0
#: 02061860/00000/SFTER_MQ01_AudioLogs_Report03:020618A2
msgctxt "002020"
msgid "Oh god, oh god... Ellie, they're here. I can hear them. Please, we have to go!"
msgstr "세상에, 세상에... 엘리, 놈들이 왔어. 소리가 들려. 제발, 가야 해!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A8
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 00A9618C
#: 0206185F/00000/SFTER_MQ01_AudioLogs_Report03:020618A8
msgctxt "002021"
msgid "*hum of consoles whirring up*"
msgstr "*콘솔이 웅웅거리며 켜지는 소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AF
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 00BC1C84
#: 0206185E/00000/SFTER_MQ01_AudioLogs_Report03:020618AF
msgctxt "002022"
msgid "*gunfire*"
msgstr "*총성*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C6
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MS02_TerranSoldier_VoiceOnly_NoAppearanceData
#. SoundFileID = 00258D54
#: 02061865/00000/SFTER_MQ01_AudioLogs_Report03:020618C6
msgctxt "002023"
msgid "Looks like it's transmitting. What do you want to do, ma'am?"
msgstr "송신되는 것 같습니다. 어떻게 하시겠습니까, 부인?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618CC
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AdmiralOdeBalewa
#. SoundFileID = 001C4316
#: 02061864/00000/SFTER_MQ01_AudioLogs_Report03:020618CC
msgctxt "002024"
msgid "Hmph, give it here."
msgstr "흥, 이리 줘."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DA
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00925622
#: 02061876/00000/SFTER_MQ01_AudioLogs_Report02:020618DA
msgctxt "002025"
msgid "Engineering's where the comms are, right? Can't get out a big enough signal unless we use the main beacon."
msgstr "통신 장비는 엔지니어링에 있지? 주 비컨을 쓰지 않으면 충분히 큰 신호를 못 보내."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618EC
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 0008D9CF
#: 0206185B/00000/SFTER_MQ01_AudioLogs_Report03:020618EC
msgctxt "002026"
msgid "*metal footsteps*"
msgstr "*금속성 발소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C1
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 00EA6DD9
#: 0206185C/00000/SFTER_MQ01_AudioLogs_Report03:020618C1
msgctxt "002027"
msgid "*distant metal footsteps*"
msgstr "*멀리서 들리는 금속성 발소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618ED
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00208320
#. Notes = monsters; short moment of realization at the beginning; transition to anguished yell as she's gunned down shortly after
#: 02061861/00000/SFTER_MQ01_AudioLogs_Report03:020618ED
msgctxt "002028"
msgid "Daniel...? N-no... You mons--"
msgstr "다니엘...? 아, 안 돼... 이 괴ㅁ--"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B2
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 002FCE2B
#: 02061867/00000/SFTER_MQ01_AudioLogs_Report03:020618B2
msgctxt "002029"
msgid "Alright, we tried. Let's call it quits and book it out of here while we can."
msgstr "좋아, 해 볼 만큼 해 봤어. 그만두고 지금 도망칠 수 있을 때 나가자."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DD
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00358ADB
#. Notes = panicking, interrupted by gunfire, quick death
#: 02061862/00000/SFTER_MQ01_AudioLogs_Report03:020618DD
msgctxt "00202A"
msgid "Ellie, it's--"
msgstr "엘리, 그건--"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D4
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00F8E2F4
#: 02061877/00000/SFTER_MQ01_AudioLogs_Report01:020618D4
msgctxt "00202B"
msgid "*sigh* There goes my vacation."
msgstr "*한숨* 내 휴가는 날아갔네."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C7
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00F771D6, 00CC8D13
#: 0206186F/00000/SFTER_MQ01_AudioLogs_Report02:020618C7
msgctxt "00202C"
msgid "Why can't we just be smart and hide?"
msgstr "그냥 똑똑하게 숨어 있으면 안 되는 거야?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C7
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00F771D6, 00CC8D13
#: 0206186F/00000/SFTER_MQ01_AudioLogs_Report02:020618C7
msgctxt "00202D"
msgid "If we go boot up that broadcast, we're practically telling all those Terran people -- \"Here we are, come kill us!\""
msgstr "가서 그 방송을 켜면, 그 테란 사람들한테 사실상 '여기 있어요, 와서 죽여 주세요!'라고 알리는 거나 마찬가지야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C4
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 000D493A
#: 02061879/00000/SFTER_MQ01_AudioLogs_Report01:020618C4
msgctxt "00202E"
msgid "*ship impact sounds followed by EMP*"
msgstr "*EMP로 이어지는 함선 충격음*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D6
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 006B235F, 00BBDA62
#. Notes = eye-kow, interrupted by her partner panicking
#: 02061863/00000/SFTER_MQ01_AudioLogs_Report03:020618D6
msgctxt "00202F"
msgid "If anyone can hear this, we've been attacked by--"
msgstr "누구든 이걸 듣고 있다면, 우리는 공격을 받았--"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D6
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 006B235F, 00BBDA62
#. Notes = eye-kow, interrupted by her partner panicking
#: 02061863/00000/SFTER_MQ01_AudioLogs_Report03:020618D6
msgctxt "002030"
msgid "Okay, got it. Testing, testing! This is Ellie Aikau, aboard the Opulence of the Stars."
msgstr "좋아, 됐어. 테스트, 테스트! 여기는 오퓰런스 오브 더 스타에 탑승한 엘리 아이카우입니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AC
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00DA20ED, 0001183C
#: 02061868/00000/SFTER_MQ01_AudioLogs_Report03:020618AC
msgctxt "002031"
msgid "They're... disrupting power somehow? The systems won't switch over."
msgstr "놈들이... 어떻게든 전력을 교란하고 있는 건가? 시스템이 전환되지 않아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AC
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00DA20ED, 0001183C
#: 02061868/00000/SFTER_MQ01_AudioLogs_Report03:020618AC
msgctxt "002032"
msgid "I don't know, I'm not an engineer... But it doesn't look like anything's actually wrong."
msgstr "몰라, 난 엔지니어가 아니야... 하지만 실제로 고장 난 건 없어 보여."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618EA
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 0046F127
#: 02061875/00000/SFTER_MQ01_AudioLogs_Report02:020618EA
msgctxt "002033"
msgid "And what good's that going to do? If those things find us, we're dead!"
msgstr "그게 무슨 소용이야? 저것들이 우릴 찾으면 우리는 죽어!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D0
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 007E3D95, 00651C0A
#: 0206186E/00000/SFTER_MQ01_AudioLogs_Report02:020618D0
msgctxt "002034"
msgid "If we don't do something while we can, they're going to keep doing this... Ship after ship. Planet after planet."
msgstr "지금 할 수 있을 때 뭔가 하지 않으면, 놈들은 계속 이럴 거야... 함선마다. 행성마다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D0
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 007E3D95, 00651C0A
#: 0206186E/00000/SFTER_MQ01_AudioLogs_Report02:020618D0
msgctxt "002035"
msgid "I get that you're scared, Dan... I am too. But we need to do this."
msgstr "네가 무서운 건 알아, 댄... 나도 그래. 하지만 이건 해야 해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D7
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 00BB0D08
#: 0206186D/00000/SFTER_MQ01_AudioLogs_Report02:020618D7
msgctxt "002036"
msgid "*silence, then a distant clank*"
msgstr "*침묵 후 멀리서 둔탁한 소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A9
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report03
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00345E9B
#: 02061869/00000/SFTER_MQ01_AudioLogs_Report03:020618A9
msgctxt "002037"
msgid "ETA on getting the lights back on?"
msgstr "조명 복구 예상 시간은?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A3
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00BAA6A1
#: 0206186A/00000/SFTER_MQ01_AudioLogs_Report02:020618A3
msgctxt "002038"
msgid "There's not going to be a later if we don't move!"
msgstr "움직이지 않으면 나중이라는 건 없어!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618F4
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 004B1705
#: 0206186B/00000/SFTER_MQ01_AudioLogs_Report02:020618F4
msgctxt "002039"
msgid "All right, let me just grab my equipment... We'll figure out the broadcast later."
msgstr "알았어, 장비만 챙길게... 방송은 나중에 어떻게든 해 보자."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618BB
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00144BCB
#: 0206187A/00000/SFTER_MQ01_AudioLogs_Report01:020618BB
msgctxt "00203A"
msgid "Whoa, what was that? Almost felt like--"
msgstr "우와, 방금 뭐였어? 거의--"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DE
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 000B0187
#: 0206186C/00000/SFTER_MQ01_AudioLogs_Report02:020618DE
msgctxt "00203B"
msgid "No, no, no, no... I knew we should've stayed put. They're coming, Ellie."
msgstr "안 돼, 안 돼, 안 돼... 가만히 있었어야 했다고 했잖아. 놈들이 오고 있어, 엘리."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618BE
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 0008107C
#: 02061870/00000/SFTER_MQ01_AudioLogs_Report02:020618BE
msgctxt "00203C"
msgid "Someone out there's got to be listening. A rescue ship, a patrol, hell -- even a passing satellite. If not now, eventually."
msgstr "저 밖에 누군가는 듣고 있을 거야. 구조선이든, 순찰대든, 젠장, 지나가는 위성이든. 지금이 아니면 언젠가는."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618CA
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00CAE9F1
#: 02061878/00000/SFTER_MQ01_AudioLogs_Report01:020618CA
msgctxt "00203D"
msgid "Almost feels like a story, yeah?"
msgstr "거의 이야기 같지 않아?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B7
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 003BC45E
#: 02061871/00000/SFTER_MQ01_AudioLogs_Report02:020618B7
msgctxt "00203E"
msgid "Warn who? We drifted way off course... No one's coming out to the Free Lanes for us."
msgstr "누구한테 경고해? 우린 항로에서 한참 벗어났어... 프리 레인스까지 우릴 찾으러 올 사람은 없어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AD
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00682D99
#: 02061872/00000/SFTER_MQ01_AudioLogs_Report02:020618AD
msgctxt "00203F"
msgid "That's not happening either. You and I both know that. The least we can do is warn everyone else about these people."
msgstr "그것도 안 돼. 너도 나도 알잖아. 우리가 할 수 있는 최소한은 모두에게 이 사람들에 대해 경고하는 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B1
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_SFX_VoiceOnly_NoAppearanceData
#. SoundFileID = 0044E3DB
#: 0206187B/00000/SFTER_MQ01_AudioLogs_Report01:020618B1
msgctxt "002040"
msgid "*rumbling sound*"
msgstr "*우르릉거리는 소리*"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AB
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00883986, 00D815D1
#: 0206187C/00000/SFTER_MQ01_AudioLogs_Report01:020618AB
msgctxt "002041"
msgid "I saw some slots past the lounge earlier. How about we..."
msgstr "아까 라운지 너머에 슬롯머신 몇 대가 보였어. 우리 한번..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618AB
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00883986, 00D815D1
#: 0206187C/00000/SFTER_MQ01_AudioLogs_Report01:020618AB
msgctxt "002042"
msgid "While I'm still riding this high maybe we should try for a real jackpot!"
msgstr "아직 기세가 좋을 때 진짜 잭팟을 노려 봐야 하지 않겠어!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A6
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00882A14
#: 02061873/00000/SFTER_MQ01_AudioLogs_Report02:020618A6
msgctxt "002043"
msgid "Maybe they'll forget about us and we can get away..."
msgstr "어쩌면 놈들이 우릴 잊어버리고 우리가 빠져나갈 수 있을지도..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A0
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00CE3237
#: 02061874/00000/SFTER_MQ01_AudioLogs_Report02:020618A0
msgctxt "002044"
msgid "We're dead either way. You heard them... No survivors. They're not taking any hostages."
msgstr "어차피 죽는 건 마찬가지야. 들었잖아... 생존자 없음. 인질도 안 잡는다고."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618A5
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00EE3020
#. Notes = a bit more playful than before
#: 0206187D/00000/SFTER_MQ01_AudioLogs_Report01:020618A5
msgctxt "002045"
msgid "Yeah, yeah. Enjoy it while you can."
msgstr "그래, 그래. 즐길 수 있을 때 즐겨."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D9
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 0007D564
#: 02061880/00000/SFTER_MQ01_AudioLogs_Report01:020618D9
msgctxt "002046"
msgid "*sigh* Maybe you have a point. Not like there's anything I can really do about it right now."
msgstr "*한숨* 어쩌면 네 말이 맞을지도. 지금 내가 할 수 있는 것도 딱히 없으니까."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C0
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 00CD1FCD
#: 02061883/00000/SFTER_MQ01_AudioLogs_Report01:020618C0
msgctxt "002047"
msgid "They're always sticking us on this empty stuff, though. When are we going to get something with some teeth?"
msgstr "그래도 늘 이런 빈 건수만 우리한테 맡기잖아. 언제쯤 좀 제대로 된 걸 맡게 될까?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618C9
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 007A0F0E
#. Notes = toward italicized/emphasized
#: 02061882/00000/SFTER_MQ01_AudioLogs_Report02:020618C9
msgctxt "002048"
msgid "This is insane. You're insane. Of all the places to run, you want to go toward the army of death robots?"
msgstr "이건 미친 짓이야. 너도 미쳤어. 도망칠 곳이 그렇게 많은데 하필 죽음의 로봇 군대 쪽으로 가자고?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0206189F
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 006D185C
#. Notes = eye-kow
#: 0206187E/00000/SFTER_MQ01_AudioLogs_Report01:0206189F
msgctxt "002049"
msgid "Ellie Aikau -- actually listening to me for once? Did I just hit a jackpot?"
msgstr "엘리 아이카우가, 한 번이라도 내 말을 실제로 듣는다고? 나 방금 잭팟 터뜨린 거야?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D3
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 006F9822, 0027E67F
#: 02061884/00000/SFTER_MQ01_AudioLogs_Report01:020618D3
msgctxt "00204A"
msgid "Sometimes you just want to hear about the good things in life. Gives you something to daydream about."
msgstr "가끔은 삶의 좋은 면에 대해 듣고 싶을 때가 있잖아. 공상할 거리도 생기고."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D3
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 006F9822, 0027E67F
#: 02061884/00000/SFTER_MQ01_AudioLogs_Report01:020618D3
msgctxt "00204B"
msgid "Aw, don't be like that. Not everything people want to read is gonna be award-winning."
msgstr "아, 그러지 마. 사람들이 읽고 싶어 하는 게 전부 수상작 수준일 필요는 없잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618D2
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 0051DEFF
#: 02061881/00000/SFTER_MQ01_AudioLogs_Report01:020618D2
msgctxt "00204C"
msgid "You know, most people would appreciate getting to live it up on company credit."
msgstr "대부분 사람들은 회사 돈으로 호화롭게 지내는 걸 고마워할걸."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618B9
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_EllieAikau
#. SoundFileID = 000ADB82
#. Notes = sarcastic, wants to do actual reporting
#: 02061885/00000/SFTER_MQ01_AudioLogs_Report01:020618B9
msgctxt "00204D"
msgid "Yeah, this is the exactly what I got my degree for -- writing puff pieces on a bunch of yuppies with too many credits to spend."
msgstr "그래, 내가 학위를 딴 이유가 바로 이거지. 쓸 돈이 너무 많은 여피들에 대한 홍보성 기사나 쓰려고."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DC
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00A35366, 00D9F836
#: 02061886/00000/SFTER_MQ01_AudioLogs_Report01:020618DC
msgctxt "00204E"
msgid "Luxury food, Zero-G dance floors, a sonic wave pool... This is the life huh, Ellie?"
msgstr "고급 요리, 무중력 댄스 플로어, 소닉 웨이브 풀... 이게 인생이지, 엘리?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020618DC
#. QuestName = SFTER_MQ01_AudioLogs
#. SceneName = SFTER_MQ01_AudioLogs_Report01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_MQ01_AudioLog_DanielFogel
#. SoundFileID = 00A35366, 00D9F836
#: 02061886/00000/SFTER_MQ01_AudioLogs_Report01:020618DC
msgctxt "00204F"
msgid "Maiden voyage for the Opulence of the Stars, glitz and glamour everywhere you look."
msgstr "오퓰런스 오브 더 스타의 처녀항해, 어디를 봐도 화려함과 매력이 가득하지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F67
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 009EB8F3, 00666E2F
#: 02067F50:02067F67
msgctxt "0021A7"
msgid "Your cooperation is appreciated."
msgstr "협조에 감사드립니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F67
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 009EB8F3, 00666E2F
#: 02067F50:02067F67
msgctxt "0021A8"
msgid "Temporary turbulence detected. Please remain in place while we work to stabilize ship systems. "
msgstr "일시적 난기류가 감지되었습니다. 함선 시스템 안정화 작업 중이니 제자리에 머물러 주십시오. "

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F66
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00C9A59E
#: 02067F50:02067F66
msgctxt "0021A9"
msgid "Initiating diagnostic subroutines cycle."
msgstr "진단 서브루틴 사이클 시작."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F65
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 001879A8
#: 02067F50:02067F65
msgctxt "0021AA"
msgid "Disruption detected. Switching to auxiliary power."
msgstr "교란 감지. 보조 전력으로 전환합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F63
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 009EAE70
#: 02067F50:02067F63
msgctxt "0021AB"
msgid "Access denied. Emergency procedures in effect."
msgstr "접근 거부. 비상 절차가 시행 중입니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F62
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 0000D299
#: 02067F50:02067F62
msgctxt "0021AC"
msgid "Lockdown in progress. Please move to approved areas."
msgstr "봉쇄 진행 중. 승인된 구역으로 이동하십시오."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F61
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00331441
#: 02067F50:02067F61
msgctxt "0021AD"
msgid "Containment will be lifted once hostile activities have ceased."
msgstr "적대 행위가 중단되면 격리가 해제됩니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F60
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00A29BCB
#: 02067F50:02067F60
msgctxt "0021AE"
msgid "Warning: Aggression is against operational regulations. Please desist."
msgstr "경고: 공격 행위는 운용 규정 위반입니다. 중지하십시오."

#. List: 2
#. EDID: SFTER_MQ01_SI_SystemVoice_Thanks
#. REC: INFO:NAM1
#. FormID: 02067F5F
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_1000_SystemVoice_LockdownLifted
#. DialogCallType = Miscellaneous
#. Speaker = ElevatorVoice
#. SoundFileID = 0070FDAC
#. Notes = opulence of the stars = ship name
#: 0209EB14/00000/SFTER_MQ01_1000_SystemVoice_LockdownLifted:02067F5F
msgctxt "0021AF"
msgid "Thank you for choosing the Opulence of the Stars. Please enjoy the rest of your voyage."
msgstr "오퓰런스 오브 더 스타를 이용해 주셔서 감사합니다. 남은 항해를 즐겨 주십시오."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F5E
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00743ED7
#: 02067F50:02067F5E
msgctxt "0021B0"
msgid "Resuming normal operations."
msgstr "정상 운용을 재개합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F5D
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00D981B9
#: 02067F50:02067F5D
msgctxt "0021B1"
msgid "Emergency status has been ended. Releasing detention state in affected areas."
msgstr "비상 상태가 종료되었습니다. 영향 구역의 억류 상태를 해제합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F5C
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 004C6A08
#: 02067F50:02067F5C
msgctxt "0021B2"
msgid "Restarting transmission... Beacon deployed."
msgstr "송신 재시작 중... 비컨 배치됨."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F5B
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 0029E85A
#: 02067F50:02067F5B
msgctxt "0021B3"
msgid "Executing full system cycle. Resolving pending routines..."
msgstr "전체 시스템 사이클 실행 중. 대기 중인 루틴 해결 중..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F5A
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00408EE6
#: 02067F50:02067F5A
msgctxt "0021B4"
msgid "Executing full system cycle. Resolving pending routine... Beacon deployed."
msgstr "전체 시스템 사이클 실행 중. 대기 중인 루틴 해결 중... 비컨 배치됨."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F59
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 007B7510
#: 02067F50:02067F59
msgctxt "0021B5"
msgid "Releasing local lockdown in \"Guest Lodging\"."
msgstr "\"손님 숙소\"의 지역 봉쇄를 해제합니다."

#. List: 2
#. EDID: SFTER_MQ01_SI_SystemVoice_NoPower
#. REC: INFO:NAM1
#. FormID: 02067F58
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0303_SystemVoice_EngineeringElevator
#. DialogCallType = Miscellaneous
#. Speaker = ElevatorVoiceEngineering
#. SoundFileID = 009B12A7
#: 0209EB15/00000/SFTER_MQ01_0303_SystemVoice_EngineeringElevator:02067F58
msgctxt "0021B6"
msgid "Elevator offline. Restore local power to resume functionality."
msgstr "엘리베이터 오프라인. 기능을 재개하려면 지역 전력을 복구하십시오."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F57
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 0004EA9C
#: 02067F50:02067F57
msgctxt "0021B7"
msgid "Re-engaging lockdown procedures. To lift detention state, full system restart is required."
msgstr "봉쇄 절차 재가동. 억류 상태를 해제하려면 전체 시스템 재시작이 필요합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F56
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00119E96
#: 02067F50:02067F56
msgctxt "0021B8"
msgid "Emergency routines in progress."
msgstr "비상 루틴 진행 중."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F55
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00825F37
#: 02067F50:02067F55
msgctxt "0021B9"
msgid "Please remain in your designated area until further notice. We appreciate your cooperation."
msgstr "추가 안내가 있을 때까지 지정 구역에 머물러 주십시오. 협조에 감사드립니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F54
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 00191131
#: 02067F50:02067F54
msgctxt "0021BA"
msgid "Security measures restored. Emergency status still in effect. Proceed with caution. "
msgstr "보안 조치 복구됨. 비상 상태는 여전히 유효합니다. 주의해서 이동하십시오. "

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02067F53
#. QuestName = SFTER_MQ01
#. DialogCallType = Miscellaneous
#. Speaker = SFTER_NPCFTrident02
#. SoundFileID = 003C3D8B
#: 02067F50:02067F53
msgctxt "0021BB"
msgid "Engaging reserve generators. Switching to auxiliary power."
msgstr "예비 발전기 가동. 보조 전력으로 전환합니다."

#. List: 2
#. EDID: SFTER_MQ01_SI_SystemVoice_YesPower
#. REC: INFO:NAM1
#. FormID: 02067F52
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0305_SystemVoice_EngineeringPowerRestored
#. DialogCallType = Miscellaneous
#. Speaker = ElevatorVoiceEngineering
#. SoundFileID = 002069F4
#. Notes = systems voice: "power restored to..." as part of a canned beginning, with the specific area "engineering" being recorded separately
#: 0209EB16/00000/SFTER_MQ01_0305_SystemVoice_EngineeringPowerRestored:02067F52
msgctxt "0021BC"
msgid "Power restored to \"Engineering Deck\"."
msgstr "\"기관실 갑판\"에 전력 복구됨."

#. List: 2
#. EDID: SFFL_SE_KT02_SailingHighSeasSharedInfo01DUPLICATE000
#. REC: INFO:NAM1
#. FormID: 010388B8
#. QuestName = SFFL_SE_KT02_SailingHighSeas
#. SceneName = SFFL_SE_KT02_100b_HailingAnswered
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_SE_KT02_RichPatron01_AudioOnly
#. SoundFileID = 002D1BAB
#. Notes = / to Player Default, Face: Spaceship / Neutral, Prompt: [공격] 아니, 난 다른 관광 안내원과 함께 있어. 우리 일은 너 같은 부유한 임원들을 사냥하는 거야.
#: 01031F7C/00000/SFFL_SE_KT02_100b_HailingAnswered:010388B8
msgctxt "0021C8"
msgid "Goddamnit! Honey, power up those weapons!"
msgstr "젠장! 여보, 무기 가동해!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02069654
msgctxt "00220B"
msgid "What opportunity?"
msgstr "무슨 기회?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02069652
msgctxt "00220C"
msgid "Let me check in with my friend first."
msgstr "먼저 내 친구에게 확인해 볼게."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02069651
msgctxt "00220D"
msgid "Sure, I need to wait for Delta anyway."
msgstr "좋아, 어차피 델타를 기다려야 하니까."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02069653
msgctxt "00220E"
msgid "I'd love if you could tell me about these flowers you're growing."
msgstr "네가 기르는 이 꽃들에 대해 들려주면 좋겠어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0206C2F6
#. QuestName = SFTER_MQ02B
#. SceneName = SFTER_MQ02B_0970_ROX
#. DialogCallType = SceneDialogue
#. Speaker = Roxane
#. SoundFileID = 00F2097F
#. Notes = Somber. She just wants to get out of here. / Somber / to Player Default, Face: Somber
#: 0206C2F4/00970/SFTER_MQ02B_0970_ROX:0206C2F6
msgctxt "002236"
msgid "There we are. Let's."
msgstr "됐어. 가자."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0206C2F7
#. QuestName = SFTER_MQ02B
#. SceneName = SFTER_MQ02B_0970_ROX
#. DialogCallType = SceneDialogue
#. Speaker = Roxane
#. SoundFileID = 00EEA9E8
#. Notes = Somber. She just wants to get out of this place. / Somber / to Player Default, Face: Somber
#: 0206C2F5/00970/SFTER_MQ02B_0970_ROX:0206C2F7
msgctxt "002237"
msgid "Is the door locked? Let me see if I can get it opened."
msgstr "문이 잠겼나? 내가 열 수 있는지 볼게."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02029370
#. QuestName = SFTER_MQ03
#. SceneName = DELTA_FB_0800_05_SFTER_MQ03
#. DialogCallType = SceneDialogue
#. Speaker = UCOfficer
#. SoundFileID = 0062C76D, 00FE0B36
#. Notes = / to UCOfficer
#: 02029359/00000/DELTA_FB_0800_05_SFTER_MQ03:02029370
msgctxt "00226F"
msgid "If they get their guns back online, we're going to be chewed up out here."
msgstr "놈들이 무장을 다시 온라인으로 돌리면, 우린 여기서 갈가리 찢길 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02070DD4
#. QuestName = SFTER_MQ03
#. SceneName = VOID_0410_01_SFTER_MQ03_B
#. DialogCallType = SceneDialogue
#. Speaker = Roxane
#. SoundFileID = 00D783BF
#. Notes = (Alt Line) Defeated. Handing over what Tracy wants. / Somber / to Tracy, Face: Somber
#: 02032977/00000/VOID_0410_01_SFTER_MQ03_B:02070DD4
msgctxt "002281"
msgid "*Sigh* Of course..."
msgstr "*한숨* 물론이지..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02070DD5
#. QuestName = SFTER_MQ03
#. SceneName = VOID_0410_01_SFTER_MQ03_B
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00210621
#. Notes = Serious. Going to tell a battle plan. / Serious / to Player Default, Face: Serious
#: 02032982/00000/VOID_0410_01_SFTER_MQ03_B:02070DD5
msgctxt "002282"
msgid "Right. Listen close."
msgstr "좋아. 잘 들어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02070DD3
#. QuestName = SFTER_MQ03
#. SceneName = VOID_0410_01_SFTER_MQ03_B
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 002AC827
#. Notes = Serious. Going to tell a battle plan. / Serious / to RyujinRep, Face: Serious
#: 02070DD2/00000/VOID_0410_01_SFTER_MQ03_B:02070DD3
msgctxt "002283"
msgid "Right."
msgstr "맞아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FDB
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00A3C253, 003A888E, 00422869
#. Notes = / to Percy
#: 02071FC5/00000/SFTER_MQ03_500_Percy_Prebattle02:02071FDB
msgctxt "002284"
msgid "Ignore anyone here who might get ahead of themselves and tell you otherwise. They're speaking out of emotion."
msgstr "여기서 감정에 앞서 다른 말을 하는 사람이 있더라도 무시해. 그들은 감정적으로 말하는 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FDB
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00A3C253, 003A888E, 00422869
#. Notes = / to Percy
#: 02071FC5/00000/SFTER_MQ03_500_Percy_Prebattle02:02071FDB
msgctxt "002285"
msgid "If any unforeseen opportunities arise, I advice you to play it safe and walk away."
msgstr "예상치 못한 기회가 생기더라도, 안전하게 행동하고 물러나길 조언하지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FDB
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00A3C253, 003A888E, 00422869
#. Notes = / to Percy
#: 02071FC5/00000/SFTER_MQ03_500_Percy_Prebattle02:02071FDB
msgctxt "002286"
msgid "If you get inside the Unifier, stay focused. Override the Grav Drive and get out. No more, no less. There's too much at stake here."
msgstr "유니파이어 안으로 들어가면 집중해. 중력 구동기를 오버라이드하고 빠져나와. 그 이상도 이하도 없어. 걸린 게 너무 많아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD4
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00D6DD98, 0067B722, 0016E34A
#. Notes = / to Player Default
#: 02071FC6/00000/SFTER_MQ03_500_Percy_Prebattle01:02071FD4
msgctxt "002287"
msgid "I just hope everyone keeps it together."
msgstr "모두가 평정심을 유지하길 바랄 뿐이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD4
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00D6DD98, 0067B722, 0016E34A
#. Notes = / to Player Default
#: 02071FC6/00000/SFTER_MQ03_500_Percy_Prebattle01:02071FD4
msgctxt "002288"
msgid "I don't hold it against them, this must feel like loose ends of the Colony war. Emotions are high, and that makes people unreliable."
msgstr "그들을 탓하지는 않아. 이건 식민지 전쟁의 남은 불씨처럼 느껴질 테니까. 감정이 고조되면 사람은 믿기 어려워지지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD4
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00D6DD98, 0067B722, 0016E34A
#. Notes = / to Player Default
#: 02071FC6/00000/SFTER_MQ03_500_Percy_Prebattle01:02071FD4
msgctxt "002289"
msgid "I fear some of our peers might get ahead of themselves and lose sight of the objective."
msgstr "우리 동료들 중 일부가 앞서나가 목표를 놓칠까 두렵군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD3
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00F9ABCD, 00895F4C, 00D10ED6
#. Notes = / to Player Default
#: 02071FC8/00000/SFTER_MQ03_500_Tracy_Prebattle01:02071FD3
msgctxt "00228A"
msgid "Indecisiveness will lead to more death. We need to be decisive."
msgstr "우유부단함은 더 많은 죽음을 부를 거야. 우리는 결단을 내려야 해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD3
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00F9ABCD, 00895F4C, 00D10ED6
#. Notes = / to Player Default
#: 02071FC8/00000/SFTER_MQ03_500_Tracy_Prebattle01:02071FD3
msgctxt "00228B"
msgid "But with that, I intend to utterly crush these Terrans by any means necessary. We need to be vicious and uncompromising."
msgstr "그렇지만 나는 필요한 모든 수단을 동원해 이 테란들을 철저히 짓밟을 생각이야. 우리는 잔혹하고 타협 없이 움직여야 해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD3
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00F9ABCD, 00895F4C, 00D10ED6
#. Notes = / to Player Default
#: 02071FC8/00000/SFTER_MQ03_500_Tracy_Prebattle01:02071FD3
msgctxt "00228C"
msgid "Well, I haven't been involved in a battle of this scale since the Colony War. I'm anxious to say the least."
msgstr "글쎄, 식민지 전쟁 이후로 이 정도 규모의 전투에는 참여한 적이 없어. 적어도 불안한 건 사실이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD2
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00F62525, 00D6598D
#. Notes = / to Player Default
#: 02071FC7/00000/SFTER_MQ03_500_Tracy_Prebattle02:02071FD2
msgctxt "00228D"
msgid "Watch your surroundings, take any opportunities that open up to hurt the enemy, and don't be afraid to lean on our allies for support."
msgstr "주변을 살피고, 적에게 타격을 줄 기회가 보이면 잡아. 그리고 아군의 지원에 기대는 걸 두려워하지 마."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD2
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00F62525, 00D6598D
#. Notes = / to Player Default
#: 02071FC7/00000/SFTER_MQ03_500_Tracy_Prebattle02:02071FD2
msgctxt "00228E"
msgid "Battles of this size get messy real fast. They're usually determined by which force can adapt to the chaos the best."
msgstr "이 정도 규모의 전투는 순식간에 엉망이 돼. 보통 혼돈에 가장 잘 적응하는 쪽이 승패를 가르지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD9
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00CFB157, 007A6E28, 003588FB
#. Notes = / to Player Default
#: 02071FC9/00000/SFTER_MQ03_500_Radha_Prebattle02:02071FD9
msgctxt "00228F"
msgid "Every soldier here will put their life on the line for you out there."
msgstr "여기 있는 모든 병사가 밖에서 너를 위해 목숨을 걸 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD9
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00CFB157, 007A6E28, 003588FB
#. Notes = / to Player Default
#: 02071FC9/00000/SFTER_MQ03_500_Radha_Prebattle02:02071FD9
msgctxt "002290"
msgid "The weakest link is what will determine if we survive this. You don't need to be the one to break the chain."
msgstr "우리가 살아남을지는 가장 약한 고리가 결정해. 네가 그 고리가 될 필요는 없어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD9
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00CFB157, 007A6E28, 003588FB
#. Notes = / to Player Default
#: 02071FC9/00000/SFTER_MQ03_500_Radha_Prebattle02:02071FD9
msgctxt "002291"
msgid "Keep your head down and coordinate with our troops. I know you have a lot of lone wolf experience, but this is war."
msgstr "몸을 낮추고 우리 병력과 협력해. 네가 혼자 움직인 경험이 많다는 건 알지만, 이건 전쟁이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD7
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0052C977, 00F4118F
#. Notes = / to Player Default
#: 02071FCA/00000/SFTER_MQ03_500_Radha_Prebattle01:02071FD7
msgctxt "002292"
msgid "That sentiment is shared by every other person here."
msgstr "여기 있는 다른 모든 사람도 같은 생각일 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD7
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0052C977, 00F4118F
#. Notes = / to Player Default
#: 02071FCA/00000/SFTER_MQ03_500_Radha_Prebattle01:02071FD7
msgctxt "002293"
msgid "Any thoughts? I don't think there's much else to share. We need to ensure after this battle there's nothing left of the Terrans to be a threat."
msgstr "생각? 더 말할 건 별로 없어. 이 전투가 끝난 뒤 테란이 더는 위협이 될 수 없도록 아무것도 남기지 않아야 해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD8
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 004F76D2
#. Notes = / to Tracy
#: 02071FCB/00000/SFTER_MQ03_500_Tracy_Prebattle02:02071FD8
msgctxt "002294"
msgid "Any advice before we attack the Unifier?"
msgstr "유니파이어를 공격하기 전에 조언할 게 있나?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD5
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Tracy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00B2FADF
#. Notes = / to Tracy
#: 02071FCC/00000/SFTER_MQ03_500_Tracy_Prebattle01:02071FD5
msgctxt "002295"
msgid "How do you feel about the battle ahead of us?"
msgstr "앞으로의 전투에 대해 어떻게 생각해?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FDA
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00EBF8B8
#. Notes = / to Radha
#: 02071FCD/00000/SFTER_MQ03_500_Radha_Prebattle02:02071FDA
msgctxt "002296"
msgid "Any advice before I head off?"
msgstr "떠나기 전에 조언할 게 있나?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FDC
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Radha_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0025D064
#. Notes = / to Radha
#: 02071FCE/00000/SFTER_MQ03_500_Radha_Prebattle01:02071FDC
msgctxt "002297"
msgid "Any thoughts on this battle?"
msgstr "이번 전투에 대한 생각은?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD6
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle02
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00472B7B
#. Notes = / to Percy
#: 02071FCF/00000/SFTER_MQ03_500_Percy_Prebattle02:02071FD6
msgctxt "002298"
msgid "Any advice before I head off?"
msgstr "떠나기 전에 조언할 게 있나?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02071FD1
#. QuestName = SFTER_MQ03
#. SceneName = SFTER_MQ03_500_Percy_Prebattle01
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00B3449F
#. Notes = / to Percy
#: 02071FD0/00000/SFTER_MQ03_500_Percy_Prebattle01:02071FD1
msgctxt "002299"
msgid "What do you think about this battle?"
msgstr "이번 전투에 대해 어떻게 생각하지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B9
#. QuestName = SFTER_VOID_RC04
#. SceneName = SFTER_VOID_RC04_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00C5F6C8
#. Notes = Getting a little annoyed now, but trying to remain stoic. Wanting to get this conversation over with. / Stern / to RyujinRep, Face: Stern
#: 02072187/00010/SFTER_VOID_RC04_00:020721B9
msgctxt "0022D7"
msgid "Perhaps not. I suppose we'll see."
msgstr "어쩌면 아닐지도. 두고 보면 알겠지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B2
#. QuestName = SFTER_VOID_RC04
#. SceneName = SFTER_VOID_RC04_00
#. DialogCallType = SceneDialogue
#. Speaker = RyujinRep
#. SoundFileID = 00B5163C
#. Notes = Friendly and trying to find a middle ground. / Friendly / to Radha, Tracy, Face: Friendly
#: 02072188/00010/SFTER_VOID_RC04_00:020721B2
msgctxt "0022D8"
msgid "Fair point. Finding a machine to keep in our pocket for the future wouldn't hurt though."
msgstr "맞는 말이야. 그래도 앞으로 쓸 수 있게 기계 하나쯤 챙겨 두는 것도 나쁘진 않겠지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721AC
#. QuestName = SFTER_VOID_RC04
#. SceneName = SFTER_VOID_RC04_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 0057250A
#. Notes = Serious and annoyed and Percy/Kenji. / Irritated / to RyujinRep, Face: Irritated
#: 02072189/00010/SFTER_VOID_RC04_00:020721AC
msgctxt "0022D9"
msgid "Research that could go towards X-tech."
msgstr "X-테크 연구에 쓰일 수 있는 자료군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A7
#. QuestName = SFTER_VOID_RC04
#. SceneName = SFTER_VOID_RC04_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 003BE1CF
#. Notes = Serious and professional. / Serious / to RyujinRep, Face: Serious
#: 0207218A/00010/SFTER_VOID_RC04_00:020721A7
msgctxt "0022DA"
msgid "Mr. Warren is right. The Terran robots have shown clear signs of faulty manufacturing. To reverse engineer them could take years of research."
msgstr "워렌 씨 말이 맞습니다. 테란 로봇들은 제조 결함의 명확한 징후를 보였습니다. 그것들을 역설계하려면 수년의 연구가 필요할 수도 있습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A5
#. QuestName = SFTER_VOID_RC04
#. SceneName = SFTER_VOID_RC04_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 000DFB96
#. Notes = Upset that Percy/Kenji would even suggest such a thing. / Irritated / to RyujinRep, Face: Irritated
#: 0207218B/00010/SFTER_VOID_RC04_00:020721A5
msgctxt "0022DB"
msgid "Sounds like a terrible idea if you ask me."
msgstr "내 생각을 묻는다면 끔찍한 생각 같군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A4
#. QuestName = SFTER_VOID_RC04
#. SceneName = SFTER_VOID_RC04_00
#. DialogCallType = SceneDialogue
#. Speaker = RyujinRep
#. SoundFileID = 00930E31
#. Notes = Professional, yet friendly. Striking up conversation while thinking about the capabilities of Terran Robots. / Defiant / to Radha, Tracy, Face: Defiant
#: 0207218C/00010/SFTER_VOID_RC04_00:020721A4
msgctxt "0022DC"
msgid "It's a shame the Terran robots have faults in their CPUs. But if we reverse engineer their machines, perhaps we could find ways around the faults and utilize them."
msgstr "테란 로봇의 CPU에 결함이 있다는 건 아쉽군요. 하지만 그들의 기계를 역설계하면 결함을 우회하고 활용할 방법을 찾을 수도 있습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B5
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00D9A1DE
#. Notes = Excited he was right about whiskey. Friendly. / Friendly / to Radha, Face: Friendly
#: 02072193/00010/SFTER_VOID_RC02_00:020721B5
msgctxt "0022DE"
msgid "I knew someone here had to like whiskey! Will do."
msgstr "여기 위스키 좋아하는 사람이 있을 줄 알았어! 알겠어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721AF
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0040F5EF
#. Notes = Friendly and more relaxed. / Friendly / to Percy, Face: Friendly
#: 02072194/00010/SFTER_VOID_RC02_00:020721AF
msgctxt "0022DF"
msgid "I'll take that whiskey."
msgstr "난 그 위스키로 하지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A3
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00413274
#. Notes = Friendly. Wondering if she wants anything. / Friendly / to Radha, Face: Friendly
#: 02072195/00010/SFTER_VOID_RC02_00:020721A3
msgctxt "0022E0"
msgid "Dhawan?"
msgstr "다완?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721AD
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00441822
#. Notes = Surprised that Tracy doesn't drink, but turns back to being friendly and find out something he could get for him. / Friendly / to Tracy, Face: Friendly
#: 02072196/00010/SFTER_VOID_RC02_00:020721AD
msgctxt "0022E1"
msgid "I see. That's my mistake. Maybe a mocktail then? I'll see if she has any mocktails."
msgstr "알겠습니다. 제 실수군요. 그럼 목테일은 어떨까요? 목테일이 있는지 확인해 보겠습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A8
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00327D42
#. Notes = Less irritated and more stoic. / Serious / to Percy, Face: Serious
#: 02072197/00010/SFTER_VOID_RC02_00:020721A8
msgctxt "0022E2"
msgid "No. I don't drink. Never have. Never will."
msgstr "아니. 나는 술을 안 마셔. 예전에도, 앞으로도."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721BA
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 0091B439
#. Notes = A little irritated at Percy. Sarcastic. / Irritated / to Percy, Face: Irritated
#: 02072199/00010/SFTER_VOID_RC02_00:020721BA
msgctxt "0022E3"
msgid "As professional as ever."
msgstr "언제나처럼 프로답군요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A6
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00ACE60D
#. Notes = Friendly and slight teasing at Tracy. / Smug / to Tracy, Face: Smug
#: 02072198/00010/SFTER_VOID_RC02_00:020721A6
msgctxt "0022E4"
msgid "I just think a drink could be good for us is all. You seem like a whiskey kind of guy."
msgstr "그냥 우리에게 한잔이 좋을 것 같다는 생각이었어요. 당신은 위스키가 어울리는 사람 같아서요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B4
#. QuestName = SFTER_VOID_RC02
#. SceneName = SFTER_VOID_RC02_00
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 001C6637
#. Notes = Friendly. / Friendly / to Radha, Tracy, Face: Friendly
#: 0207219A/00010/SFTER_VOID_RC02_00:020721B4
msgctxt "0022E5"
msgid "Dhawan. Warren. I plan to call Valeria to see about getting a few drinks brought down here. Do you want me to put in anything for you?"
msgstr "다완. 워렌. 발레리아에게 연락해서 여기로 술 몇 잔 가져오라고 할 생각인데, 뭐 원하는 거 있나요?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B8
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0079F38F
#. Notes = Mix of somber and stoic. / Serious / to Tracy, Face: Serious
#: 0207219B/00000/SFTER_VOID_RC01_00:020721B8
msgctxt "0022E7"
msgid "I suppose not."
msgstr "그런 것 같군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721AB
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 0020FD2A
#. Notes = Stoic. / Serious / to Radha, Face: Serious
#: 0207219D/00000/SFTER_VOID_RC01_00:020721AB
msgctxt "0022E8"
msgid "I see it."
msgstr "보이네."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B1
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00A09A0B
#. Notes = Stoic. / Serious / to Radha, Face: Serious
#: 0207219C/00000/SFTER_VOID_RC01_00:020721B1
msgctxt "0022E9"
msgid "But who the Terrans were and what could have been doesn't matter much now."
msgstr "하지만 테란이 어떤 사람들이었고 무엇이 될 수 있었는지는 이제 별 의미가 없어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B3
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00827AF6
#. Notes = Slight frustration and somber at how this started. / Serious / to Tracy, Face: Serious
#: 0207219E/00000/SFTER_VOID_RC01_00:020721B3
msgctxt "0022EA"
msgid "The Terrans came together because of the Colony War, and now, we, part of the UC and Freestar, are working together to stop them."
msgstr "테란은 식민지 전쟁 때문에 하나가 되었고, 이제 UC와 자유항성에 속한 우리가 그들을 막기 위해 함께하고 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721AE
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0065387F
#. Notes = Slight frustration and somber at how this started. / to Tracy
#: 0207219F/00000/SFTER_VOID_RC01_00:020721AE
msgctxt "0022EB"
msgid "I know. But surely even you see the irony."
msgstr "알아. 하지만 너도 그 아이러니는 보이겠지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B6
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00E03CAB
#. Notes = Stoic. / Serious / to Radha, Face: Serious
#: 020721A0/00000/SFTER_VOID_RC01_00:020721B6
msgctxt "0022EC"
msgid "One conflict tends to spark another."
msgstr "하나의 분쟁은 또 다른 분쟁의 불씨가 되기 마련이지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A9
#. QuestName = SFTER_VOID_RC01
#. SceneName = SFTER_VOID_RC01_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00F2CF01
#. Notes = Slight frustration and somber at how this started. / Somber / to Tracy, Face: Somber
#: 020721A1/00000/SFTER_VOID_RC01_00:020721A9
msgctxt "0022ED"
msgid "To think, all of this mess because of the Colony Wars."
msgstr "생각해 보면, 이 모든 난장판이 식민지 전쟁들 때문이라니."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721BC
#. QuestName = SFTER_VOID_RC03
#. SceneName = SFTER_VOID_RC03_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00979D59
#. Notes = Serious and professional. / Serious / to Tracy, Face: Serious
#: 0207218E/00010/SFTER_VOID_RC03_00:020721BC
msgctxt "0022EF"
msgid "Of course. I'm going to take a look at it, then I'll send it your way."
msgstr "물론입니다. 제가 살펴본 뒤 당신에게 보내겠습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721A2
#. QuestName = SFTER_VOID_RC03
#. SceneName = SFTER_VOID_RC03_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00B708B8
#. Notes = Professional. Genuine thank you. He may be serious and rough most of the time, he does care about his allies. / Serious / to Radha, Face: Serious
#: 0207218D/00010/SFTER_VOID_RC03_00:020721A2
msgctxt "0022F0"
msgid "Thank you, Mrs. Dhawan."
msgstr "감사합니다, 다완 부인."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B7
#. QuestName = SFTER_VOID_RC03
#. SceneName = SFTER_VOID_RC03_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00B8CBC0
#. Notes = Serious and professional. / Serious / to Radha, Face: Serious
#: 0207218F/00010/SFTER_VOID_RC03_00:020721B7
msgctxt "0022F1"
msgid "After all, the more we know about the Terrans, the better."
msgstr "어쨌든 테란에 대해 더 많이 알수록 좋으니까요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721B0
#. QuestName = SFTER_VOID_RC03
#. SceneName = SFTER_VOID_RC03_00
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 001696DB
#. Notes = Serious and professional. / Serious / to Radha, Face: Serious
#: 02072190/00010/SFTER_VOID_RC03_00:020721B0
msgctxt "0022F2"
msgid "Good. I'll take a look at it when I get the chance."
msgstr "좋습니다. 기회가 되면 살펴보겠습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721AA
#. QuestName = SFTER_VOID_RC03
#. SceneName = SFTER_VOID_RC03_00
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00024B95
#. Notes = Serious and Professional. / Serious / to Tracy, Face: Serious
#: 02072191/00010/SFTER_VOID_RC03_00:020721AA
msgctxt "0022F3"
msgid "A new report from Yemoja has come in."
msgstr "예모자에게서 새 보고가 들어왔습니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721C4
#. QuestName = SFTER_MQ03
#. SceneName = TRACY_SFTER_MQ03_1000_WeaponsDown
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_TracyWarren
#. SoundFileID = 00C59793
#. Notes = / to Player Default
#: 020721C2/00000/TRACY_SFTER_MQ03_1000_WeaponsDown:020721C4
msgctxt "0022F5"
msgid "Their weapon systems are down! It's time to fully mobilize our offensive. Everyone stack up on me, lets wipe them out!"
msgstr "놈들의 무기 시스템이 다운됐다! 이제 공격을 전면 전개할 때다. 모두 내 뒤로 집결해, 놈들을 쓸어버리자!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020721C5
msgctxt "0022F6"
msgid "Their weapon systems are down! It's time to fully mobilize our offensive, wipe them out!"
msgstr "놈들의 무기 시스템이 다운됐다! 이제 공격을 전면 전개해, 놈들을 쓸어버려!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E3
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Radha_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00A0D0B9, 00A2E6FC, 00A04CD1
#. Notes = Professional ad grateful. / Grateful / to Player Default, Face: Grateful, Professional and serious. / Serious / to Player Default, Face: Serious, Professional and grateful. / Grateful / to Player Default
#: 020765CF/00000/SFTER_Radha_PostMQ03_02:020765E3
msgctxt "002332"
msgid "Whatever happens now is on us. You did your job and you did it well. Thank you."
msgstr "이제 무슨 일이 벌어지든 우리 책임이야. 넌 네 일을 훌륭히 해냈어. 고마워."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E3
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Radha_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00A0D0B9, 00A2E6FC, 00A04CD1
#. Notes = Professional ad grateful. / Grateful / to Player Default, Face: Grateful, Professional and serious. / Serious / to Player Default, Face: Serious, Professional and grateful. / Grateful / to Player Default
#: 020765CF/00000/SFTER_Radha_PostMQ03_02:020765E3
msgctxt "002333"
msgid "With the Unifier gone and the Terran's tearing each other apart, I can confidently say we can focus on rebuilding from here."
msgstr "유니파이어가 사라지고 테란들이 서로를 찢어발기고 있으니, 이제부터는 재건에 집중할 수 있다고 자신 있게 말할 수 있겠군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E3
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Radha_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 00A0D0B9, 00A2E6FC, 00A04CD1
#. Notes = Professional ad grateful. / Grateful / to Player Default, Face: Grateful, Professional and serious. / Serious / to Player Default, Face: Serious, Professional and grateful. / Grateful / to Player Default
#: 020765CF/00000/SFTER_Radha_PostMQ03_02:020765E3
msgctxt "002334"
msgid "I think everyone here, including myself is in your debt. I'm not sure I'd be standing here today if not for your actions out there."
msgstr "여기 있는 모두가, 나를 포함해 네게 빚을 졌다고 생각해. 네가 밖에서 행동하지 않았다면 내가 오늘 여기 서 있었을지 모르겠어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E7
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Radha_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0015D4EC, 00757F2C, 001E622C
#. Notes = Professional. But there is a hint of disappointment. / Stern / to Player Default, Face: Stern, Professional. Hint of gratefulness. / Grateful / to Player Default, Face: Grateful
#: 020765D0/00000/SFTER_Radha_PostMQ03_01:020765E7
msgctxt "002335"
msgid "Either way, you have my thanks. You put everything on the line and pulled through. In the end that's what matters."
msgstr "어쨌든 고맙다. 넌 모든 걸 걸었고 끝까지 해냈어. 결국 중요한 건 그거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E7
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Radha_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0015D4EC, 00757F2C, 001E622C
#. Notes = Professional. But there is a hint of disappointment. / Stern / to Player Default, Face: Stern, Professional. Hint of gratefulness. / Grateful / to Player Default, Face: Grateful
#: 020765D0/00000/SFTER_Radha_PostMQ03_01:020765E7
msgctxt "002336"
msgid "That one decision probably could've saved us a lot of headache in the future if they do decide to regroup."
msgstr "그들이 다시 집결하기로 한다면, 그 결정 하나가 앞으로의 골칫거리를 많이 줄였을지도 몰라."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E7
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Radha_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Radha
#. SoundFileID = 0015D4EC, 00757F2C, 001E622C
#. Notes = Professional. But there is a hint of disappointment. / Stern / to Player Default, Face: Stern, Professional. Hint of gratefulness. / Grateful / to Player Default, Face: Grateful
#: 020765D0/00000/SFTER_Radha_PostMQ03_01:020765E7
msgctxt "002337"
msgid "I won't say I'm as pressed as some of our other comrades, but I do think you made a mistake not turning the Terran's robots against them."
msgstr "다른 동료들만큼 조급하다고는 못 하겠지만, 테란의 로봇을 그들에게 돌리지 않은 건 실수였다고 생각해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765F1
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Tracy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00941073, 002A2BCE, 00CCFA1C
#. Notes = / to Player Default
#: 020765D1/00000/SFTER_Tracy_PostMQ03_02:020765F1
msgctxt "002338"
msgid "I don't think we'll be hearing about the Terrans anytime soon, if at all. You may have very well wiped them out entirely."
msgstr "우리가 조만간, 어쩌면 아예 테란 소식을 들을 일은 없을 것 같아. 네가 사실상 그들을 완전히 쓸어버렸을지도 몰라."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765F1
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Tracy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00941073, 002A2BCE, 00CCFA1C
#. Notes = / to Player Default
#: 020765D1/00000/SFTER_Tracy_PostMQ03_02:020765F1
msgctxt "002339"
msgid "Not just that, but thanks to you the entire weight of their robotics network is collapsing on them as we speak."
msgstr "그뿐만 아니라, 네 덕분에 바로 지금 그들의 로봇 네트워크 전체가 자기들 위로 무너지고 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765F1
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Tracy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 00941073, 002A2BCE, 00CCFA1C
#. Notes = / to Player Default
#: 020765D1/00000/SFTER_Tracy_PostMQ03_02:020765F1
msgctxt "00233A"
msgid "Relieved. The Terrans threw just about everything they had at us, and yet here we are."
msgstr "안도감이지. 테란들은 가진 거의 모든 것을 우리에게 퍼부었지만, 그래도 우리는 여기 있잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E9
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00F8DADA, 006E54C8, 00417160
#. Notes = Friendly, yet professional. / Friendly / to Player Default, Face: Friendly, Friendly, yet professional. Trying to be comforting. / Grateful / to Player Default, Face: Grateful
#: 020765D3/00000/SFTER_Percy_PostMQ03_01:020765E9
msgctxt "00233B"
msgid "Your mission was perilous, but in the end you got the job done. That's what matters. Everyone here is in your debt, even if they don't show it."
msgstr "네 임무는 위험했지만, 결국 해냈어. 그게 중요해. 티를 내지 않더라도 여기 있는 모두가 네게 빚을 졌어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E9
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00F8DADA, 006E54C8, 00417160
#. Notes = Friendly, yet professional. / Friendly / to Player Default, Face: Friendly, Friendly, yet professional. Trying to be comforting. / Grateful / to Player Default, Face: Grateful
#: 020765D3/00000/SFTER_Percy_PostMQ03_01:020765E9
msgctxt "00233C"
msgid "No one knows what the consequences of overriding the Terran network would have been. Best we not find out."
msgstr "테란 네트워크를 오버라이드했을 때 어떤 결과가 생겼을지는 아무도 몰라. 모르는 편이 낫지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E9
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00F8DADA, 006E54C8, 00417160
#. Notes = Friendly, yet professional. / Friendly / to Player Default, Face: Friendly, Friendly, yet professional. Trying to be comforting. / Grateful / to Player Default, Face: Grateful
#: 020765D3/00000/SFTER_Percy_PostMQ03_01:020765E9
msgctxt "00233D"
msgid "I think despite everything thrown at us, you remained focused and made the right call."
msgstr "모든 것이 너에게 쏟아졌는데도, 넌 집중력을 잃지 않고 옳은 결정을 내렸다고 생각해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765ED
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Tracy_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 000BBE83, 00427809, 00EAC67A
#. Notes = Annoyed and frustrated. / Irritated / to Player Default, Face: Irritated, Annoyed at the player's choices. / Irritated / to Player Default, A little annoyed, but still sounds grateful and understands the risk and sacrifice the Player took. / Serious / to Player Default, Face: Serious
#: 020765D2/00000/SFTER_Tracy_PostMQ03_01:020765ED
msgctxt "00233E"
msgid "Regardless, thank you for everything. I just hope your decision doesn't comeback to haunt us."
msgstr "어쨌든 모든 것에 고맙다. 다만 네 결정이 나중에 우리를 괴롭히지 않기를 바랄 뿐이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765ED
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Tracy_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 000BBE83, 00427809, 00EAC67A
#. Notes = Annoyed and frustrated. / Irritated / to Player Default, Face: Irritated, Annoyed at the player's choices. / Irritated / to Player Default, A little annoyed, but still sounds grateful and understands the risk and sacrifice the Player took. / Serious / to Player Default, Face: Serious
#: 020765D2/00000/SFTER_Tracy_PostMQ03_01:020765ED
msgctxt "00233F"
msgid "We really don't have any concept of how large the Terran's network is, and you walked away from an prime opportunity to destroy it from the inside."
msgstr "우리는 테란의 네트워크가 얼마나 큰지 전혀 감도 잡지 못하고 있어. 그런데 넌 안에서부터 파괴할 수 있는 절호의 기회를 그냥 지나쳤지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765ED
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Tracy_PostMQ03_01
#. DialogCallType = SceneDialogue
#. Speaker = Tracy
#. SoundFileID = 000BBE83, 00427809, 00EAC67A
#. Notes = Annoyed and frustrated. / Irritated / to Player Default, Face: Irritated, Annoyed at the player's choices. / Irritated / to Player Default, A little annoyed, but still sounds grateful and understands the risk and sacrifice the Player took. / Serious / to Player Default, Face: Serious
#: 020765D2/00000/SFTER_Tracy_PostMQ03_01:020765ED
msgctxt "002340"
msgid "*Sigh* I feel like this battle has just started."
msgstr "*한숨* 이 전투는 이제 막 시작된 것 같은 기분이군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765F3
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00F8F1B0
#. Notes = Annoyed, but trying to stay professional. / Irritated / to Player Default, Face: Irritated, Prompt: Whatever arises, we're more than capable of taking on. I'll be here to lend a hand.
#: 020765D4/00000/SFTER_Percy_PostMQ03_02:020765F3
msgctxt "002341"
msgid "I think you're being insufferably naive."
msgstr "내 생각엔 네가 참을 수 없을 만큼 순진하군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765F2
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 004A0E01
#. Notes = / to Player Default
#: 020765D5/00000/SFTER_Percy_PostMQ03_02:020765F2
msgctxt "002342"
msgid "Whatever arises, we're more than capable of taking on. I'll be here to lend a hand."
msgstr "무슨 일이 생기든 우리는 충분히 감당할 수 있어. 내가 여기서 도울게."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765EA
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 0009E106
#. Notes = / to Player Default
#: 020765D8/00000/SFTER_Percy_PostMQ03_02:020765EA
msgctxt "002343"
msgid "Give me a break. I saved everyone here."
msgstr "웃기지 마. 여기 있는 모두를 내가 구했어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765EC
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 003CC19A
#. Notes = Annoyed, but trying to stay professional. / Irritated / to Player Default, Face: Irritated, Prompt: Give me a break. I saved everyone here.
#: 020765D7/00000/SFTER_Percy_PostMQ03_02:020765EC
msgctxt "002344"
msgid "I wouldn't sound so confident if I were you."
msgstr "나라면 그렇게 자신만만하게 말하지는 않겠어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765EF
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00A7F662, 002505CE
#. Notes = Annoyed, but trying to stay professional. / Irritated / to Player Default, Face: Irritated, Annoyed, but trying to stay professional. / Serious / to Player Default, Face: Serious
#: 020765D6/00000/SFTER_Percy_PostMQ03_02:020765EF
msgctxt "002345"
msgid "Whatever happens from here is on you."
msgstr "이제부터 벌어지는 일은 네 책임이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765EF
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 00A7F662, 002505CE
#. Notes = Annoyed, but trying to stay professional. / Irritated / to Player Default, Face: Irritated, Annoyed, but trying to stay professional. / Serious / to Player Default, Face: Serious
#: 020765D6/00000/SFTER_Percy_PostMQ03_02:020765EF
msgctxt "002346"
msgid "You set loose an army of rogue robots with no central network to limit their target designations."
msgstr "너는 목표 지정을 제한할 중앙 네트워크도 없는 반란 로봇 군대를 풀어놓은 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E8
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00EADFC3
#. Notes = Annoyed, but trying to stay professional. / Irritated / to Player Default, Face: Irritated, Prompt: I ensured the Terrans will never be a threat again.
#: 020765D9/00000/SFTER_Percy_PostMQ03_02:020765E8
msgctxt "002347"
msgid "No one can ever be sure of that. Years ago we hoped we were done with the Colony War, and we know what arose from that."
msgstr "그건 누구도 확신할 수 없어. 몇 년 전 우리는 식민지 전쟁이 끝났다고 믿었지만, 그 뒤 무엇이 생겨났는지 알잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765EE
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00E9DEFD
#. Notes = / to Player Default
#: 020765DA/00000/SFTER_Percy_PostMQ03_02:020765EE
msgctxt "002348"
msgid "I ensured the Terrans will never be a threat again."
msgstr "테란이 다시는 위협이 되지 못하도록 확실히 해 뒀어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E5
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 0031B053, 000D1B8B
#. Notes = Annoyed, but trying to stay professional. / Serious / to Percy, Face: Serious
#: 020765DB/00000/SFTER_Percy_PostMQ03_02:020765E5
msgctxt "002349"
msgid "Who knows what consequences interfering with the Terran network might have?"
msgstr "테란 네트워크에 개입하면 어떤 결과가 생길지 누가 알겠어?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 020765E5
#. QuestName = SFTER_MQ02_GenericDialogue
#. SceneName = SFTER_Percy_PostMQ03_02
#. DialogCallType = SceneDialogue
#. Speaker = Percy
#. SoundFileID = 0031B053, 000D1B8B
#. Notes = Annoyed, but trying to stay professional. / Serious / to Percy, Face: Serious
#: 020765DB/00000/SFTER_Percy_PostMQ03_02:020765E5
msgctxt "00234A"
msgid "If I'm to be entirely honest, I think you stepped way out of line making the call you did."
msgstr "완전히 솔직히 말하자면, 네가 그런 결정을 내린 건 선을 한참 넘었다고 생각해."

#. List: 2
