#. SoundFileID = 00802054
#. Notes = Neutral / to ScoutLeader
#: 0202C30D/02010/SFTER_INC_SCP01_FriendlyIntroDeltaBranchScene:0202C41F
msgctxt "001023"
msgid "Analysis: Elevated heart rate. Chance of deception: 62%."
msgstr "분석: 심박수 상승. 기만 가능성: 62%."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C3F8
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroDeltaBranchScene
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 00CC75B0
#. Notes = Neutral / to Player Default
#: 0202C30C/02010/SFTER_INC_SCP01_FriendlyIntroDeltaBranchScene:0202C3F8
msgctxt "001024"
msgid "Recommending immediate extermination."
msgstr "즉시 말살을 권고."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C375
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0024EA1D
#. Notes = Concerned / to Player Default, Face: Concerned
#: 0202C30E/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0202C375
msgctxt "001025"
msgid "Look, I'm serious. We're just surveyors trying to get a job done."
msgstr "들어봐, 진심이야. 우린 맡은 일을 끝내려는 조사원일 뿐이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C385
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00FFE8CF
#. Notes = / to Player Default
#: 0202C30F/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0202C385
msgctxt "001026"
msgid "It's very coincidental that you happen to be here."
msgstr "마침 당신들이 여기 있다는 게 참 우연이군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C398
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
