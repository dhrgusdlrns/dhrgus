msgid "Everything? Now I know you're lying."
msgstr "전부라고? 이제 네가 거짓말하는 걸 알겠군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC5C
#. QuestName = SFTER_INC_Dialogue
#. SceneName = SFTER_INC_SCP_Surveyor_SC_Misc05Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
