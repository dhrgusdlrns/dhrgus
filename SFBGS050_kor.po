#. SceneName = SFTER_INC_SCP01_Companion_StartScene
#. DialogCallType = SceneDialogue
#. Speaker = companion
#. SoundFileID = 00955E53
#. Notes = Confident, Face: Confident
#: 0203EAEE/00100/SFTER_INC_SCP01_Companion_StartScene:0203EB0D
msgctxt "0019CC"
msgid "I'll let you take the lead on this one."
msgstr "이번엔 네가 앞장서."

#. List: 2
#. REC: INFO:NAM1
