#. Speaker = Delta_04
#. SoundFileID = 008E4B7E
#. Notes = / to Player Default
#: 0202B993/00000/SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose:0202B9B5
msgctxt "000ED5"
msgid "You want to observe me like I'm an animal?"
msgstr "날 동물처럼 관찰하고 싶다는 거야?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202B9C1
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
#. SoundFileID = 00CBC30C
#. Notes = Fascinated by the player / to Player Default
#: 0202B999/00000/SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose:0202B9C1
msgctxt "000ED7"
msgid "You are one of the only humans marked \"Unpredictable\". Require more data to solve you. Ergo, must continue observing you."
msgstr "당신은 \"예측 불가\"로 표시된 몇 안 되는 인간 중 하나임. 당신을 해석하려면 더 많은 데이터가 필요. 따라서 계속 관찰해야 함."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202B9BC
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
#. SoundFileID = 0034D520
#. Notes = Mulling it over / to Player Default
#: 0202B99B/00000/SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose:0202B9BC
msgctxt "000EDB"
msgid "Noting facial expression, requires further clarification."
msgstr "얼굴 표정 기록 중, 추가 설명 필요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202B9B9
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_07_PostCombat_PlayerLose
