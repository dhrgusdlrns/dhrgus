#. SoundFileID = 00AD7BEA
#. Notes = Angry, Face: Angry
#: 0200D26D:0203EB5C
msgctxt "001A1F"
msgid "Scout bot is down."
msgstr "정찰 로봇이 쓰러졌다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB5B
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00665045
#. Notes = Angry, Face: Angry
#: 0200D26D:0203EB5B
msgctxt "001A20"
msgid "Lost a Devastator."
msgstr "섬멸로봇을 잃었다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB4D
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00837F9E
#. Notes = Suspicious, Face: Suspicious
#: 0203EB29:0203EB4D
msgctxt "001A21"
msgid "You can't be here. Go."
msgstr "여기 있으면 안 돼. 가."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB4C
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 0056EBBF
#. Notes = Suspicious, Face: Suspicious
#: 0203EB29:0203EB4C
msgctxt "001A22"
msgid "Move it, you're trespassing."
msgstr "움직여. 무단 침입 중이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB4B
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 007F005A
#. Notes = Suspicious, Face: Suspicious
#: 0203EB29:0203EB4B
msgctxt "001A23"
msgid "Get out of here."
msgstr "여기서 나가."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB4A
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00EE5A4B
#. Notes = Suspicious, Face: Suspicious
#: 0203EB29:0203EB4A
msgctxt "001A24"
msgid "You aren't authorized to be here. Beat it."
msgstr "여기 있을 권한 없어. 꺼져."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB49
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 005ABD4F
#. Notes = Suspicious, Face: Suspicious
#: 0203EB29:0203EB49
msgctxt "001A25"
msgid "You're trespassing. Move."
msgstr "무단 침입 중이야. 움직여."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB47
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00B340E5
#. Notes = angry, about to shoot at trespasser / Suspicious, Face: Suspicious
#: 0203EB29:0203EB47
msgctxt "001A26"
msgid "Get out of here! Last warning!"
msgstr "여기서 나가! 마지막 경고다!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB46
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00C56E23
#. Notes = angry, about to shoot at trespasser / Suspicious, Face: Suspicious
#: 0203EB29:0203EB46
msgctxt "001A27"
msgid "I'm losing my patience! Move!"
msgstr "인내심이 바닥나고 있어! 움직여!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB45
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00DB03F7
#. Notes = angry, about to shoot at trespasser / Suspicious, Face: Suspicious
#: 0203EB29:0203EB45
msgctxt "001A28"
msgid "Don't throw my mercy back in my face. Leave, or get shot!"
msgstr "내 자비를 걷어차지 마. 떠나, 아니면 총 맞는다!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB44
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00D29AC5
#. Notes = angry, about to shoot at trespasser / Suspicious, Face: Suspicious
#: 0203EB29:0203EB44
msgctxt "001A29"
msgid "This is your last chance, you hear me?"
msgstr "마지막 기회야, 알아들어?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203EB43
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Combat
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 0013CECC
#. Notes = angry, about to shoot at trespasser / Suspicious, Face: Suspicious
#: 0203EB29:0203EB43
msgctxt "001A2A"
msgid "Get out of here, or I'll put you down!"
msgstr "여기서 나가. 안 그러면 쓰러뜨려 주마!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5B
#. QuestName = SFTER_DialogueTerranConvo03
#. SceneName = SFTER_DialogueTerranConvo03Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman02
#. SoundFileID = 00D68972, 003F056F
#. Notes = Neutral / to TerranHuman01
#: 0203FC45/00000/SFTER_DialogueTerranConvo03Scene:0203FC5B
msgctxt "001A39"
msgid "Gotta say that I never get tired of seeing the bots go to work."
msgstr "로봇들이 활약하는 걸 보는 건 아무리 봐도 질리지가 않더군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5B
#. QuestName = SFTER_DialogueTerranConvo03
#. SceneName = SFTER_DialogueTerranConvo03Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman02
#. SoundFileID = 00D68972, 003F056F
#. Notes = Neutral / to TerranHuman01
#: 0203FC45/00000/SFTER_DialogueTerranConvo03Scene:0203FC5B
msgctxt "001A3A"
msgid "Yep, all clear. For now, at least."
msgstr "그래, 모두 이상 없어. 적어도 지금은."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC55
#. QuestName = SFTER_DialogueTerranConvo03
#. SceneName = SFTER_DialogueTerranConvo03Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman02
#. SoundFileID = 009EF6D2, 00C5DF58
#. Notes = emphasize "our" in "our" bad side / Neutral / to TerranHuman01, Neutral / to TerranHuman01
#: 0203FC43/00000/SFTER_DialogueTerranConvo03Scene:0203FC55
msgctxt "001A3B"
msgid "I pity anyone that thinks they can resist the Terran Armada."
msgstr "테란 함대에 저항할 수 있다고 생각하는 자들이 불쌍하군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC55
#. QuestName = SFTER_DialogueTerranConvo03
#. SceneName = SFTER_DialogueTerranConvo03Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman02
#. SoundFileID = 009EF6D2, 00C5DF58
#. Notes = emphasize "our" in "our" bad side / Neutral / to TerranHuman01, Neutral / to TerranHuman01
#: 0203FC43/00000/SFTER_DialogueTerranConvo03Scene:0203FC55
msgctxt "001A3C"
msgid "I wouldn't want to get on our bad side, either. "
msgstr "나라도 우리 눈 밖에 나고 싶진 않을 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC59
#. QuestName = SFTER_DialogueTerranConvo03
#. SceneName = SFTER_DialogueTerranConvo03Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman01
#. SoundFileID = 0069F889
#. Notes = Neutral / to TerranHuman02
#: 0203FC44/00000/SFTER_DialogueTerranConvo03Scene:0203FC59
msgctxt "001A3D"
msgid "I hear that. I wouldn't want to get on their bad side."
msgstr "동감이야. 나라도 저들 눈 밖에 나고 싶진 않겠어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5E
#. QuestName = SFTER_DialogueTerranConvo03
#. SceneName = SFTER_DialogueTerranConvo03Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman01
#. SoundFileID = 0073F9CC
#. Notes = Neutral / to TerranHuman02
#: 0203FC47/00000/SFTER_DialogueTerranConvo03Scene:0203FC5E
msgctxt "001A3E"
msgid "All good?"
msgstr "다 괜찮나?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC68
#. QuestName = SFTER_DialogueTerranConvo02
#. SceneName = SFTER_DialogueTerranConvo02Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 009C7B8B
#. Notes = Neutral / to TerranRobot
#: 0203FC4F/00000/SFTER_DialogueTerranConvo02Scene:0203FC68
msgctxt "001A3F"
msgid "Things seem quiet over here."
msgstr "이쪽은 조용해 보인다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5F
#. QuestName = SFTER_DialogueTerranConvo02
#. SceneName = SFTER_DialogueTerranConvo02Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00A70288, 0041540C, 001D38E4
#. Notes = Neutral / to TerranRobot
#: 0203FC4C/00000/SFTER_DialogueTerranConvo02Scene:0203FC5F
msgctxt "001A40"
msgid "Heh, but you already know to do that, don't you?"
msgstr "허, 그래도 그 정도는 이미 알고 있겠지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5F
#. QuestName = SFTER_DialogueTerranConvo02
#. SceneName = SFTER_DialogueTerranConvo02Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00A70288, 0041540C, 001D38E4
#. Notes = Neutral / to TerranRobot
#: 0203FC4C/00000/SFTER_DialogueTerranConvo02Scene:0203FC5F
msgctxt "001A41"
msgid "You spot a hostile, shoot to kill. "
msgstr "적을 발견하면 사살해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5F
#. QuestName = SFTER_DialogueTerranConvo02
#. SceneName = SFTER_DialogueTerranConvo02Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00A70288, 0041540C, 001D38E4
#. Notes = Neutral / to TerranRobot
#: 0203FC4C/00000/SFTER_DialogueTerranConvo02Scene:0203FC5F
msgctxt "001A42"
msgid "Good. Keep the perimeter secure. "
msgstr "좋아. 경계 구역을 계속 확보해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5C
#. QuestName = SFTER_DialogueTerranConvo02
#. SceneName = SFTER_DialogueTerranConvo02Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranRobot
#. SoundFileID = 00CFDBE8
#. Notes = Neutral / to TerranHuman
#: 0203FC4B/00000/SFTER_DialogueTerranConvo02Scene:0203FC5C
msgctxt "001A43"
msgid "Affirmative. All enemies of the Terran Armada will be eliminated. "
msgstr "확인. 테란 함대의 모든 적은 제거됩니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC66
#. QuestName = SFTER_DialogueTerranConvo02
#. SceneName = SFTER_DialogueTerranConvo02Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranRobot
#. SoundFileID = 0040E713
#. Notes = Neutral / to TerranHuman
#: 0203FC4D/00000/SFTER_DialogueTerranConvo02Scene:0203FC66
msgctxt "001A44"
msgid "Affirmative. No hostile activity detected. "
msgstr "확인. 적대 활동 감지되지 않음."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC6B
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene02
#. DialogCallType = SceneDialogue
#. Speaker = TerranRobot
#. SoundFileID = 00D1C3F7
#. Notes = Neutral / to TerranHuman
#: 0203FC4A/00000/SFTER_DialogueTerranConvo01Scene02:0203FC6B
msgctxt "001A45"
msgid "It is recommended to search the area for spare parts that could be used for emergency repairs. "
msgstr "긴급 수리에 사용할 수 있는 예비 부품을 찾기 위해 구역을 수색할 것을 권장합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC6A
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene02
#. DialogCallType = SceneDialogue
#. Speaker = TerranRobot
#. SoundFileID = 006D4594
#. Notes = Neutral / to TerranHuman
#: 0203FC4A/00000/SFTER_DialogueTerranConvo01Scene02:0203FC6A
msgctxt "001A46"
msgid "It is recommended to run diagnostics on all robots that saw combat in the last battle."
msgstr "지난 전투에 참여한 모든 로봇에 진단을 실행할 것을 권장합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC62
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene03
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00DD454F
#. Notes = Neutral / to TerranHuman
#: 0203FC49/00000/SFTER_DialogueTerranConvo01Scene03:0203FC62
msgctxt "001A47"
msgid "Keep your recommendations to yourself. Get back to your patrol. "
msgstr "권장은 됐어. 순찰로 복귀해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC61
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene03
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 007E98BA
#. Notes = Neutral / to TerranHuman
#: 0203FC49/00000/SFTER_DialogueTerranConvo01Scene03:0203FC61
msgctxt "001A48"
msgid "No, not now. Resume your patrol and come to me if you find anything."
msgstr "아니, 지금은 안 돼. 순찰을 재개하고 뭔가 발견하면 나한테 와."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC60
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene03
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00B286A3
#. Notes = didn't want to hear robots recommended action / Neutral / to TerranHuman
#: 0203FC49/00000/SFTER_DialogueTerranConvo01Scene03:0203FC60
msgctxt "001A49"
msgid "Don't got time for that today. Just resume your patrol."
msgstr "오늘은 그럴 시간 없어. 그냥 순찰이나 재개해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC65
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene02
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 000A196B
#. Notes = Neutral / to TerranRobot
#: 0203FC48/00000/SFTER_DialogueTerranConvo01Scene02:0203FC65
msgctxt "001A4A"
msgid "All right. Well, we better move on that quickly, then."
msgstr "좋아. 그렇다면 서둘러 처리해야겠군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC64
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene02
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00CB4181
#. Notes = Neutral / to TerranRobot
#: 0203FC48/00000/SFTER_DialogueTerranConvo01Scene02:0203FC64
msgctxt "001A4B"
msgid "That'll take too much time. Just resume your patrol for now. "
msgstr "그건 시간이 너무 많이 걸려. 지금은 그냥 순찰을 재개해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC63
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene02
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 000DBFCE
#. Notes = Neutral / to TerranRobot
#: 0203FC48/00000/SFTER_DialogueTerranConvo01Scene02:0203FC63
msgctxt "001A4C"
msgid "Well, what are you waiting for? Get it done."
msgstr "그럼 뭘 기다려? 당장 처리해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC67
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranRobot
#. SoundFileID = 00DF67C2
#. Notes = Neutral / to TerranHuman
#: 0203FC50/00000/SFTER_DialogueTerranConvo01Scene:0203FC67
msgctxt "001A4D"
msgid "Acknowledged. May I recommend a course of action?"
msgstr "확인했습니다. 행동 방침을 권장해도 되겠습니까?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC58
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 007F6C90, 00EABA0A
#. Notes = Neutral / to TerranRobot
#: 0203FC51/00000/SFTER_DialogueTerranConvo01Scene:0203FC58
msgctxt "001A4E"
msgid "If that changes, let me know immediately. "
msgstr "상황이 바뀌면 즉시 알려."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC58
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 007F6C90, 00EABA0A
#. Notes = Neutral / to TerranRobot
#: 0203FC51/00000/SFTER_DialogueTerranConvo01Scene:0203FC58
msgctxt "001A4F"
msgid "All right."
msgstr "좋아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC57
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00DDB8E7, 00799DCF
#. Notes = Neutral / to TerranRobot
#: 0203FC51/00000/SFTER_DialogueTerranConvo01Scene:0203FC57
msgctxt "001A50"
msgid "Keep your guard up, though. Don't want anyone getting the drop on us."
msgstr "그래도 경계는 늦추지 마. 누가 우릴 기습하게 둘 순 없지."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC57
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 00DDB8E7, 00799DCF
#. Notes = Neutral / to TerranRobot
#: 0203FC51/00000/SFTER_DialogueTerranConvo01Scene:0203FC57
msgctxt "001A51"
msgid "Okay, good. "
msgstr "좋아, 됐어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5A
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranRobot
#. SoundFileID = 004B20C5
#. Notes = Neutral / to TerranHuman
#: 0203FC52/00000/SFTER_DialogueTerranConvo01Scene:0203FC5A
msgctxt "001A52"
msgid "I am not detecting any unusual activity in my scans. Perimeter is secure."
msgstr "스캔에서 특이 활동이 감지되지 않습니다. 경계 구역은 안전합니다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC5D
#. QuestName = SFTER_DialogueTerranConvo01
#. SceneName = SFTER_DialogueTerranConvo01Scene
#. DialogCallType = SceneDialogue
#. Speaker = TerranHuman
#. SoundFileID = 003A766F
#. Notes = Question / to TerranRobot, Face: Question
#: 0203FC54/00000/SFTER_DialogueTerranConvo01Scene:0203FC5D
msgctxt "001A53"
msgid "Anything to report?"
msgstr "보고할 사항 있나?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02028198
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_1400_Delta_TerranEnd
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 0035EA9D, 0074E805
#. Notes = / to Player Default, Prompt: 잠깐, 여파라고? 위험이 뭐야?
#: 0202811B/00000/SFTER_MQ01_1400_Delta_TerranEnd:02028198
msgctxt "001A54"
msgid "Running cost-benefit analysis..."
msgstr "비용 편익 분석 실행 중..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC73
#. QuestName = SFTER_MQ01
#. SceneName = SFTER_MQ01_0900_Delta_Intro
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 00EB259D
#: 0203FC72/00000/SFTER_MQ01_0900_Delta_Intro:0203FC73
msgctxt "001A55"
msgid "Establishing new moniker... \"Auxiliary Human\". Recompiling... Updating interactions accordingly."
msgstr "새 별칭 설정 중... \"보조 인간\". 재컴파일 중... 그에 맞게 상호작용 업데이트 중."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceC03
#. REC: INFO:NAM1
#. FormID: 0203F2BB
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 001698B0
#. Notes = / to Player Default
#: 0200E06F/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2BB
msgctxt "001A56"
msgid "How'd you come to be way out here?"
msgstr "어쩌다 이렇게 먼 곳까지 오게 됐지?"

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceC02
#. REC: INFO:NAM1
#. FormID: 0203F2BA
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00589E3B
#. Notes = / to Player Default
#: 0200E06F/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2BA
msgctxt "001A57"
msgid "Why are you all the way out here?"
msgstr "왜 이렇게 먼 곳까지 나와 있는 거지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2D2
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00056041
#. Notes = Concerned / to Player Default, Face: Concerned
#: 0200E06B/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2D2
msgctxt "001A58"
msgid "Terrans out here? I guess we can count ourselves lucky we haven't run into anyone. Except for you, of course."
msgstr "여기에 테란이 있다고? 아무도 마주치지 않은 걸 다행으로 여겨야겠네. 물론 당신은 빼고."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2D1
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00DBEB54
#. Notes = Concerned / to Player Default, Face: Concerned
#: 0200E06B/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2D1
msgctxt "001A59"
msgid "Terrans, in this area? I'm not saying your reports are wrong, but we haven't seen anyone else out here, 'cept for you."
msgstr "테란이 이 구역에? 네 보고가 틀렸다는 건 아니지만, 여기서 당신 말고는 아무도 못 봤어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2EE
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 005385DB
#. Notes = Confident / to Player Default, Face: Confident
#: 0200E06D/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2EE
msgctxt "001A5A"
msgid "We're freelance surveyors gathering data. This place looked as good as any to take a quick rest."
msgstr "우린 데이터를 수집하는 프리랜서 탐사원이야. 잠깐 쉬기엔 여기도 괜찮아 보였거든."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C454
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0015A065, 00F0F5D3
#. Notes = Confident / to Player Default, Face: Confident, Friendly / to Player Default, Face: Friendly
#: 0200E06D/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0202C454
msgctxt "001A5B"
msgid "You can sell that data for a nice price in some areas."
msgstr "그런 데이터는 지역에 따라 꽤 좋은 가격에 팔 수 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200E07B
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00214944, 009F6294
#. Notes = Confident / to Player Default, Face: Confident, Friendly / to Player Default, Face: Friendly
#: 0200E06D/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0200E07B
msgctxt "001A5C"
msgid "We're surveyors, so we've got a long way to go."
msgstr "우린 탐사원이라 갈 길이 멀어."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceB03
#. REC: INFO:NAM1
#. FormID: 0203F2E0
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00D3D5FF
#. Notes = / to Player Default
#: 0200E06C/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2E0
msgctxt "001A5D"
msgid "Reports say there are Terran soldiers in the immediate area."
msgstr "보고에 따르면 바로 이 근처에 테란 병사들이 있다."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceB02
#. REC: INFO:NAM1
#. FormID: 0203F2DF
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 0004DBE9
#. Notes = / to Player Default
#: 0200E06C/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2DF
msgctxt "001A5E"
msgid "Terran soldiers have been reported in this area."
msgstr "이 지역에 테란 병사들이 있다는 보고가 있었다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2EC
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00CA85A5
#. Notes = Concerned / to Player Default, Face: Concerned
#: 020174A9/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2EC
msgctxt "001A5F"
msgid "Wait, what? Those Terrans are terrorists. "
msgstr "잠깐, 뭐? 그 테란들은 테러리스트잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2EB
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00054678
#. Notes = Concerned / to Player Default, Face: Concerned
#: 020174A9/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2EB
msgctxt "001A60"
msgid "Terrans? Oh no, we're not Terrans. "
msgstr "테란? 아냐, 우린 테란이 아니야."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceA03
#. REC: INFO:NAM1
#. FormID: 0203F2B6
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = Player Default
#. SoundFileID = 0083909F
#. Notes = / to Player Default
#: 020174AA/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2B6
msgctxt "001A61"
msgid "For a Terran scouting party, you don't look like much."
msgstr "테란 정찰대치고는 별거 없어 보이는데."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceA02
#. REC: INFO:NAM1
#. FormID: 0203F2B5
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = Player Default
#. SoundFileID = 002F435F
#. Notes = / to Player Default
#: 020174AA/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2B5
msgctxt "001A62"
msgid "I believe you're the Terran scouting party I'm looking for."
msgstr "네가 내가 찾던 테란 정찰대인 것 같군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2CD
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0049DC56
#. Notes = Friendly / to Player Default, Face: Friendly
#: 0202C2E3/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2CD
msgctxt "001A63"
msgid "I appreciate the warning. I'll be sure we have someone keeping watch."
msgstr "경고는 고마워. 누군가 망을 보게 할게."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2CC
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00012AD0
#. Notes = Friendly / to Player Default, Face: Friendly
#: 0202C2E3/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2CC
msgctxt "001A64"
msgid "Thanks for the heads up. We'll be sure to keep an eye out."
msgstr "알려줘서 고마워. 꼭 주변을 살필게."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B9
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 008D775D
#. Notes = / to Player Default
#: 0202C2E4/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2B9
msgctxt "001A65"
msgid "You're awfully brave to be in an area where Terrans have been reported."
msgstr "테란이 보고된 지역에 있다니, 대단히 용감하군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B8
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0003CD43
#. Notes = / to Player Default
#: 0202C2E4/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2B8
msgctxt "001A66"
msgid "Terrans have been reported in the area. It's not safe here."
msgstr "이 지역에 테란이 보고됐어. 여긴 안전하지 않아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2F2
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00424CE9
#. Notes = Giving in after being persuaded to talk. / Concerned / to Player Default, Face: Concerned
#: 0202C310/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2F2
msgctxt "001A67"
msgid "*sigh* All right."
msgstr "*한숨* 알았어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2F1
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 007CCBDA
#. Notes = Giving in after being persuaded to talk. / Concerned / to Player Default, Face: Concerned
#: 0202C310/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2F1
msgctxt "001A68"
msgid "Okay, okay..."
msgstr "알았어, 알았다고..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2D6
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00A26EC2
#. Notes = / to Player Default
#: 0202C311/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2D6
msgctxt "001A69"
msgid "I know when people are trying to hide, and you're no surveyor."
msgstr "사람들이 뭔가 숨길 때는 알아볼 수 있어. 넌 탐사원이 아니야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2D5
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00099897
#. Notes = / to Player Default
#: 0202C311/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2D5
msgctxt "001A6A"
msgid "I can tell this is eating at you. Admit the truth, and we can talk."
msgstr "이 일이 널 괴롭히고 있다는 게 보여. 사실을 인정하면 대화할 수 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C7
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 006FB33E
#. Notes = / to Player Default
#: 0202C30F/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2C7
msgctxt "001A6B"
msgid "The coincidence is a little suspect."
msgstr "우연치고는 좀 수상하군."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C6
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 007D7292
#. Notes = / to Player Default
#: 0202C30F/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2C6
msgctxt "001A6C"
msgid "Terrans in the area and you just happen to be the only ones here."
msgstr "이 지역에 테란이 있는데 마침 너희만 여기 있다라."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2DD
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0070F6EB
#. Notes = Concerned / to Player Default, Face: Concerned
#: 0202C30E/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2DD
msgctxt "001A6D"
msgid "I get that the timing bad, but you're got the wrong group. We're just surveyors."
msgstr "시점이 안 좋다는 건 알지만, 사람을 잘못 짚었어. 우린 그냥 탐사원이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2DC
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00D8CBF4
#. Notes = Concerned / to Player Default, Face: Concerned
#: 0202C30E/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2DC
msgctxt "001A6E"
msgid "I see how it looks, but you're wrong. "
msgstr "어떻게 보이는지는 알겠지만, 넌 틀렸어."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceDelta03
#. REC: INFO:NAM1
#. FormID: 0203F2E5
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = Player Default
#. SoundFileID = 004BABCC
#. Notes = / to Player Default
#: 0202C313/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2E5
msgctxt "001A6F"
msgid "[Delta] Delta?"
msgstr "[델타] 델타?"

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceDelta02
#. REC: INFO:NAM1
#. FormID: 0203F2E4
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = Player Default
#. SoundFileID = 00EF4762
#. Notes = / to Player Default
#: 0202C313/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2E4
msgctxt "001A70"
msgid "[Delta] Delta, thoughts?"
msgstr "[델타] 델타, 생각은?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2F7
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00B8D351
#. Notes = Nervous about getting caught. / Nervous / to Player Default, Face: Nervous
#: 0203F2A4/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2F7
msgctxt "001A71"
msgid "Me? I'm terrified, but I've got to keep it together. The last thing I want to do is freak everyone out."
msgstr "나? 무서워 죽겠지만 정신을 붙잡아야 해. 모두를 겁먹게 만드는 건 절대 싫어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2F6
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 00BEFBFC
#. Notes = Nervous about getting caught. / Nervous / to Player Default, Face: Nervous
#: 0203F2A4/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2F6
msgctxt "001A72"
msgid "Are you kidding? I'm a nervous wreck. I just want to keep it together so I don't cause a panic."
msgstr "농담해? 나 완전히 초조해 죽겠어. 괜히 공황을 일으키지 않게 정신을 붙잡고 싶은 것뿐이야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2F5
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0051D348
#. Notes = Nervous about getting caught. / Nervous / to Player Default, Face: Nervous
#: 0203F2A4/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2F5
msgctxt "001A73"
msgid "Believe me, I'm just trying to keep it together for my friends so they don't panic."
msgstr "믿어줘. 친구들이 겁먹지 않게 내가 정신을 붙잡으려는 것뿐이야."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceTerrorists03
#. REC: INFO:NAM1
#. FormID: 0203F2E9
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 009C3488
#. Notes = / to Player Default
#: 0203F2A5/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2E9
msgctxt "001A74"
msgid "I would've thought you'd be more concerned about a major terrorist group being nearby."
msgstr "근처에 대형 테러 조직이 있다면 더 걱정할 줄 알았는데."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceTerrorists02
#. REC: INFO:NAM1
#. FormID: 0203F2E8
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00F49FDF
#. Notes = / to Player Default
#: 0203F2A5/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2E8
msgctxt "001A75"
msgid "You seem pretty calm about a terrorist group in the immediate area."
msgstr "바로 근처에 테러 조직이 있는데도 꽤 침착해 보이는군."

#. List: 2
#. EDID: SFTER_INC_SCP_PlayerChoiceTerrorists01
#. REC: INFO:NAM1
#. FormID: 0203F2E7
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 001263A3
#. Notes = / to Player Default
#: 0203F2A5/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2E7
msgctxt "001A76"
msgid "You don't seem too alarmed to learn there are major terrorists in the area."
msgstr "이 지역에 대형 테러리스트들이 있다는 걸 알았는데도 별로 놀라지 않은 것 같군."

#. List: 2
#. EDID: SFTER_INC_SCP_GiveInResponse03
#. REC: INFO:NAM1
#. FormID: 0203F2DA
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00B68983
#. Notes = Giving in under threat of pain. / Nervous / to Player Default, Face: Nervous
#: 0203F2A6/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2DA
msgctxt "001A77"
msgid "Whoa, okay, all right."
msgstr "워, 알았어, 알았다고."

#. List: 2
#. EDID: SFTER_INC_SCP_GiveInResponse02
#. REC: INFO:NAM1
#. FormID: 0203F2D9
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 0087BC47
#. Notes = Giving in under threat of pain. / Nervous / to Player Default, Face: Nervous
#: 0203F2A6/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2D9
msgctxt "001A78"
msgid "All right, let's just be civil about this..."
msgstr "알았어. 이성적으로 얘기하자..."

#. List: 2
#. EDID: SFTER_INC_SCP_GiveInResponse01
#. REC: INFO:NAM1
#. FormID: 0203F2D8
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 008C0DFE
#. Notes = Giving in under threat of pain. / Nervous / to Player Default, Face: Nervous
#: 0203F2A6/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2D8
msgctxt "001A79"
msgid "Okay, okay!"
msgstr "알았어, 알았어!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C0
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 0093530D
#. Notes = / to Player Default
#: 0203F2A7/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2C0
msgctxt "001A7A"
msgid "Just admit it, or what happens next won't be pleasant for anyone."
msgstr "그냥 인정해. 안 그러면 다음 일은 누구에게도 좋지 않을 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2BF
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 004B3066
#. Notes = / to Player Default
#: 0203F2A7/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2BF
msgctxt "001A7B"
msgid "You can take the easy way and admit it, or we can do this the hard way."
msgstr "쉽게 인정하고 끝내든가, 어렵게 가든가 선택해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2BE
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
#. SoundFileID = 007A84AB
#. Notes = / to Player Default
#: 0203F2A7/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2BE
msgctxt "001A7C"
msgid "Talk, or I guarantee you and all your friends are dead."
msgstr "말해. 안 그러면 너와 네 친구들은 모두 죽는다고 장담하지."

#. List: 2
#. EDID: SFTER_INC_SCP_Confession01
#. REC: INFO:NAM1
#. FormID: 0203F2B2
#. QuestName = SFTER_INC_MIN_ScoutingParty01
#. SceneName = SFTER_INC_SCP01_FriendlyIntroMainScene
#. DialogCallType = Miscellaneous
#. Speaker = ScoutLeader
#. SoundFileID = 00C72009, 00A2C42C, 0061B2AA
#. Notes = Nervous / to Player Default, Face: Nervous, Worried / to Player Default, Face: Worried, Concerned / to Player Default, Face: Concerned
#: 0203F2A8/02000/SFTER_INC_SCP01_FriendlyIntroMainScene:0203F2B2
msgctxt "001A7D"
msgid "We're Terrans, yes, but it's not what you think."
msgstr "우린 테란이 맞아. 하지만 네 생각과는 달라."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203FC76
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_01
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_FrankSantos
#. SoundFileID = 00E5A4A8
#. Notes = NO FACE DATA NEEDED Chastising the body
#: 0203FC75/00000/SFTER_EC_Robot01_AL_01:0203FC76
msgctxt "001A7E"
msgid "No, you were supposed to be perfect, you promised me you would be perfect."
msgstr "안 돼, 넌 완벽해야 했잖아. 완벽할 거라고 약속했잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02041AC3
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_01_PreCombat
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
#. SoundFileID = 00A0D75C, 004E4C88
#. Notes = Oh, and by the way...
#: 02041ABC/00001/SFTER_EC_Robot_Q04_01_PreCombat:02041AC3
msgctxt "001A7F"
msgid "Spent time preparing this encounter. Eager to test new creations."
msgstr "이번 인카운터를 준비하는 데 시간 소모. 새 창작물을 시험하고 싶음."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 02041AC3
#. QuestName = SFTER_EC_Robot_Q04
#. SceneName = SFTER_EC_Robot_Q04_01_PreCombat
#. DialogCallType = SceneDialogue
#. Speaker = Delta_04
#. SoundFileID = 00A0D75C, 004E4C88
#. Notes = Oh, and by the way...
#: 02041ABC/00001/SFTER_EC_Robot_Q04_01_PreCombat:02041AC3
msgctxt "001A80"
msgid "Be advised, preparation is a consistent quality found in superior beings."
msgstr "참고: 준비성은 우월등급 존재에게서 일관되게 발견되는 자질임."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C8
#. QuestName = SFTER_Z01_ConnorDialogue
#. SceneName = SFTER_Z01_Connor_TL_FatherScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00C5325C
#. Notes = / to Player Default
#: 020396A7/00000/SFTER_Z01_Connor_TL_FatherScene:0203F2C8
msgctxt "001A81"
msgid "I should let you go."
msgstr "널 보내줘야겠어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2CE
#. QuestName = SFTER_Z01_ConnorDialogue
#. SceneName = SFTER_Z01_Connor_TL_FatherScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 0062C49A
#. Notes = Somber / to Player Default, Face: Somber, Prompt: 아버지를 육체적으로도 정신적으로도 잃으신 일에 애도를 표합니다.
#: 020396A6/00000/SFTER_Z01_Connor_TL_FatherScene:0203F2CE
msgctxt "001A82"
msgid "That's probably for the best."
msgstr "그게 아마 최선일 거야."

#. List: 2
#. EDID: SFTER_Z01_Connor_SceneReentry01
#. REC: INFO:NAM1
#. FormID: 0203F2C1
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = Miscellaneous
#. Speaker = Connor
#. SoundFileID = 00C6B579
#. Notes = Scene re-entry or preceded by: I didn't think I'd hear from him ever again, but after those threats over SSNN, a part of me knew it was a possibility / Question / to Player Default, Face: Question
#: 02005AEE/00000/SFTER_Z01_Connor_200_SlateScene:0203F2C1
msgctxt "001A83"
msgid "If you don't mind my asking... how did he die?"
msgstr "실례가 안 된다면... 그는 어떻게 죽었나요?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2E1
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00E90F95
#. Notes = / to Player Default
#: 0203F298/00000/SFTER_Z01_Connor_200_SlateScene:0203F2E1
msgctxt "001A84"
msgid "Death was the only way out for an extremist like your father."
msgstr "네 아버지 같은 극단주의자에게 죽음만이 유일한 출구였어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B0
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0012247F, 00592B2E
#. Notes = Serious / to Player Default, Face: Serious
#: 0203F294/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B0
msgctxt "001A85"
msgid "You didn't have to... so thank you."
msgstr "그럴 필요 없었는데... 그러니 고마워."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B0
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0012247F, 00592B2E
#. Notes = Serious / to Player Default, Face: Serious
#: 0203F294/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B0
msgctxt "001A86"
msgid "And I appreciate you delivering the slate, knowing he was the enemy."
msgstr "그가 적이라는 걸 알면서도 슬레이트를 전해줘서 고마워."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2D3
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00AD6B1F
#. Notes = Serious / to Player Default, Face: Serious, Prompt: 서로 이해하게 되어 다행이에요.
#: 0203F299/00000/SFTER_Z01_Connor_200_SlateScene:0203F2D3
msgctxt "001A87"
msgid "We do. My father made his choice."
msgstr "이해해요. 아버지는 자신의 선택을 한 거예요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C4
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00BA1DA6
#. Notes = Scene re-entry line. Already knows his father died. / Depressed / to Player Default, Face: Depressed
#: 02005AEE/00000/SFTER_Z01_Connor_200_SlateScene:0203F2C4
msgctxt "001A88"
msgid "It's hard to admit, but what happened was inevitable."
msgstr "인정하긴 힘들지만, 일어난 일은 필연이었어요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AC
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 005EB7D2, 0013F06A, 00B55C0F
#. Notes = Serious / to Player Default, Face: Serious, Prompt: 전쟁은 우리 모두를 피해자로 만들죠.
#: 0203F295/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AC
msgctxt "001A89"
msgid "I do appreciate you delivering the slate, though. Not anyone would fulfill the last request of an enemy... so thank you."
msgstr "그래도 슬레이트를 전해준 건 정말 고마워요. 아무나 적의 마지막 부탁을 들어주진 않을 테니까... 고마워요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AC
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 005EB7D2, 0013F06A, 00B55C0F
#. Notes = Serious / to Player Default, Face: Serious, Prompt: 전쟁은 우리 모두를 피해자로 만들죠.
#: 0203F295/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AC
msgctxt "001A8A"
msgid "But you probably don't want to be here any longer than you have to."
msgstr "하지만 꼭 필요한 것보다 오래 여기 있고 싶진 않겠죠."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AC
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 005EB7D2, 0013F06A, 00B55C0F
#. Notes = Serious / to Player Default, Face: Serious, Prompt: 전쟁은 우리 모두를 피해자로 만들죠.
#: 0203F295/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AC
msgctxt "001A8B"
msgid "And yet all it takes is the decisions of a few powerful people to subject us all to it."
msgstr "그런데도 몇몇 권력자의 결정만으로 우리 모두가 거기에 휘말리게 되죠."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2CA
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 00FC6A31
#. Notes = / to Player Default
#: 0203F29A/00000/SFTER_Z01_Connor_200_SlateScene:0203F2CA
msgctxt "001A8C"
msgid "I'm glad we have an understanding."
msgstr "서로 이해하게 되어 다행이에요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2A9
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 008B3848
#. Notes = / to Player Default
#: 0203F2A0/00000/SFTER_Z01_Connor_200_SlateScene:0203F2A9
msgctxt "001A8D"
msgid "[Lie] I don't know. He was dead when I found him."
msgstr "[거짓말] 몰라. 내가 찾았을 때는 이미 죽어 있었어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AA
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00DD0572
#. Notes = / to Player Default
#: 0203F296/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AA
msgctxt "001A8E"
msgid "War makes victims of us all."
msgstr "전쟁은 우리 모두를 피해자로 만들죠."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2EF
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00CF04FC
#. Notes = Serious / to Player Default, Face: Serious, Prompt: 네 아버지 같은 극단주의자에게 죽음만이 유일한 출구였어.
#: 0203F297/00000/SFTER_Z01_Connor_200_SlateScene:0203F2EF
msgctxt "001A8F"
msgid "I hate to believe it, but I know you're right."
msgstr "믿고 싶진 않지만, 당신 말이 맞다는 걸 알아요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AD
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00E4C60E
#. Notes = / to Player Default
#: 0203F29C/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AD
msgctxt "001A90"
msgid "I killed him. I'm sorry it had to be this way."
msgstr "내가 죽였어. 이렇게 될 수밖에 없어서 미안해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B1
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0036EC17, 002CBC21, 00C7D4A3, 00F77920
#. Notes = Sad, confused, surprise. / Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 이렇게 될 수밖에 없어서 미안해., Depressed / to Player Default, Face: Depressed
#: 0203F29B/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B1
msgctxt "001A91"
msgid "Just know, I appreciate it. "
msgstr "그 마음만은 알아줘. 정말 고마워."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B1
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0036EC17, 002CBC21, 00C7D4A3, 00F77920
#. Notes = Sad, confused, surprise. / Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 이렇게 될 수밖에 없어서 미안해., Depressed / to Player Default, Face: Depressed
#: 0203F29B/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B1
msgctxt "001A92"
msgid "It must've taken a lot to bring me this slate and then admit the truth of what happened."
msgstr "이 슬레이트를 가져와 주고, 무슨 일이 있었는지 사실대로 인정하는 데 큰 용기가 필요했을 거예요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B1
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0036EC17, 002CBC21, 00C7D4A3, 00F77920
#. Notes = Sad, confused, surprise. / Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 이렇게 될 수밖에 없어서 미안해., Depressed / to Player Default, Face: Depressed
#: 0203F29B/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B1
msgctxt "001A93"
msgid "I... I don't blame you. And maybe it's better this way. He was the enemy, and now he can't hurt anyone else. "
msgstr "난... 당신을 원망하지 않아요. 어쩌면 이게 나을지도 몰라요. 그는 적이었고, 이제 더는 누구도 해칠 수 없으니까요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B1
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0036EC17, 002CBC21, 00C7D4A3, 00F77920
#. Notes = Sad, confused, surprise. / Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 이렇게 될 수밖에 없어서 미안해., Depressed / to Player Default, Face: Depressed
#: 0203F29B/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B1
msgctxt "001A94"
msgid "You? And yet you still came to bring me this..."
msgstr "당신이요? 그런데도 이걸 전해주러 온 거군요..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C9
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0046AED9, 00DE219B, 00DE9125
#. Notes = Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 테란은 죽어 마땅해., Concerned / to Player Default, Face: Concerned, Depressed / to Player Default (+1 more)
#: 0203F29D/00000/SFTER_Z01_Connor_200_SlateScene:0203F2C9
msgctxt "001A95"
msgid "He was a coward who turned his back on his own son."
msgstr "그는 자기 아들에게 등을 돌린 겁쟁이였어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C9
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0046AED9, 00DE219B, 00DE9125
#. Notes = Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 테란은 죽어 마땅해., Concerned / to Player Default, Face: Concerned, Depressed / to Player Default (+1 more)
#: 0203F29D/00000/SFTER_Z01_Connor_200_SlateScene:0203F2C9
msgctxt "001A96"
msgid "He was the enemy, and regardless of what this slate might say, he would've kept killing innocents rather than admit he was wrong."
msgstr "그는 적이었고, 이 슬레이트에 뭐라고 적혀 있든 자신이 틀렸다는 걸 인정하기보다 계속 무고한 사람들을 죽였을 거야."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2C9
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0046AED9, 00DE219B, 00DE9125
#. Notes = Surprised / to Player Default, Face: Surprised, Prompt: 내가 죽였어. 테란은 죽어 마땅해., Concerned / to Player Default, Face: Concerned, Depressed / to Player Default (+1 more)
#: 0203F29D/00000/SFTER_Z01_Connor_200_SlateScene:0203F2C9
msgctxt "001A97"
msgid "You? I... I want to argue, but... in my father's case, I know it's true."
msgstr "당신이요? 나... 반박하고 싶지만... 내 아버지의 경우엔 그 말이 사실이라는 걸 알아요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2B3
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00A81CE9
#. Notes = / to Player Default
#: 0203F29E/00000/SFTER_Z01_Connor_200_SlateScene:0203F2B3
msgctxt "001A98"
msgid "I killed him. The Terrans deserve death."
msgstr "내가 죽였어. 테란은 죽어 마땅해."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AB
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00E80958, 0072115F
#. Notes = Depressed / to Player Default, Face: Depressed, Prompt: 그는 테란의 행성 작전 중 전투에서 죽었어., Concerned / to Player Default, Face: Concerned
#: 0203F2A1/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AB
msgctxt "001A99"
msgid "I guess all I can hope for is that he didn't take any innocent lives before dying himself."
msgstr "이제 바랄 수 있는 건 그가 죽기 전에 무고한 목숨을 빼앗지 않았기를 바라는 것뿐이네요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AB
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00E80958, 0072115F
#. Notes = Depressed / to Player Default, Face: Depressed, Prompt: 그는 테란의 행성 작전 중 전투에서 죽었어., Concerned / to Player Default, Face: Concerned
#: 0203F2A1/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AB
msgctxt "001A9A"
msgid "So, he died for their stupid cause after all. "
msgstr "결국 그 멍청한 대의를 위해 죽은 거군요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AF
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 0000A41E
#. Notes = / to Player Default
#: 0203F2A2/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AF
msgctxt "001A9B"
msgid "He died in combat during a Terran planetary operation."
msgstr "그는 테란의 행성 작전 중 전투에서 죽었어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2CF
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Player Default
#. SoundFileID = 003AB25D
#. Notes = Depressed / to Player Default, Face: Depressed, Prompt: [거짓말] 몰라. 내가 찾았을 때는 이미 죽어 있었어.
#: 0203F29F/00000/SFTER_Z01_Connor_200_SlateScene:0203F2CF
msgctxt "001A9C"
msgid "I knew the Terran Armada would be the death of him, but I guess some part of me always hoped he'd see the truth."
msgstr "테란 함대가 결국 아버지를 죽음으로 몰 거란 걸 알았지만, 마음 한구석으로는 아버지가 진실을 보길 바랐나 봐요."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203F2AE
#. QuestName = SFTER_Z01
#. SceneName = SFTER_Z01_Connor_200_SlateScene
#. DialogCallType = SceneDialogue
#. Speaker = Connor
#. SoundFileID = 00B711CF
#. Notes = Somber / to Player Default, Face: Somber
#: 0203F2A3/00000/SFTER_Z01_Connor_200_SlateScene:0203F2AE
msgctxt "001A9D"
msgid "I... I'll read the slate more in depth later, but... thank you for delivering this."
msgstr "저... 슬레이트는 나중에 더 자세히 읽어볼게요. 그래도... 전해줘서 고마워요."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks07
#. REC: INFO:NAM1
#. FormID: 02042548
#. QuestName = SFTER_INC_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 005C2D00
#. Notes = Player rescued them and they're out of danger. / Grateful, Face: Grateful
#: 0203B6AC:02042548
msgctxt "001AA4"
msgid "Don't let us slow you down. We'll find our way back home."
msgstr "우리 때문에 지체하지 마. 집으로 돌아갈 길은 우리가 찾을게."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks06
#. REC: INFO:NAM1
#. FormID: 02042547
#. QuestName = SFTER_INC_MAJ_AssaultPlatformGround01
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 001D8CC8
#. Notes = Player rescued them and they're out of danger. / Grateful, Face: Grateful
#: 0202C2D8:02042547
msgctxt "001AA5"
msgid "You saved our lives. I thought we were done for."
msgstr "당신이 우리 목숨을 구했어. 우린 끝장인 줄 알았어."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks05
#. REC: INFO:NAM1
#. FormID: 02042546
#. QuestName = SFTER_INC_MAJ_AssaultPlatformGround01
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 0005403E
#. Notes = Player rescued them and they're out of danger. / Grateful, Face: Grateful
#: 0202C2D8:02042546
msgctxt "001AA6"
msgid "You showed up just in time. Thank you."
msgstr "제때 와줬어. 고마워."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks04
#. REC: INFO:NAM1
#. FormID: 02042545
#. QuestName = SFTER_INC_MAJ_AssaultPlatformGround01
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 00B81F01
#. Notes = Player rescued them and they're out of danger. / Grateful, Face: Grateful
#: 0202C2D8:02042545
msgctxt "001AA7"
msgid "Thanks for getting us out of there."
msgstr "거기서 꺼내줘서 고마워."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks03
#. REC: INFO:NAM1
#. FormID: 02042544
#. QuestName = SFTER_INC_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 00F371D2
#. Notes = Player rescued them and they are safe, but the Terran threat is still out there. / Grateful, Face: Grateful
#: 0203B6AC:02042544
msgctxt "001AA8"
msgid "We can take it from here. Go stop those Terrans."
msgstr "여기서부턴 우리가 알아서 할게. 가서 저 테란들을 막아."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks02
#. REC: INFO:NAM1
#. FormID: 02042543
#. QuestName = SFTER_INC_Dialogue
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 005087C0
#. Notes = Player rescued them and they're out of danger. / Grateful, Face: Grateful
#: 0203B6AC:02042543
msgctxt "001AA9"
msgid "Don't worry about us. Help is on the way."
msgstr "우린 걱정하지 마. 구조대가 오고 있어."

#. List: 2
#. EDID: SFTER_INC_Captive_Thanks01
#. REC: INFO:NAM1
#. FormID: 02042542
#. QuestName = SFTER_INC_MAJ_AssaultPlatformGround01
#. DialogCallType = Miscellaneous
#. Speaker = SFFL_NPCMGenericMale02, SFFL_NPCMGenericMale01, SFFL_NPCFGenericFemale01, SFFL_NPCFGenericFemale02 (+4 more)
#. SoundFileID = 00D45EB6
#. Notes = Player rescued them and they're out of danger. / Grateful, Face: Grateful
#: 0202C2D8:02042542
msgctxt "001AAA"
msgid "We're safe, thanks to you."
msgstr "당신 덕분에 우린 안전해졌어."

