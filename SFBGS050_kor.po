#: 0205DC4D/00000/SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene:0205DC56
msgctxt "001F55"
msgid "All cards on the table, huh?"
msgstr "패를 전부 까자는 건가?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0205DC55
#. QuestName = SFTER_INC_Dialogue
#. SceneName = SFTER_INC_SCP_Surveyor_SC_RepeatableManipulation01Scene
#. DialogCallType = SceneDialogue
#. Speaker = ScoutLeader
