#. SoundFileID = 001C166B
#. Notes = Angry, Face: Angry
#: 0200D26B:0200E39A
msgctxt "00017D"
msgid "Take them down!"
msgstr "쓰러뜨려!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200D2A1
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Detection
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 003485A8
#. Notes = Angry, Face: Angry
#: 0200D26B:0200D2A1
msgctxt "00017F"
msgid "Let's go!"
msgstr "가자!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200D2A0
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Detection
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00BCA77A
#. Notes = Angry, Face: Angry
#: 0200D26B:0200D2A0
msgctxt "000180"
msgid "Engaging! "
msgstr "교전한다!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200D29F
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Detection
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 005B8C78
#. Notes = Angry, Face: Angry
#: 0200D26B:0200D29F
msgctxt "000181"
msgid "Fire!"
msgstr "쏴!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200D29E
#. QuestName = SFTER_DialogueGenericTerranHumans
#. DialogCallType = Detection
#. Speaker = SFTER_NPCMTerranGeneric01, SFTER_NPCMTerranGeneric02, SFTER_NPCMTerranGeneric03, SFTER_NPCFTerranGeneric01 (+2 more)
#. SoundFileID = 00E99022
#. Notes = Angry, Face: Angry
#: 0200D26B:0200D29E
msgctxt "000182"
msgid "Take them out!"
msgstr "처치해!"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0200E3A7
