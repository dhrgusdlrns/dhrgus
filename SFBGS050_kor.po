#. List: 1
#. EDID: SFTER_EC_Robot01_FrankBounty_03_MSG
#. REC: MESG:DESC
#. FormID: 02031F17
msgctxt "0011B2"
msgid "Undisclosed crimes against humanity"
msgstr "공개되지 않은 반인도적 범죄"

#. List: 1
#. EDID: SFTER_EC_Robot01_AnnaBounty_00_MSG
#. REC: MESG:DESC
#. FormID: 02031F16
msgctxt "0011B3"
msgid "Trafficking outside of Neon"
msgstr "네온 외부 밀매"

#. List: 1
#. EDID: SFTER_EC_Robot01_FrankBounty_01_MSG
#. REC: MESG:DESC
#. FormID: 02031F1B
msgctxt "0011B4"
msgid "Violation of human anatomy"
