#. SoundFileID = 006ADC39
#. Notes = / to Player Default
#: 0202C542/00000/DELTA_FB_1310_08_SFTER_MQ03:0202C56F
msgctxt "000F70"
msgid "Looping power allocation..."
msgstr "전력 할당 반복 중..."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202C56B
#. QuestName = SFTER_MQ03
#. SceneName = DELTA_FB_1310_08_SFTER_MQ03
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 00607979
#. Notes = / to Player Default
#: 0202C543/00000/DELTA_FB_1310_08_SFTER_MQ03:0202C56B
