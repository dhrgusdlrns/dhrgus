msgid "You think so?"
msgstr "정말 그렇게 생각해?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202757C
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AnnaSantos
#. SoundFileID = 002C67AB, 00F2AF33
#. Notes = NO FACE DATA NEEDED Attempt to inspire
#: 0202756F/00000/SFTER_EC_Robot01_AL_02:0202757C
msgctxt "000ACF"
msgid "So what if someone's missing an eye? You can give them a better one."
msgstr "눈 하나가 없으면 어때? 당신은 더 좋은 눈을 달아줄 수 있잖아."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0202757C
#. QuestName = SFTER_EC_Robot01_AudioLogs
#. SceneName = SFTER_EC_Robot01_AL_02
#. DialogCallType = SceneDialogue
#. Speaker = SFTER_AnnaSantos
