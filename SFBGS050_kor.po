#. SoundFileID = 00695DB6
#. Notes = Nodding / to Barrett
#: 0203AD0D/00000/SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01:0203AD15
msgctxt "0014DF"
msgid "Correct. Dr. Bourreau used foreign substance in unit creation."
msgstr "정확함. 부로 박사는 기체 제작에 외부 물질을 사용했다."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AD1F
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01
#. DialogCallType = SceneDialogue
#. Speaker = Barrett
#. SoundFileID = 007D7E19
#. Notes = Knows they annoy Delta / Friendly / to Delta, Face: Friendly
#: 0203AD0E/00000/SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01:0203AD1F
msgctxt "0014E0"
msgid "Just Barrett works. So, your processor is made of X-Tech, right?"
msgstr "그냥 배럿이라고 불러도 돼. 그래서 네 프로세서는 X-테크로 만들어진 거지?"

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AD25
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01
#. DialogCallType = SceneDialogue
#. Speaker = Delta
#. SoundFileID = 007AB800
#. Notes = Autopilot / to Barrett
#: 0203AD0F/00000/SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01:0203AD25
msgctxt "0014E1"
msgid "Dr. Barrett. Alert: Annoyance levels increased."
msgstr "배럿 박사. 경보: 짜증 수준 상승."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AD20
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01
#. DialogCallType = SceneDialogue
#. Speaker = Barrett
#. SoundFileID = 00B39068
#. Notes = Knows they annoy Delta / Friendly / to Delta, Face: Friendly
#: 0203AD10/00000/SFTER_CREW_EliteCrew_Delta_Convo_Barrett00_01:0203AD20
msgctxt "0014E2"
msgid "Delta! Buddy! I have some questions for you."
msgstr "델타! 친구야! 물어볼 게 좀 있어."

#. List: 2
#. REC: INFO:NAM1
#. FormID: 0203AD17
#. QuestName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett01
#. SceneName = SFTER_CREW_EliteCrew_Delta_Convo_Barrett01_01
